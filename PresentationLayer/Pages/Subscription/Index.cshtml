@page
@model PresentationLayer.Pages.Subscription.IndexModel
@{
    ViewData["Title"] = "Gói hội viên";
    ViewBag.ActiveMenu = "Subscription";

    var info = Model.Info;
    bool isBasic   = info.CurrentPlan == "Basic"   && info.IsActive;
    bool isPro     = info.CurrentPlan == "Pro"     && info.IsActive;
    bool isUltra   = info.CurrentPlan == "Ultra"   && info.IsActive;

    // Quota progress bar (5h) — đơn vị: token
    double pctShort = info.ShortTermLimit == long.MaxValue ? 0 : (info.ShortTermLimit == 0 ? 100 : Math.Min(100.0, info.ShortTermUsedCount * 100.0 / info.ShortTermLimit));
    string barColorShort = pctShort >= 90 ? "var(--pink)" : pctShort >= 60 ? "#f59e0b" : "var(--green)";

    // Quota progress bar (Monthly) — đơn vị: token
    double pctMonth = info.MonthlyLimit == long.MaxValue ? 0 : (info.MonthlyLimit == 0 ? 100 : Math.Min(100.0, info.UsedCount * 100.0 / info.MonthlyLimit));
    string barColorMonth = pctMonth >= 90 ? "var(--pink)" : pctMonth >= 60 ? "#f59e0b" : "var(--green)";

    var vnZone = TimeZoneInfo.FindSystemTimeZoneById(
        System.Runtime.InteropServices.RuntimeInformation.IsOSPlatform(System.Runtime.InteropServices.OSPlatform.Windows)
            ? "SE Asia Standard Time" : "Asia/Ho_Chi_Minh");

    string FmtDateTime(DateTime? dt) => dt == null ? "-" : TimeZoneInfo.ConvertTimeFromUtc(dt.Value, vnZone).ToString("HH:mm dd/MM/yyyy");
}

@section Styles {
<style>
    .plan-card {
        background: var(--white);
        border: 3px solid var(--black);
        box-shadow: 6px 6px 0px var(--black);
        padding: 28px 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        position: relative;
        transition: transform .1s;
        flex: 1;
        min-width: 260px;
    }
    .plan-card.active-plan {
        border-color: var(--pink);
        box-shadow: 6px 6px 0px var(--pink);
    }
    .plan-card:hover { transform: translate(-3px,-3px); }
    .plan-badge {
        position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
        background: var(--pink); color: var(--white);
        border: 2px solid var(--black); padding: 3px 14px;
        font-size: 11px; font-weight: 900; white-space: nowrap; letter-spacing:.5px;
    }
    .plan-name  { font-size: 22px; font-weight: 900; text-align: center; text-transform: uppercase; }
    .plan-price { font-size: 28px; font-weight: 900; text-align: center; color: var(--pink); }
    .plan-price span { font-size: 14px; font-weight: 700; color: #555; }
    .plan-feature { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 700; }
    .plan-feature i { width: 16px; text-align: center; }
    .quota-bar-bg {
        height: 14px; background: #e5e7eb;
        border: 2px solid var(--black); position: relative; overflow: hidden;
    }
    .quota-bar-fill {
        height: 100%; transition: width .4s;
    }
    .upgrade-btn {
        width: 100%; padding: 11px; font-weight: 900; font-size: 14px;
        border: 3px solid var(--black); cursor: pointer;
        box-shadow: 3px 3px 0px var(--black); transition: .1s;
        text-transform: uppercase;
    }
    .upgrade-btn:active { transform: translate(3px,3px); box-shadow: 0 0 0 var(--black); }
    .info-box {
        background: var(--white); border: 3px solid var(--black);
        box-shadow: 5px 5px 0px var(--black); padding: 20px 24px;
    }
</style>
}

<div class="main-wrapper">
<div style="padding: 30px;">

    <h1 style="color:var(--pink); font-weight:900; font-size:28px; text-transform:uppercase; margin-bottom:6px;">
        <i class="fa-solid fa-crown"></i> GÓI HỘI VIÊN
    </h1>
    <p style="font-weight:700; color:#555; margin-bottom:24px;">Nâng cấp gói cước để tăng giới hạn hỏi đáp AI và mở khóa các tính năng cao cấp.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:#d4edda; border:2px solid #28a745; color:#155724; padding:12px 16px; font-weight:800; margin-bottom:20px; font-size:13px;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    <!-- ── TRẠNG THÁI HIỆN TẠI ── -->
    <div class="info-box" style="margin-bottom:28px;">
        <div style="font-weight:900; font-size:16px; margin-bottom:14px; border-bottom:2px dashed #ccc; padding-bottom:8px;">
            <i class="fa-solid fa-circle-info" style="color:var(--blue);"></i> TRẠNG THÁI GÓI CỦA BẠN
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:24px; align-items:flex-start;">
            <div style="flex:1; min-width:200px;">
                <div style="font-size:13px; font-weight:700; color:#555; margin-bottom:4px;">GÓI HIỆN TẠI</div>
                <div style="font-size:20px; font-weight:900; color:@(isUltra ? "#f59e0b" : isPro ? "var(--blue)" : "#555");">
                    @if (isUltra) { <i class="fa-solid fa-crown"></i> } 
                    else if (isPro) { <i class="fa-solid fa-star"></i> }
                    else { <i class="fa-regular fa-circle"></i> }
                    @info.CurrentPlan.ToUpper()
                </div>
                @if (info.CurrentPlan != "Basic" && info.CurrentPlan != "Free" && info.Expiry != null)
                {
                    <div style="font-size:12px; font-weight:700; color:#888; margin-top:4px;">
                        Hết hạn: @FmtDateTime(info.Expiry)
                    </div>
                }
            </div>
            <div style="flex:2; min-width:220px; display:flex; flex-direction:column; gap:16px;">
                
                <!-- Quota 5 Giờ -->
                <div>
                    <div style="font-size:13px; font-weight:700; color:#555; margin-bottom:6px;">
                        <i class="fa-solid fa-clock-rotate-left"></i> CHU KỲ 5 GIỜ (TOKEN)
                        <span style="float:right; color:var(--black);">
                            Đã dùng @(info.ShortTermLimit == long.MaxValue ? "0" : Math.Round(pctShort).ToString())%
                        </span>
                    </div>
                    <div class="quota-bar-bg">
                        <div class="quota-bar-fill" style="width:@(pctShort.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%; background:@barColorShort;"></div>
                    </div>
                    <div style="font-size:11px; font-weight:700; margin-top:4px; color:#555;">
                        @if (info.ShortTermLimit == long.MaxValue)
                        { <span style="color:var(--green);">Không giới hạn <i class="fa-solid fa-infinity"></i></span> }
                        else if (info.ShortTermRemaining == 0)
                        { <span style="color:var(--pink);">Đã hết token — reset vào @FmtDateTime(info.ResetDate)</span> }
                        else
                        { <span>Còn <strong>@(Math.Round(100 - pctShort))%</strong> token — @(info.ResetDate != null ? $"reset vào {FmtDateTime(info.ResetDate)}" : "chu kỳ bắt đầu khi hỏi")</span> }
                    </div>
                </div>

                <!-- Quota Tháng -->
                <div>
                    <div style="font-size:13px; font-weight:700; color:#555; margin-bottom:6px;">
                        <i class="fa-solid fa-calendar-check"></i> CHU KỲ THÁNG (TOKEN)
                        <span style="float:right; color:var(--black);">
                            Đã dùng @(info.MonthlyLimit == long.MaxValue ? "0" : Math.Round(pctMonth).ToString())%
                        </span>
                    </div>
                    <div class="quota-bar-bg">
                        <div class="quota-bar-fill" style="width:@(pctMonth.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%; background:@barColorMonth;"></div>
                    </div>
                    <div style="font-size:11px; font-weight:700; margin-top:4px; color:#555;">
                        @if (info.MonthlyLimit == long.MaxValue)
                        { <span style="color:var(--green);">Không giới hạn <i class="fa-solid fa-infinity"></i></span> }
                        else if (info.Remaining == 0)
                        { <span style="color:var(--pink);">Đã hết token — reset vào @FmtDateTime(info.MonthlyResetDate)</span> }
                        else
                        { <span>Còn <strong>@(Math.Round(100 - pctMonth))%</strong> token — @(info.MonthlyResetDate != null ? $"reset vào {FmtDateTime(info.MonthlyResetDate)}" : "chu kỳ bắt đầu khi hỏi")</span> }
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ── CÁC GÓI ── -->
    <div style="display:flex; flex-wrap:wrap; gap:24px; margin-bottom:32px; align-items:stretch;">
        @foreach (var plan in Model.Plans)
        {
            bool isCurrent = info.CurrentPlan == plan.Name && info.IsActive;
            string iconColor = plan.Name == "Ultra" ? "#f59e0b" : plan.Name == "Pro" ? "var(--blue)" : "#6b7280";
            string planIcon = plan.Name == "Ultra" ? "fa-solid fa-crown" : plan.Name == "Pro" ? "fa-solid fa-star" : "fa-regular fa-circle";
            string borderStyle = plan.Name == "Ultra" && !isCurrent ? "border-color:#f59e0b;" : "";

            <div class="plan-card @(isCurrent ? "active-plan" : "")" style="@borderStyle">
                @if (isCurrent)
                {
                    <div class="plan-badge">GÓI HIỆN TẠI</div>
                }
                else if (plan.Name == "Pro")
                {
                    <div class="plan-badge" style="background:var(--yellow); color:var(--black);">PHỔ BIẾN NHẤT</div>
                }

                <div class="plan-name">
                    <i class="@planIcon" style="color:@iconColor;"></i> @plan.Name
                </div>
                
                <div class="plan-price">
                    @if (plan.Price == 0)
                    {
                        @:MIỄN PHÍ
                    }
                    else
                    {
                        @plan.Price.ToString("N0")<span style="font-size: 20px;">đ</span> <span>/ @plan.DurationDays ngày</span>
                    }
                </div>

                <hr style="border:1px dashed #ccc; margin:4px 0;">

                @foreach (var feature in plan.FeatureList)
                {
                    if (feature.Contains("Hỗ trợ tài liệu đính kèm", StringComparison.OrdinalIgnoreCase))
                        continue;

                    <div class="plan-feature">
                        <i class="fa-solid fa-check" style="color:var(--green);"></i> @feature
                    </div>
                }
                
                @{
                    var realLimit = BussinessLayer.Services.TokenQuota.GetMonthlyTokenLimit(plan.Name);
                    string displayFeature = realLimit == long.MaxValue
                        ? "Không giới hạn token / tháng"
                        : $"Tối đa {realLimit:N0} token / tháng";
                }
                <div class="plan-feature">
                    <i class="fa-solid fa-check" style="color:var(--green);"></i> @displayFeature
                </div>

                <div style="margin-top:auto; padding-top:16px;">
                    @if (isCurrent)
                    {
                        <div style="width:100%; padding:11px; font-weight:900; font-size:14px; border:3px solid #ccc; text-align:center; color:#aaa; background:#f9f9f9; cursor:default;">
                            ĐANG SỬ DỤNG
                        </div>
                    }
                    else if (plan.Price == 0)
                    {
                        <div style="width:100%; padding:11px; font-weight:900; font-size:14px; border:3px solid #ccc; text-align:center; color:#aaa; background:#f9f9f9; cursor:default;">
                            GÓI CƠ BẢN
                        </div>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Upgrade">
                            <input type="hidden" name="plan" value="@plan.Name" />
                            <button type="submit" class="upgrade-btn" style="background:@(plan.Name == "Ultra" ? "#f59e0b" : "var(--blue)"); color:@(plan.Name == "Ultra" ? "var(--black)" : "var(--white)");">
                                <i class="fa-solid fa-arrow-up"></i> ĐĂNG KÝ NGAY
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>

    <!-- ── GHI CHÚ ── -->
    <div style="background:var(--white); border:2px dashed var(--black); padding:16px 20px; font-size:13px; font-weight:700; color:#555; margin-bottom: 32px;">
        <i class="fa-solid fa-triangle-exclamation" style="color:var(--yellow);"></i>
        <strong>Lưu ý về Quota:</strong> Hạn mức được tính theo <b>token AI</b> (lượng văn bản AI đọc + trả lời; 1 câu hỏi thông thường tốn khoảng 3.000–6.000 token) trên 2 chu kỳ: Chu kỳ ngắn hạn 5 Giờ (để chống spam server) và Chu kỳ dài hạn 1 Tháng. Hạn mức sẽ được tự động thiết lập lại khi chu kỳ tương ứng kết thúc.
    </div>

    <!-- ── GÓI NẠP THÊM ── -->
    <div style="margin-bottom: 32px;">
        <h2 style="color:var(--pink); font-weight:900; font-size:24px; text-transform:uppercase; margin-bottom:16px;">
            <i class="fa-solid fa-bolt"></i> GÓI NẠP TOKEN DỰ PHÒNG (ADD-ON)
        </h2>
        <div style="background:var(--white); border:3px solid var(--black); box-shadow:5px 5px 0px var(--black); padding:20px 24px; margin-bottom:24px;">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <div style="font-size:14px; font-weight:700; color:#555; margin-bottom:4px;">TOKEN DỰ PHÒNG CỦA BẠN</div>
                    <div style="font-size:24px; font-weight:900; color:var(--blue);">
                        @info.ExtraQuota.ToString("N0") <span style="font-size:14px; color:#888;">token</span>
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap:12px;">
                    <span style="font-weight:700; font-size:14px; color:#555;">Sử dụng token dự phòng:</span>
                    <label class="switch" style="position:relative; display:inline-block; width:50px; height:24px;">
                        <input type="checkbox" id="toggleExtraQuota" @(info.UseExtraQuota ? "checked" : "") style="opacity:0; width:0; height:0;">
                        <span class="slider round" style="position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background-color:#ccc; transition:.4s; border-radius:34px;">
                            <span class="slider-btn" style="position:absolute; content:''; height:16px; width:16px; left:4px; bottom:4px; background-color:white; transition:.4s; border-radius:50%; @(info.UseExtraQuota ? "transform:translateX(26px);" : "")"></span>
                        </span>
                    </label>
                </div>
            </div>
            <div style="font-size:12px; font-weight:700; color:#888; margin-top:8px;">
                <i class="fa-solid fa-circle-info"></i> Token dự phòng sẽ chỉ bị trừ khi bạn đã dùng hết giới hạn của gói Hội viên. Bạn có thể bật/tắt để kiểm soát việc sử dụng. Token dự phòng sẽ <b>KHÔNG BAO GIỜ</b> hết hạn.
            </div>
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:24px; align-items:stretch;">
            @foreach (var addon in Model.Addons)
            {
                <div class="plan-card" style="min-width:240px; padding:20px;">
                    <div class="plan-name" style="font-size:18px;">
                        <i class="fa-solid fa-bolt" style="color:#f59e0b;"></i> @addon.Name
                    </div>
                    
                    <div class="plan-price" style="font-size:24px;">
                        @addon.Price.ToString("N0")<span style="font-size: 16px;">đ</span>
                    </div>

                    <hr style="border:1px dashed #ccc; margin:8px 0;">

                    <div class="plan-feature" style="justify-content:center; font-size:14px; margin-bottom:12px;">
                        <i class="fa-solid fa-plus" style="color:var(--green);"></i> <strong>@addon.QuotaAmount.ToString("N0")</strong> token
                    </div>
                    
                    <div style="margin-top:auto;">
                        <form method="post" asp-page-handler="BuyAddon">
                            <input type="hidden" name="addonId" value="@addon.Id" />
                            <button type="submit" class="upgrade-btn" style="background:var(--white); color:var(--black); border: 2px solid var(--black); box-shadow: 2px 2px 0px var(--black); padding: 8px;">
                                <i class="fa-solid fa-cart-shopping"></i> MUA NGAY
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

</div>
</div>

@* Token chống CSRF cho lời gọi AJAX tới handler ToggleExtraQuota bên dưới *@
@Html.AntiForgeryToken()

@section Scripts {
    <script>
        document.getElementById('toggleExtraQuota').addEventListener('change', function(e) {
            const isChecked = e.target.checked;
            const sliderBtn = e.target.nextElementSibling.querySelector('.slider-btn');
            
            // UI update
            if(isChecked) {
                sliderBtn.style.transform = 'translateX(26px)';
                e.target.nextElementSibling.style.backgroundColor = 'var(--pink)';
            } else {
                sliderBtn.style.transform = 'translateX(0)';
                e.target.nextElementSibling.style.backgroundColor = '#ccc';
            }

            // Gọi handler của chính trang này
            fetch('?handler=ToggleExtraQuota&useExtraQuota=' + isChecked, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(res => {
                if(!res.ok) {
                    throw new Error('Network response was not ok');
                }
                return res.json();
            })
            .then(data => {
                console.log('Toggle success:', data);
            })
            .catch(err => {
                console.error('Toggle error:', err);
                // Revert UI on error
                e.target.checked = !isChecked;
                if(!isChecked) {
                    sliderBtn.style.transform = 'translateX(26px)';
                    e.target.nextElementSibling.style.backgroundColor = 'var(--pink)';
                } else {
                    sliderBtn.style.transform = 'translateX(0)';
                    e.target.nextElementSibling.style.backgroundColor = '#ccc';
                }
                alert('Có lỗi xảy ra khi cập nhật trạng thái.');
            });
        });

        // Initialize color based on state
        window.addEventListener('DOMContentLoaded', () => {
            const toggle = document.getElementById('toggleExtraQuota');
            if(toggle.checked) {
                toggle.nextElementSibling.style.backgroundColor = 'var(--pink)';
            }
        });
    </script>
}
