@functions {
  private (string Accent, string Soft, string Icon) GetSubjectVisual(string subjectName)
  {
    var name = subjectName ?? string.Empty;
    var n = name.ToLowerInvariant();
    if (n.Contains("ai") || n.Contains("machine")) return ("#4f46e5","#e0e7ff","fa-solid fa-brain");
    if (n.Contains("c#") || n.Contains(".net") || n.Contains("code")) return ("#0f766e","#ccfbf1","fa-solid fa-code");
    if (n.Contains("math") || n.Contains("toan")) return ("#b45309","#fef3c7","fa-solid fa-square-root-variable");
    if (n.Contains("english") || n.Contains("anh")) return ("#2563eb","#dbeafe","fa-solid fa-language");
    if (n.Contains("database") || n.Contains("sql")) return ("#7c3aed","#ede9fe","fa-solid fa-database");
    if (n.Contains("phys") || n.Contains("vat ly")) return ("#dc2626","#fee2e2","fa-solid fa-atom");
    var palette = new[]{("#7c3aed","#ede9fe","fa-solid fa-book-open"),("#0891b2","#cffafe","fa-solid fa-folder-tree"),("#ea580c","#ffedd5","fa-solid fa-folder-open"),("#16a34a","#dcfce7","fa-solid fa-graduation-cap"),("#db2777","#fce7f3","fa-solid fa-pen-nib")};
    var b = name.Sum(ch=>(int)ch); var s=palette[b%palette.Length];
    return (s.Item1,s.Item2,"fa-solid fa-folder-open");
  }
}

<script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
const chatMessages = document.getElementById("chatMessages");
let sessions = [], currentSessionId = null, restrictToDocs = true;
let selectedSubjectId = null;
let connection = null, isStreaming = false;
let streamingMessageEl = null, streamingRawText = "";

function selectSubject(id) {
  // Click lại môn đang chọn (hoặc bấm nút "Tất cả môn học") → quay về chế độ tìm trên tất cả các môn
  selectedSubjectId = (id === null || selectedSubjectId === id) ? null : id;
  document.querySelectorAll(".subject-item").forEach(function(el){ el.classList.remove("active"); });
  var allBtn = document.getElementById("btnAllSubjects");
  if (selectedSubjectId) {
    if (allBtn) allBtn.classList.remove("active");
    var item = document.getElementById("subject-item-" + selectedSubjectId);
    if (item) item.classList.add("active");
  } else {
    if (allBtn) allBtn.classList.add("active");
  }
}

function filterSubjects() {
  var input = document.getElementById("searchSubjectInput");
  var filter = input.value.toLowerCase();
  var nodes = document.querySelectorAll(".subject-item");
  nodes.forEach(function(node) {
    var nameNode = node.querySelector(".subject-item-name");
    if (nameNode) {
      var name = nameNode.textContent.toLowerCase();
      if (name.includes(filter)) {
        node.style.display = "flex";
      } else {
        node.style.display = "none";
      }
    }
  });
}

// ===== SIGNALR =====
async function initSignalR() {
  try {
    connection = new signalR.HubConnectionBuilder()
      .withUrl("/courseHub")
      .withAutomaticReconnect([0,1000,3000,5000])
      .build();

    connection.on("ReceiveChunk", function(chunk) {
      if (!streamingMessageEl) return;
      streamingRawText += chunk;
      var textEl = streamingMessageEl.querySelector(".message-text");
      if (textEl) { textEl.innerHTML = renderMdCit(streamingRawText, []); }
      chatMessages.scrollTop = chatMessages.scrollHeight;
    });

    connection.on("StreamComplete", function(data) {
      isStreaming = false; setStreamingUI(false);
      if (!streamingMessageEl) return;
      var cits = data.citations || [];
      var textEl = streamingMessageEl.querySelector(".message-text");
      if (textEl) {
        textEl.innerHTML = renderMdCit(streamingRawText, cits);
        textEl.setAttribute("data-raw", streamingRawText);
        streamingMessageEl.classList.remove("streaming-bubble");
        appendBotActions(streamingMessageEl.querySelector(".message-content"), streamingRawText);
        appendRemBadge(streamingMessageEl.querySelector(".message-content"), data.remaining);
      }
      var s = sessions.find(function(x){return x.id===currentSessionId;});
      if (s) {
        s.messages.push({role:"model",text:data.reply||streamingRawText,citations:cits});
        if (data.sessionTitle) s.title = data.sessionTitle;
        if (data.sessionId) currentSessionId = data.sessionId;
      }
      streamingMessageEl = null; streamingRawText = "";
      renderSessionsList(); refreshQuota();
    });

    connection.on("StreamError", function(message, outOfQuota) {
      isStreaming = false; setStreamingUI(false);
      removeTypingIndicator();
      if (streamingMessageEl) { streamingMessageEl.remove(); streamingMessageEl = null; streamingRawText = ""; }
      if (outOfQuota) {
        document.getElementById("quotaOverlayMsg").textContent = message || "Ban da het token.";
        document.getElementById("quotaOverlay").style.display = "flex";
      } else { appendErrMsg(message || "Loi khong xac dinh."); }
    });

    await connection.start();
  } catch(e) { console.warn("SignalR fallback:", e); }
}

// ===== UTILS =====
function esc(t) { return (t||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;"); }
function fmtMd(text) {
  if (!text) return "";
  if (typeof marked !== "undefined") return marked.parse(text);
  return esc(text).replace(/\n/g,"<br>");
}
function citMeta(c) {
  var parts = [];
  if (c.subjectName) parts.push(c.subjectName);
  if (c.chapterTitle) parts.push(c.chapterTitle);
  if (c.sectionTitle) parts.push(c.sectionTitle);
  if (c.chunkOrderIndex) parts.push("Đoạn " + c.chunkOrderIndex);
  return parts.join(" • ");
}
function renderMdCit(text, cits) {
  var html = fmtMd(text);
  if (!Array.isArray(cits)||cits.length===0) return html;
  html = html.replace(/\[(\d+)\]/g, function(match, p1) {
    var idx = parseInt(p1)-1;
    if (idx>=0&&idx<cits.length) {
      var c=cits[idx], snippet=esc(c.snippet||""), fc=esc(c.fullContent||c.snippet||""), title=esc(c.documentTitle||"Tài liệu"), meta=esc(citMeta(c));
      var docId=c.documentId||0, chunkIdx=c.chunkOrderIndex||0;
      var metaHtml = meta ? "<span style=\"display:block;color:#666;font-size:10px;margin-bottom:3px;\"><i class=\"fa-solid fa-location-dot\"></i> "+meta+"</span>" : "";
      return "<span class=\"citation-badge\" data-title=\""+title+"\" data-meta=\""+meta+"\" data-fc=\""+fc+"\" data-doc=\""+docId+"\" data-chunk=\""+chunkIdx+"\" onclick=\"openCit(this)\">"+p1+"<span class=\"citation-tooltip-content\"><strong style=\"color:var(--blue);display:block;margin-bottom:3px;\">"+title+"</strong>"+metaHtml+"<span style=\"font-style:italic;\">\""+snippet+"\"</span><span style=\"display:block;color:var(--blue);font-size:10px;margin-top:4px;font-weight:800;\"><i class=\"fa-solid fa-up-right-from-square\"></i> Click để xem trong tài liệu gốc</span></span></span>";
    }
    return match;
  });
  return html;
}
function openCit(el) {
  document.getElementById("modalTitle").textContent = "Trích dẫn: " + el.getAttribute("data-title");
  var meta = el.getAttribute("data-meta");
  var fc = el.getAttribute("data-fc") || "";
  
  var contentHtml = "";
  if (meta) {
    contentHtml += "<div style=\"background:var(--yellow); color:var(--black); padding:6px 12px; border:2px solid var(--black); box-shadow:2px 2px 0 var(--black); font-weight:800; margin-bottom:16px; font-size:13px; display:inline-block;\"><i class=\"fa-solid fa-location-dot\"></i> Vị trí: " + esc(meta) + "</div>\n";
  }
  contentHtml += "<div style=\"white-space:pre-wrap; line-height:1.7;\">" + esc(fc) + "</div>";
  
  document.getElementById("modalContent").innerHTML = contentHtml;
  // Deep-link mở tài liệu gốc tại đúng vị trí chunk được trích dẫn
  var link = document.getElementById("modalGotoDoc");
  if (link) {
    var docId = parseInt(el.getAttribute("data-doc")||"0"), chunkIdx = parseInt(el.getAttribute("data-chunk")||"0");
    if (docId > 0) {
      link.href = "/ViewDocument?id=" + docId + (chunkIdx > 0 ? "&chunk=" + chunkIdx : "");
      link.style.display = "inline-block";
    } else {
      link.style.display = "none";
    }
  }
  document.getElementById("previewModal").style.display = "flex";
}
function appendBotActions(contentEl, rawText) {
  var bar = document.createElement("div");
  bar.style.cssText = "margin-top:10px;display:flex;gap:8px;";
  var copyBtn = document.createElement("button");
  copyBtn.style.cssText = "background:var(--white);color:var(--black);border:2px solid var(--black);padding:5px 10px;font-weight:800;font-size:10px;cursor:pointer;box-shadow:2px 2px 0 var(--black);";
  copyBtn.innerHTML = "<i class=\"fa-regular fa-copy\"></i> COPY";
  copyBtn.onclick = function() { navigator.clipboard.writeText(rawText).then(function(){copyBtn.textContent="DA COPY";setTimeout(function(){copyBtn.innerHTML="<i class=\"fa-regular fa-copy\"></i> COPY";},2000);}); };
  var regenBtn = document.createElement("button");
  regenBtn.style.cssText = "background:var(--white);color:var(--black);border:2px solid var(--black);padding:5px 10px;font-weight:800;font-size:10px;cursor:pointer;box-shadow:2px 2px 0 var(--black);";
  regenBtn.innerHTML = "<i class=\"fa-solid fa-rotate-right\"></i> THỬ LẠI";
  regenBtn.onclick = regenerateMessage;
  bar.appendChild(copyBtn); bar.appendChild(regenBtn);
  contentEl.appendChild(bar);
}
function appendRemBadge(contentEl, remaining) {
  if (remaining===undefined||remaining===null) return;
  var q = document.createElement("span");
  q.style.cssText = "font-size:10px;color:#777;font-weight:bold;display:block;margin-top:6px;border-top:1px dashed #ddd;padding-top:5px;";
  q.textContent = "(Còn "+(remaining>=999999999?"∞":Number(remaining).toLocaleString("vi-VN"))+" token)";
  contentEl.appendChild(q);
}
function appendErrMsg(msg) {
  var err = document.createElement("div");
  err.className = "message message-bot";
  err.innerHTML = "<div class=\"chat-avatar\" style=\"background:#d93856;\"><i class=\"fa-solid fa-robot\"></i></div><div class=\"message-content\" style=\"border-color:#d93856;\"><div class=\"message-sender\" style=\"color:#d93856;\">Hệ thống</div><p class=\"message-text\">"+esc(msg)+"</p></div>";
  chatMessages.appendChild(err); chatMessages.scrollTop = chatMessages.scrollHeight;
}
function renderMessageUI(role, text, cits) {
  var div = document.createElement("div"), isUser = role==="user";
  div.className = isUser?"message message-user":"message message-bot";
  var icon = isUser?"fa-user":"fa-robot";
  var sender = isUser?"Bạn":"Trợ lý AI";
  var bodyHtml;
  if (isUser) {
    bodyHtml = "<p class=\"message-text\" data-raw=\""+esc(text)+"\">"+esc(text).replace(/\n/g,"<br>")+"</p>";
    bodyHtml += "<div style=\"margin-top:8px;display:flex;gap:8px;justify-content:flex-end;\"><button onclick=\"cpyMsg(this)\" style=\"background:transparent;color:#666;border:none;font-weight:800;font-size:10px;cursor:pointer;\"><i class=\"fa-regular fa-copy\"></i> COPY</button><button onclick=\"editMsg(this)\" style=\"background:transparent;color:#666;border:none;font-weight:800;font-size:10px;cursor:pointer;\"><i class=\"fa-solid fa-pen\"></i> SỬA</button></div>";
  } else {
    bodyHtml = "<div class=\"message-text\" data-raw=\""+esc(text)+"\" style=\"font-weight:500;font-size:14px;line-height:1.65;\">"+renderMdCit(text,cits)+"</div>";
  }
  div.innerHTML = "<div class=\"chat-avatar\"><i class=\"fa-solid "+icon+"\"></i></div><div class=\"message-content\"><div class=\"message-sender\">"+sender+"</div>"+bodyHtml+"</div>";
  if (!isUser) appendBotActions(div.querySelector(".message-content"), text);
  chatMessages.appendChild(div); chatMessages.scrollTop = chatMessages.scrollHeight;
  return div;
}
function cpyMsg(btn) {
  var raw = btn.closest(".message-content").querySelector("[data-raw]").getAttribute("data-raw");
  navigator.clipboard.writeText(raw).then(function(){var o=btn.textContent;btn.textContent="DA COPY";setTimeout(function(){btn.textContent=o;},2000);});
}
function editMsg(btn) {
  var raw = btn.closest(".message-content").querySelector("[data-raw]").getAttribute("data-raw");
  var s = sessions.find(function(x){return x.id===currentSessionId;});
  if (s) { var idx=s.messages.map(function(m){return m.text;}).lastIndexOf(raw); if(idx!==-1){s.messages=s.messages.slice(0,idx);renderMessages();} }
  var inp = document.getElementById("messageInput"); inp.value=raw; inp.focus(); autoResize(inp);
}
function regenerateMessage() {
  var s = sessions.find(function(x){return x.id===currentSessionId;});
  if (!s||s.messages.length<2) return;
  var lastUserIdx = s.messages.map(function(m){return m.role;}).lastIndexOf("user");
  if (lastUserIdx===-1) return;
  var text=s.messages[lastUserIdx].text;
  s.messages=s.messages.slice(0,lastUserIdx); renderMessages();
  document.getElementById("messageInput").value=text; sendMessage();
}
function createStreamingBubble() {
  var div = document.createElement("div");
  div.className = "message message-bot streaming-bubble";
  div.innerHTML = "<div class=\"chat-avatar\"><i class=\"fa-solid fa-robot\"></i></div><div class=\"message-content\"><div class=\"message-sender\">Trợ lý AI</div><div class=\"message-text\" style=\"font-weight:500;font-size:14px;line-height:1.65;min-height:24px;\"></div></div>";
  chatMessages.appendChild(div); chatMessages.scrollTop = chatMessages.scrollHeight;
  return div;
}
function showTypingIndicator() {
  var d = document.createElement("div");
  d.className = "message message-bot typing-indicator-msg";
  d.innerHTML = "<div class=\"chat-avatar\"><i class=\"fa-solid fa-robot\"></i></div><div class=\"message-content\"><div class=\"message-sender\">Trợ lý AI</div><p class=\"message-text\"><i class=\"fa-solid fa-circle-notch fa-spin\"></i> Đang suy nghĩ...</p></div>";
  chatMessages.appendChild(d); chatMessages.scrollTop = chatMessages.scrollHeight;
}
function removeTypingIndicator() { document.querySelectorAll(".typing-indicator-msg").forEach(function(el){el.remove();}); }
function setStreamingUI(on) {
  document.getElementById("sendBtn").disabled = on;
  document.getElementById("streamingStatus").style.display = on?"inline-flex":"none";
}

// ===== SESSIONS =====
function normSession(s) { return {id:s.id,title:s.title||"Cuộc trò chuyện mới",messages:(s.messages||[]).map(function(m){return {role:m.role,text:m.text,citations:m.citations||[]};})}; }
function renderSessionsList() {
  var box = document.getElementById("sessionsListBox"); if (!box) return;
  box.innerHTML = "";
  if (sessions.length===0) { box.innerHTML="<div style=\"font-size:11px;color:#777;text-align:center;padding:8px;\">Chưa có cuộc trò chuyện.</div>"; return; }
  sessions.forEach(function(s) {
    var isActive = s.id===currentSessionId;
    var item = document.createElement("div");
    item.className = "session-item"+(isActive?" active":"");
    item.onclick = function(e) { if (e.target.closest(".del-btn")) return; switchSession(s.id); };
    var tit = document.createElement("span");
    tit.style.cssText = "overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;margin-right:6px;";
    tit.textContent = s.title;
    var del = document.createElement("button");
    del.className = "del-btn";
    del.style.cssText = "background:none;border:none;cursor:pointer;padding:2px 3px;color:#555;";
    del.innerHTML = "<i class=\"fa-solid fa-trash-can\" style=\"font-size:10px;\"></i>";
    del.onclick = function(e) { e.stopPropagation(); deleteSession(s.id); };
    item.appendChild(tit); item.appendChild(del);
    box.appendChild(item);
  });
}
function renderMessages() {
  var s = sessions.find(function(x){return x.id===currentSessionId;});
  chatMessages.innerHTML = "";
  if (s&&s.messages&&s.messages.length>0) { s.messages.forEach(function(m){renderMessageUI(m.role,m.text,m.citations||[]);}); }
  else { chatMessages.innerHTML = "<div class=\"message message-bot\"><div class=\"chat-avatar\"><i class=\"fa-solid fa-robot\"></i></div><div class=\"message-content\"><div class=\"message-sender\">Trợ lý AI</div><p class=\"message-text\">Hãy chọn môn học và gửi câu hỏi để bắt đầu!</p></div></div>"; }
  chatMessages.scrollTop = chatMessages.scrollHeight;
}
function switchSession(id) { currentSessionId=id; renderSessionsList(); renderMessages(); }
async function apiPost(url, payload) {
  var r = await fetch(url,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload||{})});
  return r.json();
}
async function initSessions() {
  try {
    var r = await fetch("?handler=Sessions");
    var data = await r.json();
    if (!data.success) throw new Error();
    sessions = (data.sessions||[]).map(normSession);
    if (sessions.length===0) { await createNewSession(); return; }
    currentSessionId = sessions[0].id;
    renderSessionsList(); renderMessages();
  } catch(e) {
    document.getElementById("sessionsListBox").innerHTML = "<div style=\"font-size:11px;color:#d93856;padding:8px;\">Không thể tải lịch sử.</div>";
    renderMessages();
  }
}
async function createNewSession() {
  var data = await apiPost("?handler=CreateSession",{});
  if (!data.success||!data.session) return;
  var s = normSession(data.session);
  sessions.unshift(s); currentSessionId=s.id;
  renderSessionsList(); renderMessages();
}
function showDeleteConfirm(msg) {
  return new Promise(function(resolve) {
    document.getElementById("deleteConfirmMsg").textContent = msg;
    var modal = document.getElementById("deleteConfirmModal");
    var btnOk = document.getElementById("btnConfirmDelete");
    var btnCancel = document.getElementById("btnCancelDelete");
    var cleanup = function() { modal.style.display = "none"; btnOk.onclick = null; btnCancel.onclick = null; };
    btnOk.onclick = function() { cleanup(); resolve(true); };
    btnCancel.onclick = function() { cleanup(); resolve(false); };
    modal.style.display = "flex";
  });
}

async function deleteSession(id) {
  var ok = await showDeleteConfirm("Xóa cuộc hội thoại này?");
  if (!ok) return;
  await apiPost("?handler=DeleteSession",{sessionId:id});
  sessions = sessions.filter(function(s){return s.id!==id;});
  if (sessions.length===0) { await createNewSession(); }
  else { if (currentSessionId===id) currentSessionId=sessions[0]?.id||null; renderSessionsList(); renderMessages(); }
}
async function clearChatHistory() {
  var ok = await showDeleteConfirm("Xóa toàn bộ tin nhắn trong cuộc hội thoại này?");
  if (!ok) return;
  await apiPost("?handler=ClearSession",{sessionId:currentSessionId});
  var s = sessions.find(function(x){return x.id===currentSessionId;});
  if (s) { s.messages=[]; s.title="Cuộc trò chuyện mới"; }
  renderSessionsList(); renderMessages();
}

// ===== SEND MESSAGE =====
async function sendMessage() {
  var input = document.getElementById("messageInput");
  var text = input.value.trim();
  if (!text||!currentSessionId||isStreaming) return;
  var s = sessions.find(function(x){return x.id===currentSessionId;});
  if (!s) return;
  renderMessageUI("user",text,[]);
  var history = s.messages.map(function(m){return {role:m.role,text:m.text};});
  s.messages.push({role:"user",text:text,citations:[]});
  input.value=""; autoResize(input);
  var modelName = document.getElementById("modelSelector")?.value || "";
  var req = {message:text,sessionId:currentSessionId,history:history,subjectId:selectedSubjectId,restrictToDocs:restrictToDocs,modelName:modelName};
  isStreaming=true; setStreamingUI(true);

  var signalrReady = connection && connection.state === signalR.HubConnectionState.Connected;
  if (signalrReady) {
    streamingRawText=""; streamingMessageEl=createStreamingBubble();
    try { await connection.invoke("SendStreamingMessage", req); }
    catch(e) {
      console.error("SignalR invoke error:", e);
      isStreaming=false; setStreamingUI(false);
      if (streamingMessageEl){streamingMessageEl.remove();streamingMessageEl=null;}
      appendErrMsg("Loi ket noi real-time.");
    }
  } else {
    showTypingIndicator();
    try {
      var resp = await fetch("?handler=SendChatMessage",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(req)});
      var data = await resp.json();
      removeTypingIndicator(); isStreaming=false; setStreamingUI(false);
      if (!data.success) {
        if (data.outOfQuota) {
          document.getElementById("quotaOverlayMsg").textContent = data.message||"Ban da het token.";
          document.getElementById("quotaOverlay").style.display="flex";
        } else { appendErrMsg(data.message||"Loi khong xac dinh."); }
        input.value=text; autoResize(input); return;
      }
      var cits=data.citations||[];
      var msgEl=renderMessageUI("model",data.reply,cits);
      s.messages.push({role:"model",text:data.reply,citations:cits});
      appendRemBadge(msgEl.querySelector(".message-content"),data.remaining);
      if (data.sessionTitle) s.title=data.sessionTitle;
      if (data.sessionId) currentSessionId=data.sessionId;
      renderSessionsList(); refreshQuota();
    } catch(err) {
      removeTypingIndicator(); isStreaming=false; setStreamingUI(false);
      appendErrMsg("Khong the ket noi may chu."); input.value=text; autoResize(input);
    }
  }
}

// ===== QUOTA REFRESH =====
async function refreshQuota() {
  try {
    var r = await fetch("?handler=QuotaInfo");
    var data = await r.json();
    if (!data.success) return;
    var planLabel=document.getElementById("quotaPlanLabel");
    var barFill=document.getElementById("quotaBarFill");
    var countLabel=document.getElementById("quotaCountLabel");
    var extraCount=document.getElementById("extraQuotaCount");
    if (planLabel) planLabel.textContent=data.plan||"";
    if (countLabel) {
      var sl2 = data.shortTermLimit > 0 ? data.shortTermLimit : 1;
      var pct2 = sl2 >= 999999999 ? 0 : Math.min(100, Math.round((data.shortTermUsed||0)/sl2*100));
      countLabel.textContent="Đã dùng " + pct2 + "% (chu kỳ 5h)";
    }
    if (barFill&&data.shortTermLimit>0&&data.shortTermLimit<999999999) {
      var pct=Math.min(100,Math.round((data.shortTermUsed||0)/data.shortTermLimit*100));
      barFill.style.width=pct+"%";
      barFill.className="quota-bar-fill "+(pct>=90?"red":pct>=70?"orange":"green");
    }
    if (extraCount) extraCount.textContent=Number(data.extraQuota||0).toLocaleString("vi-VN");
  } catch(e) {}
}

// ===== CONTROLS =====
function autoResize(el){el.style.height="auto";el.style.height=Math.min(el.scrollHeight,120)+"px";}
function handleKeyDown(e){if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();sendMessage();}}
function toggleSidebar(){var s=document.getElementById("sidebarColumn"),o=document.getElementById("sidebarOverlay"),open=s.classList.toggle("open");o.style.display=open?"block":"none";}
function closeSidebar(){document.getElementById("sidebarColumn").classList.remove("open");document.getElementById("sidebarOverlay").style.display="none";}
function closePreviewModal(){document.getElementById("previewModal").style.display="none";}

// Phạm vi kiến thức luôn giới hạn trong tài liệu (bỏ chế độ "Tất cả" trả lời tự do).

// ===== EXTRA QUOTA TOGGLE =====
var toggleExtraQ = document.getElementById("toggleExtraQuotaChat");
var sliderTrack = document.getElementById("sliderTrack");
var sliderBtn = document.getElementById("sliderBtn");
if (toggleExtraQ) {
  toggleExtraQ.addEventListener("change", async function(e) {
    var isChecked=e.target.checked;
    sliderBtn.style.transform=isChecked?"translateX(24px)":"";
    sliderTrack.style.backgroundColor=isChecked?"var(--pink)":"#ccc";
    try {
      var r=await fetch("?handler=ToggleExtraQuota&useExtraQuota="+isChecked,{method:"POST"});
      if (!r.ok) throw new Error();
    } catch {
      e.target.checked=!isChecked;
      sliderBtn.style.transform=!isChecked?"translateX(24px)":"";
      sliderTrack.style.backgroundColor=!isChecked?"var(--pink)":"#ccc";
    }
  });
}

