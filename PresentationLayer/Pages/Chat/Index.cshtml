@page
@model PresentationLayer.Pages.Chat.IndexModel
@{
    Layout = "_Layout";
    ViewBag.ActiveMenu = "AI";
}

@section Styles {
<style>
.main-content { flex: 1; display: flex; overflow: hidden; }
.sidebar-column {
    width: 300px; min-width: 260px; max-width: 340px;
    padding: 16px 12px; border-right: var(--border);
    display: flex; flex-direction: column; gap: 14px;
    flex-shrink: 0; background-color: var(--bg);
    overflow-y: auto; transition: transform 0.3s ease;
}
.sidebar-column::-webkit-scrollbar { width: 6px; }
.sidebar-column::-webkit-scrollbar-thumb { background: #aaa; }
.section-title { color: #9e3636; font-weight: 900; font-size: 14px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.quota-badge { display:flex; flex-direction:column; gap:4px; background:var(--white); border:var(--border); box-shadow:2px 2px 0 var(--black); padding:10px 12px; font-size:12px; font-weight:700; }
.quota-badge-plan { font-size:14px; font-weight:900; display:flex; align-items:center; gap:6px; }
.quota-bar-wrap { background:#eee; border:1px solid #ccc; height:6px; border-radius:3px; overflow:hidden; }
.quota-bar-fill { height:100%; background:var(--pink); border-radius:3px; transition:width 0.3s ease; }
.quota-bar-fill.green { background:#16a34a; }
.quota-bar-fill.orange { background:#ea580c; }
.quota-bar-fill.red { background:#d93856; }
.quota-warn { color:#d93856; font-size:10px; font-weight:800; margin-top:2px; }
.sources-box { flex:1 1 0; min-height:0; overflow-y:auto; background:var(--white); border:var(--border); box-shadow:3px 3px 0 var(--black); padding:8px; }
.sources-box::-webkit-scrollbar { width:5px; }
.sources-box::-webkit-scrollbar-thumb { background:#aaa; }
.subject-item { display:flex; align-items:center; gap:8px; padding:8px 10px; border:2px solid #000; box-shadow:2px 2px 0 #000; background:var(--white); margin-bottom:8px; font-size:11px; font-weight:900; cursor:pointer; transition:all 0.1s ease; }
.subject-item:last-child { margin-bottom:0; }
.subject-item:hover { transform:translate(-1px,-1px); box-shadow:3px 3px 0 #000; }
.subject-item.active { background:var(--yellow); }
.subject-item-name { flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.subject-item-count { font-size:10px; color:#555; white-space:nowrap; }
.subject-item-check { display:none; color:#16a34a; font-size:12px; }
.subject-item.active .subject-item-check { display:inline-block; }
.all-subjects-btn { width:100%; display:flex; align-items:center; gap:8px; padding:9px 12px; border:2px solid #000; box-shadow:2px 2px 0 #000; background:var(--white); font-size:12px; font-weight:900; cursor:pointer; margin-bottom:8px; text-transform:uppercase; transition:all 0.1s ease; }
.all-subjects-btn:hover { transform:translate(-1px,-1px); box-shadow:3px 3px 0 #000; }
.all-subjects-btn.active { background:var(--pink); color:#fff; }
.sessions-box { flex:1 1 0; min-height:0; overflow-y:auto; background:var(--white); border:var(--border); box-shadow:3px 3px 0 var(--black); padding:6px; display:flex; flex-direction:column; gap:4px; }
.sessions-box::-webkit-scrollbar { width:4px; }
.sessions-box::-webkit-scrollbar-thumb { background:#d93856; }
.session-item { display:flex; align-items:center; justify-content:space-between; padding:7px 9px; border:2px solid #000; font-size:11px; font-weight:800; cursor:pointer; background:var(--white); transition:all 0.1s ease; }
.session-item:hover { background:#f5f5f5; transform:translate(-1px,-1px); box-shadow:2px 2px 0 #000; }
.session-item.active { background:var(--yellow); box-shadow:2px 2px 0 #000; }
.toggle-group { display:flex; border:var(--border); width:100%; }
.toggle-btn { padding:6px; font-weight:800; font-size:11px; border:none; cursor:pointer; flex:1; text-align:center; }
.toggle-btn:not(:last-child) { border-right:var(--border); }
.toggle-btn.active { background-color:var(--yellow); }
.toggle-btn:not(.active) { background-color:var(--white); }
.restriction-hint { font-size:10px; color:#555; font-weight:700; margin-top:4px; }
.right-column { flex:1; padding:20px 24px; display:flex; flex-direction:column; overflow:hidden; background-color:var(--bg); }
.chat-container { background-color:var(--white); display:flex; flex-direction:column; flex:1; overflow:hidden; border:var(--border); box-shadow:6px 6px 0 0 var(--black); background-image:radial-gradient(#d1d5db 1.5px,transparent 1.5px); background-size:20px 20px; }
.chat-header { background:var(--white); border-bottom:var(--border); padding:10px 16px; display:flex; justify-content:space-between; align-items:center; gap:10px; flex-shrink:0; }
.chat-header-title { color:#d93856; font-weight:900; font-size:16px; display:flex; align-items:center; gap:8px; }
.chat-header-right { display:flex; align-items:center; gap:8px; flex-shrink:0; }
.chat-messages { flex:1; overflow-y:auto; padding:20px 24px; display:flex; flex-direction:column; gap:16px; }
.chat-messages::-webkit-scrollbar { width:8px; }
.chat-messages::-webkit-scrollbar-thumb { background:#d93856; }
.message { display:flex; gap:12px; max-width:82%; }
.message-user { align-self:flex-end; flex-direction:row-reverse; }
.message-bot { align-self:flex-start; }
.chat-avatar { width:36px; height:36px; border:var(--border); display:flex; align-items:center; justify-content:center; flex-shrink:0; color:var(--white); font-size:14px; }
.message-bot .chat-avatar { background-color:var(--green); }
.message-user .chat-avatar { background-color:var(--pink); }
.message-content { background:var(--white); padding:12px 16px; border:var(--border); box-shadow:var(--shadow); }
.message-sender { font-weight:900; font-size:12px; margin-bottom:4px; color:var(--black); }
.message-text { font-size:14px; font-weight:500; line-height:1.65; margin:0; color:#222; }
.message-text h1,.message-text h2,.message-text h3 { font-weight:900; margin-top:14px; margin-bottom:8px; color:#000; }
.message-text p { margin-bottom:8px; }
.message-text p:last-child { margin-bottom:0; }
.message-text ul,.message-text ol { padding-left:22px; margin-bottom:12px; }
.message-text li { margin-bottom:4px; }
.message-text code { background:#f3f4f6; padding:2px 5px; font-family:monospace; font-size:88%; color:#d93856; border:1px solid #000; font-weight:700; }
.message-text pre { background:#fff8dc; padding:12px; border:2px solid #000; font-family:monospace; overflow-x:auto; margin:12px 0; box-shadow:3px 3px 0 #000; }
.message-text pre code { background:none; padding:0; border:none; color:#000; font-weight:500; }
.message-text strong { font-weight:900; color:#000; }
.message-text blockquote { border-left:4px solid var(--pink); padding:8px 12px; margin:12px 0; color:#444; font-style:italic; background:#fdf2f8; }
.message-text table { width:100%; border-collapse:collapse; margin:12px 0; }
.message-text th,.message-text td { border:2px solid #000; padding:8px; }
.message-text th { background-color:var(--yellow); font-weight:900; }
.streaming-bubble .message-text::after { content:"▌"; animation:blink 0.7s step-end infinite; color:var(--pink); }
@@keyframes blink { 50% { opacity:0; } }
.input-area { background:var(--white); border-top:var(--border); padding:14px 16px; display:flex; gap:10px; align-items:flex-end; flex-shrink:0; }
.input-box { flex:1; border:var(--border); padding:10px 14px; font-size:14px; font-weight:600; outline:none; resize:none; min-height:44px; max-height:120px; overflow-y:auto; font-family:inherit; line-height:1.5; }
.input-box:focus { box-shadow:2px 2px 0 var(--pink); border-color:var(--pink); }
.send-btn { background-color:#8b3d3d; color:var(--white); border:var(--border); padding:0 20px; height:44px; font-weight:900; font-size:14px; cursor:pointer; display:flex; align-items:center; gap:8px; box-shadow:2px 2px 0 var(--black); white-space:nowrap; flex-shrink:0; }
.send-btn:active { transform:translate(2px,2px); box-shadow:0 0 0 var(--black); }
.send-btn:disabled { background-color:#999; cursor:not-allowed; transform:none; }
.citation-badge { display:inline-flex; align-items:center; justify-content:center; background-color:var(--pink); color:#fff; font-size:10px; font-weight:900; border-radius:3px; width:17px; height:17px; margin-left:3px; cursor:pointer; position:relative; vertical-align:super; box-shadow:1px 1px 0 #000; border:1px solid #000; transition:all 0.1s; }
.citation-badge:hover { transform:translate(-1px,-1px); box-shadow:2px 2px 0 #000; }
.citation-tooltip-content { display:none; position:absolute; bottom:130%; left:50%; transform:translateX(-50%); width:max-content; max-width:260px; background:#fff; color:#000; border:2px solid #000; box-shadow:3px 3px 0 #000; padding:8px; font-size:11px; font-weight:600; z-index:1000; white-space:normal; line-height:1.4; pointer-events:none; }
.citation-badge:hover .citation-tooltip-content { display:block; }
.quota-modal-wrap { display:none; position:fixed; z-index:9999; left:0; top:0; width:100%; height:100%; background:rgba(0,0,0,0.65); align-items:center; justify-content:center; }
.quota-modal { background:#fff; border:4px solid #000; box-shadow:10px 10px 0 #000; width:460px; max-width:92%; padding:32px; text-align:center; }
.quota-modal h2 { font-weight:900; font-size:22px; color:#d93856; margin:0 0 12px; }
.quota-modal p { font-size:14px; color:#333; margin:0 0 24px; font-weight:600; line-height:1.6; }
.brutal-btn-upgrade { background-color:var(--pink); color:#fff; border:2px solid #000; padding:12px 28px; font-weight:900; font-size:15px; cursor:pointer; box-shadow:4px 4px 0 #000; display:inline-block; text-decoration:none; }
.brutal-btn-upgrade:hover { transform:translate(-2px,-2px); box-shadow:6px 6px 0 #000; }
.sidebar-toggle-btn { display:none; background:none; border:2px solid #000; padding:6px 10px; cursor:pointer; font-size:14px; font-weight:900; }
.model-select { border:var(--border); padding:5px 8px; font-weight:700; font-size:11px; background:var(--white); cursor:pointer; max-width:160px; }
@@media (max-width:768px) {
    .sidebar-column { position:fixed; left:0; top:0; height:100%; z-index:200; transform:translateX(-100%); }
    .sidebar-column.open { transform:translateX(0); box-shadow:4px 0 0 rgba(0,0,0,0.2); }
    .sidebar-toggle-btn { display:inline-flex; }
    .right-column { padding:12px; }
    .chat-messages { padding:14px 12px; }
    .message { max-width:94%; }
}
</style>
}

<div id="sidebarOverlay" onclick="closeSidebar()" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:199;"></div>

<div class="main-content">
  <div class="sidebar-column" id="sidebarColumn">
    <!-- Quota Badge -->
    <div class="quota-badge" id="quotaBadge">
      <div class="quota-badge-plan">
        <i class="fa-solid fa-crown" style="color:#f59e0b;"></i>
        <span id="quotaPlanLabel">@Model.Info.CurrentPlan</span>
      </div>
      <div style="font-size:11px;color:#555;font-weight:800;text-transform:uppercase;">Usage của tài khoản</div>
      <div class="quota-bar-wrap">
        @{
          var sl = Model.Info.ShortTermLimit > 0 ? Model.Info.ShortTermLimit : 1;
          var pct = sl >= 999999999 ? 0 : Math.Min(100,(int)((double)Model.Info.ShortTermUsedCount/sl*100));
          var bc = pct>=90?"red":pct>=70?"orange":"green";
        }
        <div class="quota-bar-fill @bc" id="quotaBarFill" style="width:@(pct)%;"></div>
      </div>
      <div id="quotaCountLabel" style="font-size:11px;color:#333;font-weight:700;">
        Đã dùng @(pct)% (chu kỳ 5h)
      </div>
      @if(pct>=90){<div class="quota-warn">Sắp hết hạn mức 5h!</div>}
    </div>

    <!-- Mon hoc -->
    <div style="display:flex;flex-direction:column;flex:1 1 0;min-height:120px;">
      <div class="section-title">Môn học</div>
      @{
        var idxDocs = Model.Documents
          .Where(d=>d.Status==BussinessLayer.DTOs.DocumentStatus.Indexed)
          .ToList();
        var subjectGroups = idxDocs
          .Where(d=>d.SubjectId.HasValue)
          .GroupBy(d=>new { Id = d.SubjectId!.Value, Name = string.IsNullOrWhiteSpace(d.SubjectName) ? ("Môn #"+d.SubjectId) : d.SubjectName!.Trim() })
          .OrderBy(g=>g.Key.Name).ToList();
      }

      <button type="button" id="btnAllSubjects" class="all-subjects-btn active" onclick="selectSubject(null)" title="Hỏi trên tài liệu của tất cả các môn học">
        <i class="fa-solid fa-layer-group"></i>
        <span style="flex:1;text-align:left;">Tất cả môn học</span>
        <span style="font-size:10px;font-weight:800;opacity:0.85;">@idxDocs.Count tài liệu</span>
      </button>

      <div style="margin-bottom: 8px;">
        <input type="text" id="searchSubjectInput" placeholder="Tìm kiếm môn học..." style="width:100%; padding: 8px 10px; border: 2px solid #000; box-shadow: 2px 2px 0 #000; font-size: 11px; font-weight: 700; outline: none; box-sizing: border-box; transition: transform 0.1s ease;" onfocus="this.style.transform='translate(-1px,-1px)'; this.style.boxShadow='3px 3px 0 #000';" onblur="this.style.transform='none'; this.style.boxShadow='2px 2px 0 #000';" onkeyup="filterSubjects()">
      </div>

      <div class="sources-box" id="sourcesBox">
        @if(subjectGroups.Any()){
          @foreach(var sg in subjectGroups){
            var v=GetSubjectVisual(sg.Key.Name);
            <div class="subject-item" id="subject-item-@sg.Key.Id" onclick="selectSubject(@sg.Key.Id)" title="@sg.Key.Name">
              <i class="@v.Icon" style="color:@v.Accent;font-size:12px;"></i>
              <span class="subject-item-name">@sg.Key.Name</span>
              <span class="subject-item-count">@sg.Count() tài liệu</span>
              <i class="fa-solid fa-circle-check subject-item-check"></i>
            </div>
          }
        } else {
          <div style="font-size:11px;color:#777;text-align:center;padding:12px;">Chưa có tài liệu thuộc môn học nào.</div>
        }
      </div>
    </div>

    <!-- Lich su Chat -->
    <div style="display:flex;flex-direction:column;flex:1 1 0;min-height:120px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
        <div class="section-title" style="margin:0;">Lịch sử Chat</div>
        <button onclick="createNewSession()" style="padding:3px 8px;font-size:10px;font-weight:800;background:var(--green);cursor:pointer;border:2px solid #000;box-shadow:1px 1px 0 #000;display:inline-flex;align-items:center;gap:4px;">+ MỚI</button>
      </div>
      <div id="sessionsListBox" class="sessions-box">
        <div style="font-size:11px;color:#777;text-align:center;padding:8px;">Đang tải...</div>
      </div>
    </div>

    <!-- Dieu khien -->
    <div style="display:flex;flex-direction:column;gap:10px;background:#fefefe;padding:10px;border:var(--border);box-shadow:2px 2px 0 var(--black);">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <div>
          <div style="font-size:12px;font-weight:700;">Token dự phòng: <span style="color:var(--blue);font-weight:900;font-size:14px;" id="extraQuotaCount">@Model.Info.ExtraQuota.ToString("N0")</span></div>
          <div style="font-size:10px;color:#777;">Dùng khi hết hạn mức</div>
        </div>
        <label style="position:relative;display:inline-block;width:44px;height:20px;">
          <input type="checkbox" id="toggleExtraQuotaChat" @(Model.Info.UseExtraQuota?"checked":"") style="opacity:0;width:0;height:0;">
          <span id="sliderTrack" style="position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background-color:@(Model.Info.UseExtraQuota?"var(--pink)":"#ccc");transition:.4s;border-radius:34px;">
            <span id="sliderBtn" style="position:absolute;height:14px;width:14px;left:3px;bottom:3px;background-color:white;transition:.4s;border-radius:50%;@(Model.Info.UseExtraQuota?"transform:translateX(24px);":"")"></span>
          </span>
        </label>
      </div>
      <div style="height:1px;background:#e5e5e5;"></div>
      <div>
        <div class="section-title" style="font-size:12px;margin:0 0 4px 0;">Phạm vi kiến thức</div>
        <div style="display:flex;align-items:center;gap:6px;padding:6px 10px;border:var(--border);background:var(--yellow);font-size:11px;font-weight:900;">
          <i class="fa-solid fa-book"></i> Chỉ trả lời trong tài liệu
        </div>
        <div class="restriction-hint" id="restrictHint"> </div>
      </div>
    </div>
  </div>

  <!-- CHAT -->
  <div class="right-column">
    <div class="chat-container">
      <div class="chat-header">
        <button class="sidebar-toggle-btn" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
        <div class="chat-header-title">
          <i class="fa-solid fa-robot"></i> TRỢ LÝ HỌC TẬP AI
          <span id="streamingStatus" style="display:none;font-size:11px;color:var(--green);font-weight:700;"><i class="fa-solid fa-circle-notch fa-spin"></i> Đang trả lời...</span>
        </div>
        <div class="chat-header-right">
          <button onclick="clearChatHistory()" style="padding:5px 10px;font-size:10px;background:var(--white);font-weight:800;border:2px solid #000;box-shadow:1px 1px 0 #000;cursor:pointer;display:flex;align-items:center;gap:5px;">
            <i class="fa-solid fa-trash-can"></i> XÓA
          </button>
        </div>
      </div>
      <div class="chat-messages" id="chatMessages">
        <div class="message message-bot">
          <div class="chat-avatar"><i class="fa-solid fa-robot"></i></div>
          <div class="message-content">
            <div class="message-sender">Trợ lý AI</div>
            <p class="message-text">Chào bạn! Tôi là trợ lý học tập AI. Hãy chọn môn học ở sidebar và gửi câu hỏi — tôi sẽ trả lời dựa trên các tài liệu của môn đó nhé!</p>
          </div>
        </div>
      </div>
      <div class="input-area">
        <textarea id="messageInput" class="input-box" placeholder="Nhập câu hỏi... (Enter = gửi, Shift+Enter = xuống dòng)" rows="1" oninput="autoResize(this)" onkeydown="handleKeyDown(event)"></textarea>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()">Gửi <i class="fa-solid fa-paper-plane"></i></button>
      </div>
    </div>
  </div>
</div>

<!-- QUOTA OVERLAY -->
<div id="quotaOverlay" class="quota-modal-wrap">
  <div class="quota-modal">
    <h2>Hết token!</h2>
    <p id="quotaOverlayMsg">Bạn đã dùng hết hạn mức token trong chu kỳ này.</p>
    <a href="/Subscription" class="brutal-btn-upgrade">Nâng cấp gói ngay</a>
    <button onclick="document.getElementById('quotaOverlay').style.display='none'" style="display:block;margin:12px auto 0;background:none;border:none;font-size:13px;cursor:pointer;color:#555;text-decoration:underline;">Đóng</button>
  </div>
</div>

<!-- PREVIEW MODAL -->
<style>
  @@keyframes modalPop {
    0% { transform: scale(0.9) translateY(20px); opacity: 0; }
    100% { transform: scale(1) translateY(0); opacity: 1; }
  }
  .preview-modal-backdrop {
    display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%;
    background: rgba(17, 17, 17, 0.7); backdrop-filter: blur(5px);
    align-items: center; justify-content: center;
    padding: 20px;
  }
  .preview-modal-box {
    background: var(--white); border: 4px solid var(--black); box-shadow: 12px 12px 0 var(--black);
    width: 700px; max-width: 100%; display: flex; flex-direction: column; max-height: 85vh;
    animation: modalPop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    position: relative;
  }
  .preview-modal-header {
    background: var(--yellow); border-bottom: 4px solid var(--black); padding: 16px 24px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .preview-modal-title {
    font-weight: 900; font-size: 20px; margin: 0; color: var(--black); text-transform: uppercase;
    display: flex; align-items: center; gap: 10px;
  }
  .preview-modal-close {
    background: var(--white); border: 3px solid var(--black); box-shadow: 3px 3px 0 var(--black);
    font-size: 20px; font-weight: 900; cursor: pointer; width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center; transition: all 0.2s;
  }
  .preview-modal-close:hover {
    transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--black); background: var(--pink); color: var(--white);
  }
  .preview-modal-close:active {
    transform: translate(3px, 3px); box-shadow: 0 0 0 var(--black);
  }
  .preview-modal-content-wrap {
    padding: 24px; flex: 1; overflow-y: auto; background: var(--bg);
  }
  .preview-modal-content {
    font-family: 'Inter', system-ui, -apple-system, sans-serif; font-size: 15px; line-height: 1.7;
    color: #222; white-space: pre-wrap; background: var(--white); padding: 20px;
    border: 3px solid var(--black); box-shadow: inset 4px 4px 0 rgba(0,0,0,0.05);
    border-radius: 2px;
  }
  .preview-modal-footer {
    border-top: 4px solid var(--black); padding: 16px 24px; background: var(--white);
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
  }
  .btn-neo-blue {
    background: var(--blue); color: var(--black); border: 3px solid var(--black); box-shadow: 4px 4px 0 var(--black);
    padding: 10px 20px; font-weight: 900; font-size: 14px; text-decoration: none; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s; cursor: pointer;
  }
  .btn-neo-blue:hover {
    transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--black); background: #00f5ff;
  }
  .btn-neo-blue:active {
    transform: translate(4px, 4px); box-shadow: 0 0 0 var(--black);
  }
  .btn-neo-black {
    background: var(--black); color: var(--white); border: 3px solid var(--black); box-shadow: 4px 4px 0 var(--pink);
    padding: 10px 24px; font-weight: 900; font-size: 14px; text-transform: uppercase;
    transition: all 0.2s; cursor: pointer;
  }
  .btn-neo-black:hover {
    transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--pink);
  }
  .btn-neo-black:active {
    transform: translate(4px, 4px); box-shadow: 0 0 0 var(--pink);
  }
</style>
