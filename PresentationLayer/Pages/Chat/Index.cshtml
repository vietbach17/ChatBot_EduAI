      <button id="btnConfirmDelete" style="background:#d93856;color:#fff;border:2px solid #000;padding:8px 20px;font-weight:900;cursor:pointer;box-shadow:3px 3px 0 #000;transition:transform 0.1s;onmouseover=\"this.style.transform='translate(-2px,-2px)'\" onmouseout=\"this.style.transform='none'\">Xóa</button>
    </div>
