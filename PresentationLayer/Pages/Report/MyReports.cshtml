@page
@model PresentationLayer.Pages.Report.MyReportsModel
@{
    ViewData["Title"] = "Báo cáo & Hỗ trợ";
    ViewBag.ActiveMenu = "Reports";

    string StatusBadge(string status) => status switch
    {
        "Pending" => "background: var(--yellow); color: var(--black);",
        "InProgress" => "background: var(--blue); color: var(--white);",
        "Resolved" => "background: var(--green); color: var(--white);",
        "Rejected" => "background: #ff4d4f; color: var(--white);",
        _ => "background: #ccc; color: var(--black);"
    };
}

<style>
    .report-card {
        background: var(--white); border: var(--border);
        box-shadow: 4px 4px 0px var(--black); padding: 20px; margin-bottom: 20px;
    }
    .r-input {
        width: 100%; padding: 10px; border: 2px solid var(--black);
        font-family: inherit; font-size: 15px; margin-top: 5px; margin-bottom: 15px;
    }
    .r-input:focus { outline: none; border-color: var(--pink); box-shadow: 2px 2px 0px var(--pink); }
    .r-btn {
        background: var(--pink); color: var(--white); border: 2px solid var(--black);
        padding: 12px 20px; font-weight: 900; font-size: 15px; cursor: pointer;
        box-shadow: 3px 3px 0px var(--black); text-transform: uppercase; transition: 0.1s;
    }
    .r-btn:active { box-shadow: 0 0 0 0 var(--black); transform: translate(3px, 3px); }
    .status-badge {
        display: inline-block; padding: 4px 12px; border: 2px solid var(--black);
        font-weight: 900; font-size: 11px; text-transform: uppercase; box-shadow: 1px 1px 0px var(--black);
    }
    .r-label { font-weight: 800; font-size: 14px; }
</style>

<div class="main-wrapper" style="padding: 30px;">
    <h1 style="color: var(--pink); font-weight: 900; text-transform: uppercase; font-size: 30px; margin-bottom: 5px;">
        <i class="fa-solid fa-headset"></i> Báo cáo & Hỗ trợ
    </h1>
    <p style="font-weight: 700; color: #555; margin-bottom: 25px;">
        Gửi báo cáo về các vấn đề bạn gặp phải. Admin sẽ tiếp nhận và phản hồi.
    </p>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        var isError = Model.StatusMessage.StartsWith("Error:");
        <div class="report-card" style="background: @(isError ? "#ffcccc" : "#d4f8d4"); border-color: @(isError ? "#dc2626" : "var(--green)");">
            <strong>@(isError ? "⚠️ " : "✅ ")</strong> @Model.StatusMessage.Replace("Error:", "").Replace("Thành công:", "")
        </div>
    }

    <div style="display: grid; grid-template-columns: 5fr 7fr; gap: 25px; align-items: start;">
        <!-- FORM GỬI BÁO CÁO -->
        <div class="report-card">
            <h2 style="font-weight: 900; font-size: 18px; color: var(--blue); border-bottom: 2px dashed #ccc; padding-bottom: 10px; margin-bottom: 15px;">
                <i class="fa-solid fa-paper-plane"></i> GỬI BÁO CÁO MỚI
            </h2>

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Input.RelatedTransactionId" />

                <label class="r-label">Loại vấn đề</label>
                <select asp-for="Input.Category" class="r-input" required>
                    <option value="">-- Chọn loại vấn đề --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Key">@cat.Value</option>
                    }
                </select>

                @if (Model.Input.RelatedTransactionId.HasValue)
                {
                    <div style="background: var(--yellow); border: 2px solid var(--black); padding: 8px 12px; font-weight: 800; font-size: 13px; margin-bottom: 15px;">
                        <i class="fa-solid fa-link"></i> Báo cáo cho giao dịch #@Model.Input.RelatedTransactionId
                    </div>
                }

                <label class="r-label">Tiêu đề</label>
                <input type="text" asp-for="Input.Title" class="r-input" maxlength="200" required placeholder="Tóm tắt ngắn gọn vấn đề..." />

                <label class="r-label">Mô tả chi tiết</label>
                <textarea asp-for="Input.Description" class="r-input" rows="5" required placeholder="Mô tả cụ thể vấn đề bạn gặp phải..."></textarea>

                <label class="r-label">Ảnh đính kèm (không bắt buộc)</label>
                <input type="file" asp-for="ImageFile" class="r-input" accept="image/*" id="reportImageInput" style="margin-bottom: 5px;" />
                
                <!-- Khu vực hiển thị ảnh xem trước nhỏ -->
                <div id="imagePreviewContainer" style="display: none; margin-bottom: 15px; position: relative; width: max-content;">
                    <img id="imagePreview" src="" alt="Xem trước ảnh" style="width: 100px; height: 100px; object-fit: cover; border: 2px solid var(--black); box-shadow: 2px 2px 0px var(--black);" />
                    <button type="button" id="removeImageBtn" style="position: absolute; top: -5px; right: -5px; background: var(--pink); color: var(--white); border: 2px solid var(--black); border-radius: 50%; width: 20px; height: 20px; font-size: 10px; cursor: pointer; font-weight: 900; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <p style="font-size: 12px; color: #888; font-weight: 700; margin-bottom: 15px;">
                    <i class="fa-solid fa-circle-info"></i> Với báo cáo giao dịch, hãy đính kèm ảnh chụp biên lai chuyển khoản. (Tối đa 5MB)
                </p>

                <button type="submit" class="r-btn" style="width: 100%;">
                    <i class="fa-solid fa-paper-plane"></i> Gửi báo cáo
                </button>
            </form>
        </div>

        <!-- DANH SÁCH BÁO CÁO CỦA TÔI -->
        <div>
            <h2 style="font-weight: 900; font-size: 18px; color: var(--pink); margin-bottom: 15px;">
                <i class="fa-solid fa-clock-rotate-left"></i> BÁO CÁO CỦA TÔI (@Model.MyReports.Count)
            </h2>

            @if (!Model.MyReports.Any())
            {
                <div class="report-card" style="text-align: center; background: #f9f9f9;">
                    <i class="fa-regular fa-folder-open" style="font-size: 40px; color: #bbb; margin-bottom: 10px;"></i>
                    <p style="font-weight: 800; color: #777;">Bạn chưa gửi báo cáo nào.</p>
                </div>
            }
            else
            {
                @foreach (var r in Model.MyReports)
                {
                    <div class="report-card">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 8px;">
                            <div>
                                <span class="status-badge" style="background: #eee; color: var(--black); margin-bottom: 6px;">@r.CategoryLabel</span>
                                <h3 style="font-weight: 900; font-size: 16px; margin-top: 8px;">@r.Title</h3>
                            </div>
                            <span class="status-badge" style="@StatusBadge(r.Status); white-space: nowrap;">@r.StatusLabel</span>
                        </div>

                        <p style="font-weight: 600; font-size: 14px; color: #444; white-space: pre-wrap; margin-bottom: 10px;">@r.Description</p>

                        @if (r.RelatedTransactionId.HasValue)
                        {
                            <div style="font-size: 12px; font-weight: 800; color: var(--blue); margin-bottom: 8px;">
                                <i class="fa-solid fa-link"></i> Giao dịch #@r.RelatedTransactionId
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(r.ImageUrl))
                        {
                            <a href="@r.ImageUrl" target="_blank">
                                <img src="@r.ImageUrl" alt="Ảnh đính kèm" style="max-width: 180px; max-height: 180px; border: 2px solid var(--black); margin-bottom: 10px; object-fit: cover;" />
                            </a>
                        }

                        <div style="font-size: 11px; color: #999; font-weight: 700; border-top: 1px dashed #ddd; padding-top: 8px;">
                            <i class="fa-regular fa-clock"></i> Gửi lúc: @r.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")
                        </div>

                        @if (!string.IsNullOrEmpty(r.AdminResponse))
                        {
                            <div style="background: #eef6ff; border: 2px solid var(--blue); padding: 12px; margin-top: 12px;">
                                <div style="font-weight: 900; font-size: 12px; color: var(--blue); margin-bottom: 5px;">
                                    <i class="fa-solid fa-user-shield"></i> PHẢN HỒI TỪ ADMIN@(string.IsNullOrEmpty(r.HandledByAdminName) ? "" : $" ({r.HandledByAdminName})")
                                </div>
                                <p style="font-weight: 700; font-size: 14px; color: var(--black); white-space: pre-wrap;">@r.AdminResponse</p>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const reportImageInput = document.getElementById('reportImageInput');
        const previewContainer = document.getElementById('imagePreviewContainer');
        const previewImage = document.getElementById('imagePreview');
        const removeImageBtn = document.getElementById('removeImageBtn');

        reportImageInput.addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImage.src = e.target.result;
                    previewContainer.style.display = 'block';
                }
                reader.readAsDataURL(file);
            } else {
                clearImagePreview();
            }
        });

        removeImageBtn.addEventListener('click', function() {
            reportImageInput.value = ''; // Reset input file
            clearImagePreview();
        });

        function clearImagePreview() {
            previewImage.src = '';
            previewContainer.style.display = 'none';
        }
    </script>
}
