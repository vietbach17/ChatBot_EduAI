@page
@model PresentationLayer.Pages.Auth.RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký - EduManager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;800;900&display=swap');

        :root {
            --primary-pink: #eb2f64;
            --brutal-yellow: #f4cf45;
            --black: #000000;
            --white: #ffffff;
            --bg-color: #f8f8f8;
            --border-width: 3px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Montserrat', sans-serif; }

        body {
            background-color: var(--bg-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background-image: repeating-linear-gradient(45deg, #f0f0f0 25%, transparent 25%, transparent 75%, #f0f0f0 75%, #f0f0f0), repeating-linear-gradient(45deg, #f0f0f0 25%, var(--bg-color) 25%, var(--bg-color) 75%, #f0f0f0 75%, #f0f0f0);
            background-position: 0 0, 20px 20px;
            background-size: 40px 40px;
        }

        .decor { position: absolute; z-index: 0; }
        .dec-tri-1 { top: 20%; left: 25%; transform: rotate(-15deg); }
        .dec-squ-1 { top: 40%; left: 23%; transform: rotate(10deg); }
        .dec-dot-1 { top: 50%; left: 26%; }
        .dec-squ-2 { bottom: 30%; left: 25%; transform: rotate(-20deg); }
        .dec-tri-2 { bottom: 20%; left: 28%; transform: rotate(45deg); width: 20px; height: 20px; }
        .dec-tri-3 { top: 22%; right: 26%; transform: rotate(25deg); }
        .dec-squ-3 { top: 38%; right: 24%; transform: rotate(-30deg); }
        .dec-dot-2 { top: 50%; right: 25%; }
        .dec-tri-4 { bottom: 25%; right: 22%; transform: rotate(-10deg); }

        .shape-triangle {
            width: 30px; height: 30px;
            background-color: var(--primary-pink);
            clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
            filter: drop-shadow(0px 0px 0px var(--black)) drop-shadow(2px 0px 0px var(--black)) drop-shadow(0px 2px 0px var(--black)) drop-shadow(-2px 0px 0px var(--black)) drop-shadow(0px -2px 0px var(--black));
        }
        .shape-triangle.yellow { background-color: var(--brutal-yellow); }
        .shape-dot { width: 12px; height: 12px; background-color: var(--black); border-radius: 50%; }

        .top-logo {
            position: absolute; top: 30px; left: 40px;
            color: var(--primary-pink); font-size: 24px; font-weight: 900;
            display: flex; align-items: center; gap: 10px; z-index: 10; text-decoration: none;
        }

        .register-wrapper {
            position: relative; z-index: 10;
            width: 100%; max-width: 450px;
            display: flex; flex-direction: column; align-items: center;
        }

        .register-box {
            background-color: var(--white);
            border: var(--border-width) solid var(--black);
            box-shadow: 8px 8px 0px 0px var(--black);
            padding: 40px 35px;
            width: 100%;
            text-align: center;
            margin-bottom: 20px;
        }

        .register-box h1 {
            color: var(--primary-pink); font-weight: 900; font-size: 30px;
            margin-bottom: 10px; letter-spacing: 1px;
            display: flex; align-items: center; justify-content: center; gap: 10px;
        }

        .subtitle { font-weight: 800; font-size: 13px; margin-bottom: 30px; color: var(--black); }

        .input-group { text-align: left; margin-bottom: 18px; }
        .input-group label { display: block; font-weight: 800; margin-bottom: 8px; font-size: 14px; }

        .input-wrapper { position: relative; display: flex; align-items: center; }
        .input-wrapper i.left-icon { position: absolute; left: 15px; font-size: 16px; color: var(--black); }

        .input-wrapper input {
            width: 100%; padding: 12px 15px 12px 40px;
            border: var(--border-width) solid var(--black);
            font-size: 14px; font-weight: 600; outline: none; transition: all 0.1s;
        }
        .input-wrapper input:focus {
            box-shadow: 4px 4px 0px 0px var(--black);
            transform: translate(-2px, -2px);
        }
        .input-wrapper input::placeholder { color: #888; font-weight: 500; }

        .text-danger { color: var(--primary-pink); font-size: 12px; font-weight: 700; margin-top: 5px; display: block; }

        .btn-brutal {
            width: 100%; padding: 14px; font-size: 15px; font-weight: 900;
            border: var(--border-width) solid var(--black); cursor: pointer;
            box-shadow: 4px 4px 0px 0px var(--black); transition: all 0.1s ease;
            text-transform: uppercase;
        }
        .btn-brutal:active { transform: translate(4px, 4px); box-shadow: 0px 0px 0px 0px var(--black); }

        .btn-register { background-color: var(--primary-pink); color: var(--white); margin-bottom: 15px; }
        .btn-secondary {
            background-color: var(--white); color: var(--black);
            text-decoration: none; display: inline-block;
        }

        .validation-summary {
            background-color: #f8d7da; border: 2px solid var(--primary-pink);
            color: var(--primary-pink); padding: 10px; font-weight: bold;
            margin-bottom: 20px; text-align: left; font-size: 13px;
        }

        .login-footer { font-size: 13px; font-weight: 700; margin-top: 10px; }
        .login-footer a { color: var(--black); font-weight: 900; text-decoration: underline; text-decoration-thickness: 2px; }

        .role-badge {
            display: inline-block;
            background-color: var(--brutal-yellow);
            border: 2px solid var(--black);
            padding: 4px 12px;
            font-size: 12px;
            font-weight: 900;
            margin-bottom: 20px;
            box-shadow: 2px 2px 0px var(--black);
        }
    </style>
</head>
<body>

    <a href="/" class="top-logo">
        <i class="fa-solid fa-graduation-cap"></i> EduManager
    </a>

    <div class="decor dec-tri-1 shape-triangle"></div>
    <svg class="decor dec-squ-1" width="40" height="30" viewBox="0 0 40 30" fill="none">
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="#f4cf45" stroke-width="4" stroke-linecap="round"/>
    </svg>
    <div class="decor dec-dot-1 shape-dot"></div>
    <svg class="decor dec-squ-2" width="40" height="30" viewBox="0 0 40 30" fill="none">
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="#eb2f64" stroke-width="4" stroke-linecap="round"/>
    </svg>
    <div class="decor dec-tri-2 shape-triangle"></div>
    <div class="decor dec-tri-3 shape-triangle"></div>
    <svg class="decor dec-squ-3" width="40" height="30" viewBox="0 0 40 30" fill="none">
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="#eb2f64" stroke-width="4" stroke-linecap="round"/>
    </svg>
    <div class="decor dec-dot-2 shape-dot"></div>
    <div class="decor dec-tri-4 shape-triangle yellow"></div>

    <div class="register-wrapper">
        <div class="register-box">
            <h1>ĐĂNG KÝ ✏️</h1>
            <p class="subtitle">Tạo tài khoản mới để bắt đầu học tập!</p>

            <div class="role-badge"><i class="fa-solid fa-user-graduate"></i> Vai trò mặc định: STUDENT</div>

            <div asp-validation-summary="ModelOnly" class="validation-summary" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

            <form method="post">
                <div class="input-group">
                    <label asp-for="Input.Username">Tên đăng nhập</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-user left-icon"></i>
                        <input asp-for="Input.Username" placeholder="Nhập tên đăng nhập" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Username" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Input.Email">Email <span style="font-weight:500; color:#888;">(tuỳ chọn)</span></label>
                    <div class="input-wrapper">
                        <i class="fa-regular fa-envelope left-icon"></i>
                        <input asp-for="Input.Email" placeholder="example@email.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock left-icon"></i>
                        <input asp-for="Input.Password" type="password" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock left-icon"></i>
                        <input asp-for="Input.ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-brutal btn-register">
                    <i class="fa-solid fa-user-plus"></i> TẠO TÀI KHOẢN
                </button>
            </form>

            <a asp-page="/Auth/Login" class="btn-brutal btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> QUAY LẠI ĐĂNG NHẬP
            </a>
        </div>

        <div class="login-footer">
            Đã có tài khoản? <a asp-page="/Auth/Login">Đăng nhập ngay!</a>
        </div>
    </div>

</body>
</html>
