@page
@model PresentationLayer.Pages.Auth.LoginModel
@{
    // Tắt layout mặc định để dùng giao diện full màn hình này
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập - EduManager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;800;900&display=swap');

        :root {
            --primary-pink: #eb2f64;
            --brutal-yellow: #f4cf45;
            --black: #000000;
            --white: #ffffff;
            --bg-color: #f8f8f8;
            --border-width: 3px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Montserrat', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden; /* Ngăn scroll bar nếu họa tiết tràn viền */
            /* Nền caro mờ */
            background-image: repeating-linear-gradient(45deg, #f0f0f0 25%, transparent 25%, transparent 75%, #f0f0f0 75%, #f0f0f0), repeating-linear-gradient(45deg, #f0f0f0 25%, var(--bg-color) 25%, var(--bg-color) 75%, #f0f0f0 75%, #f0f0f0);
            background-position: 0 0, 20px 20px;
            background-size: 40px 40px;
        }

        /* =========================================
           HỌA TIẾT TRANG TRÍ MEMPHIS (NỔI XUNG QUANH)
        ========================================= */
        .decor {
            position: absolute;
            z-index: 0;
        }

        /* Tam giác hồng bên trái trên */
        .dec-tri-1 { top: 20%; left: 25%; transform: rotate(-15deg); }
        /* Squiggle vàng bên trái giữa */
        .dec-squ-1 { top: 40%; left: 23%; transform: rotate(10deg); }
        /* Chấm tròn đen bên trái */
        .dec-dot-1 { top: 50%; left: 26%; }
        /* Squiggle hồng bên trái dưới */
        .dec-squ-2 { bottom: 30%; left: 25%; transform: rotate(-20deg); }
        /* Tam giác hồng bên trái dưới cùng */
        .dec-tri-2 { bottom: 20%; left: 28%; transform: rotate(45deg); width: 20px; height: 20px; }

        /* Tam giác hồng bên phải trên */
        .dec-tri-3 { top: 22%; right: 26%; transform: rotate(25deg); }
        /* Squiggle hồng bên phải giữa */
        .dec-squ-3 { top: 38%; right: 24%; transform: rotate(-30deg); }
        /* Chấm tròn đen bên phải */
        .dec-dot-2 { top: 50%; right: 25%; }
        /* Tam giác vàng bên phải dưới */
        .dec-tri-4 { bottom: 25%; right: 22%; transform: rotate(-10deg); }

        /* Style chung cho SVG tam giác */
        .shape-triangle {
            width: 30px;
            height: 30px;
            background-color: var(--primary-pink);
            clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
            border: 2px solid var(--black);
            /* Mẹo tạo viền cho clip-path bằng drop-shadow */
            filter: drop-shadow(0px 0px 0px var(--black)) drop-shadow(2px 0px 0px var(--black)) drop-shadow(0px 2px 0px var(--black)) drop-shadow(-2px 0px 0px var(--black)) drop-shadow(0px -2px 0px var(--black));
        }
        .shape-triangle.yellow { background-color: var(--brutal-yellow); }
        
        .shape-dot {
            width: 12px; height: 12px;
            background-color: var(--black);
            border-radius: 50%;
        }

        /* =========================================
           LOGO GÓC TRÁI TRÊN
        ========================================= */
        .top-logo {
            position: absolute;
            top: 30px;
            left: 40px;
            color: var(--primary-pink);
            font-size: 24px;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 10;
        }

        /* =========================================
           KHUNG ĐĂNG NHẬP CHÍNH
        ========================================= */
        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 450px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .login-box {
            background-color: var(--white);
            border: var(--border-width) solid var(--black);
            box-shadow: 8px 8px 0px 0px var(--black);
            padding: 40px 35px;
            width: 100%;
            text-align: center;
            margin-bottom: 20px;
        }

        .login-box h1 {
            color: var(--primary-pink);
            font-weight: 900;
            font-size: 32px;
            margin-bottom: 10px;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .subtitle {
            font-weight: 800;
            font-size: 13px;
            margin-bottom: 30px;
            color: var(--black);
        }

        /* Form Controls */
        .input-group {
            text-align: left;
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            font-weight: 800;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i.left-icon {
            position: absolute;
            left: 15px;
            font-size: 16px;
            color: var(--black);
        }

        .input-wrapper i.right-icon {
            position: absolute;
            right: 15px;
            font-size: 16px;
            color: var(--black);
            cursor: pointer;
        }

        .input-wrapper input {
            width: 100%;
            padding: 12px 40px;
            border: var(--border-width) solid var(--black);
            font-size: 14px;
            font-weight: 600;
            outline: none;
            transition: all 0.1s;
        }

        .input-wrapper input:focus {
            box-shadow: 4px 4px 0px 0px var(--black);
            transform: translate(-2px, -2px);
        }

        .input-wrapper input::placeholder {
            color: #888;
            font-weight: 500;
        }

        .text-danger {
            color: var(--primary-pink);
            font-size: 12px;
            font-weight: 700;
            margin-top: 5px;
            display: block;
        }

        /* Nút bấm */
        .btn-brutal {
            width: 100%;
            padding: 14px;
            font-size: 15px;
            font-weight: 900;
            border: var(--border-width) solid var(--black);
            cursor: pointer;
            box-shadow: 4px 4px 0px 0px var(--black);
            transition: all 0.1s ease;
            text-transform: uppercase;
        }

        .btn-brutal:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px 0px var(--black);
        }

        .btn-login {
            background-color: var(--primary-pink);
            color: var(--white);
            margin-bottom: 20px;
        }

        .btn-secondary {
            background-color: var(--white);
            color: var(--black);
            margin-bottom: 10px;
            text-decoration: none;
            display: inline-block;
        }

        .alert-success {
            background-color: #d4edda;
            border: 2px solid #28a745;
            color: #155724;
            padding: 10px;
            font-weight: bold;
            margin-bottom: 20px;
            text-align: center;
        }
        
        .validation-summary {
            background-color: #f8d7da;
            border: 2px solid var(--primary-pink);
            color: var(--primary-pink);
            padding: 10px;
            font-weight: bold;
            margin-bottom: 20px;
            text-align: left;
            font-size: 13px;
        }

        /* Footer Đăng ký */
        .login-footer {
            font-size: 13px;
            font-weight: 700;
            margin-top: 20px;
        }

        .login-footer a {
            color: var(--black);
            font-weight: 900;
            text-decoration: underline;
            text-decoration-thickness: 2px;
        }

        /* Demo Accounts */
        .demo-accounts {
            margin-top: 30px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .demo-btn {
            background: var(--white);
            border: 2px solid var(--black);
            padding: 5px 10px;
            font-size: 11px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 2px 2px 0px var(--black);
        }
        .demo-btn:active {
            transform: translate(2px, 2px);
            box-shadow: 0px 0px 0px var(--black);
        }
    </style>
</head>
<body>

    <a href="/" style="text-decoration: none;">
        <div class="top-logo">
            <i class="fa-solid fa-graduation-cap"></i> EduManager
        </div>
    </a>

    <div class="decor dec-tri-1 shape-triangle"></div>
    
    <svg class="decor dec-squ-1" width="40" height="30" viewBox="0 0 40 30" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="#f4cf45" stroke-width="4" stroke-linecap="round"/>
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="black" stroke-width="6" stroke-linecap="round" style="z-index:-1; position:absolute; stroke:black; mix-blend-mode: destination-over;"/>
    </svg>
    
    <div class="decor dec-dot-1 shape-dot"></div>

    <svg class="decor dec-squ-2" width="40" height="30" viewBox="0 0 40 30" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="#eb2f64" stroke-width="4" stroke-linecap="round"/>
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="black" stroke-width="6" stroke-linecap="round" style="z-index:-1; position:absolute; stroke:black; mix-blend-mode: destination-over;"/>
    </svg>

    <div class="decor dec-tri-2 shape-triangle"></div>
    <div class="decor dec-tri-3 shape-triangle"></div>
    
    <svg class="decor dec-squ-3" width="40" height="30" viewBox="0 0 40 30" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="#eb2f64" stroke-width="4" stroke-linecap="round"/>
        <path d="M3 15 C 8 -5, 12 35, 18 15 C 24 -5, 28 35, 33 15" stroke="black" stroke-width="6" stroke-linecap="round" style="z-index:-1; position:absolute; stroke:black; mix-blend-mode: destination-over;"/>
    </svg>

    <div class="decor dec-dot-2 shape-dot"></div>
    <div class="decor dec-tri-4 shape-triangle yellow"></div>

    <div class="login-wrapper">
        <div class="login-box">
            <h1>ĐĂNG NHẬP 👋 🔒</h1>
            <p class="subtitle">Chào mừng bạn quay trở lại với hệ thống học tập!</p>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-success">@TempData["SuccessMessage"]</div>
            }

            <form method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                
                <div asp-validation-summary="ModelOnly" class="validation-summary" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>
                
                <div class="input-group">
                    <label asp-for="Input.Username">Username</label>
                    <div class="input-wrapper">
                        <i class="fa-regular fa-envelope left-icon"></i>
                        <input id="Username" asp-for="Input.Username" placeholder="Nhập username của bạn" required autocomplete="username">
                    </div>
                    <span asp-validation-for="Input.Username" class="text-danger"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock left-icon"></i>
                        <input id="Password" asp-for="Input.Password" type="password" placeholder="••••••••" required autocomplete="current-password">
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-brutal btn-login">ĐĂNG NHẬP</button>
            </form>
            
            <a asp-page="/Auth/ForgotPassword" class="btn-brutal btn-secondary">QUÊN MẬT KHẨU?</a>
        </div>

        <div class="login-footer">
            Chưa có tài khoản? <a asp-page="/Auth/Register">Đăng ký ngay!</a>
        </div>
        
        <div class="demo-accounts">
            <button class="demo-btn" onclick="quickFill('admin', 'admin123')">Admin</button>
            <button class="demo-btn" style="color: blue;" onclick="quickFill('lecturer', 'lecturer123')">Lecturer</button>
            <button class="demo-btn" style="color: purple;" onclick="quickFill('student', 'student123')">Student</button>
        </div>
    </div>

    <script>
        function quickFill(user, pass) {
            document.getElementById('Username').value = user;
            document.getElementById('Password').value = pass;
        }
    </script>
</body>
</html>
