@page
@model PresentationLayer.Pages.Auth.ForgotPasswordModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu - EduManager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;800;900&display=swap');

        :root {
            --primary-pink: #eb2f64;
            --brutal-yellow: #f4cf45;
            --black: #000000;
            --white: #ffffff;
            --bg-color: #f8f8f8;
            --border-width: 3px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Montserrat', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            background-image: repeating-linear-gradient(45deg, #f0f0f0 25%, transparent 25%, transparent 75%, #f0f0f0 75%, #f0f0f0), repeating-linear-gradient(45deg, #f0f0f0 25%, var(--bg-color) 25%, var(--bg-color) 75%, #f0f0f0 75%, #f0f0f0);
            background-position: 0 0, 20px 20px;
            background-size: 40px 40px;
        }

        .top-logo {
            position: absolute;
            top: 30px;
            left: 40px;
            color: var(--primary-pink);
            font-size: 24px;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 10;
        }

        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 450px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .login-box {
            background-color: var(--white);
            border: var(--border-width) solid var(--black);
            box-shadow: 8px 8px 0px 0px var(--black);
            padding: 40px 35px;
            width: 100%;
            text-align: center;
            margin-bottom: 20px;
        }

        .login-box h1 {
            color: var(--black);
            font-weight: 900;
            font-size: 26px;
            margin-bottom: 10px;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-transform: uppercase;
        }

        .subtitle {
            font-weight: 700;
            font-size: 13px;
            margin-bottom: 30px;
            color: #555;
            line-height: 1.5;
        }

        .input-group {
            text-align: left;
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            font-weight: 800;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i.left-icon {
            position: absolute;
            left: 15px;
            font-size: 16px;
            color: var(--black);
        }

        .input-wrapper input {
            width: 100%;
            padding: 12px 40px;
            border: var(--border-width) solid var(--black);
            font-size: 14px;
            font-weight: 600;
            outline: none;
            transition: all 0.1s;
        }

        .input-wrapper input:focus {
            box-shadow: 4px 4px 0px 0px var(--black);
            transform: translate(-2px, -2px);
        }

        .input-wrapper input::placeholder {
            color: #888;
            font-weight: 500;
        }

        .text-danger {
            color: var(--primary-pink);
            font-size: 12px;
            font-weight: 700;
            margin-top: 5px;
            display: block;
        }

        .btn-brutal {
            width: 100%;
            padding: 14px;
            font-size: 15px;
            font-weight: 900;
            border: var(--border-width) solid var(--black);
            cursor: pointer;
            box-shadow: 4px 4px 0px 0px var(--black);
            transition: all 0.1s ease;
            text-transform: uppercase;
        }

        .btn-brutal:active {
            transform: translate(4px, 4px);
            box-shadow: 0px 0px 0px 0px var(--black);
        }

        .btn-primary {
            background-color: var(--brutal-yellow);
            color: var(--black);
            margin-bottom: 20px;
        }

        .btn-secondary {
            background-color: var(--white);
            color: var(--black);
            margin-bottom: 10px;
            text-decoration: none;
            display: inline-block;
        }

        .alert-success {
            background-color: #d4edda;
            border: 2px solid #28a745;
            color: #155724;
            padding: 10px;
            font-weight: bold;
            margin-bottom: 20px;
            text-align: center;
        }
        
        .validation-summary {
            background-color: #f8d7da;
            border: 2px solid var(--primary-pink);
            color: var(--primary-pink);
            padding: 10px;
            font-weight: bold;
            margin-bottom: 20px;
            text-align: left;
            font-size: 13px;
        }
    </style>
</head>
<body>

    <a href="/" style="text-decoration: none;">
        <div class="top-logo">
            <i class="fa-solid fa-graduation-cap"></i> EduManager
        </div>
    </a>

    <div class="login-wrapper">
        <div class="login-box">
            <h1><i class="fa-solid fa-unlock-keyhole" style="color: var(--primary-pink);"></i> KHÔI PHỤC MẬT KHẨU</h1>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-success">@TempData["SuccessMessage"]</div>
            }

            <div asp-validation-summary="ModelOnly" class="validation-summary" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

            @if (Model.Step == 1)
            {
                <p class="subtitle">Nhập địa chỉ email mà bạn đã đăng ký để nhận mã xác thực (OTP).</p>
                <form method="post" asp-page-handler="SendOtp">
                    <input type="hidden" asp-for="Step" />
                    
                    <div class="input-group">
                        <label asp-for="Email">Địa chỉ Email</label>
                        <div class="input-wrapper">
                            <i class="fa-regular fa-envelope left-icon"></i>
                            <input asp-for="Email" placeholder="ví dụ: abc@gmail.com" required>
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-brutal btn-primary">Gửi mã xác thực</button>
                </form>
            }
            else if (Model.Step == 2)
            {
                <p class="subtitle">Chúng tôi đã gửi một mã OTP gồm 6 chữ số đến email <b>@Model.Email</b>. Vui lòng kiểm tra hộp thư.</p>
                <form method="post" asp-page-handler="VerifyOtp">
                    <input type="hidden" asp-for="Step" />
                    <input type="hidden" asp-for="Email" />
                    
                    <div class="input-group">
                        <label asp-for="Otp">Mã OTP (6 số)</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-hashtag left-icon"></i>
                            <input asp-for="Otp" placeholder="123456" maxlength="6" required style="font-size: 20px; letter-spacing: 5px; text-align: center; padding-left: 15px;">
                        </div>
                        <span asp-validation-for="Otp" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-brutal btn-primary">Xác nhận OTP</button>
                </form>
            }
            else if (Model.Step == 3)
            {
                <p class="subtitle">Mã OTP hợp lệ. Bây giờ bạn có thể thiết lập mật khẩu mới.</p>
                <form method="post" asp-page-handler="ResetPassword">
                    <input type="hidden" asp-for="Step" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Otp" />
                    
                    <div class="input-group">
                        <label asp-for="NewPassword">Mật khẩu mới</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock left-icon"></i>
                            <input asp-for="NewPassword" type="password" placeholder="••••••••" required>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-check left-icon"></i>
                            <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" required>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-brutal btn-primary" style="background-color: var(--primary-pink); color: var(--white);">Đổi mật khẩu</button>
                </form>
            }
            
            <a asp-page="/Auth/Login" class="btn-brutal btn-secondary" style="margin-top: 10px;">QUAY LẠI ĐĂNG NHẬP</a>
        </div>
    </div>
</body>
</html>
