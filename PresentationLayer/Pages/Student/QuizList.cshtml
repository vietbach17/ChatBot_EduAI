@page
@model PresentationLayer.Pages.Student.QuizListModel
@{
    ViewData["Title"] = "Danh Sách Bài Thi";
    ViewBag.ActiveMenu = "StudentQuizzes";
}

<style>
    .brutal-card {
        background-color: var(--white);
        border: 2px solid var(--black);
        box-shadow: 4px 4px 0px var(--black);
        padding: 20px;
        margin-bottom: 20px;
        transition: 0.2s;
    }
    .brutal-card:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px var(--black);
    }
    .brutal-btn {
        background-color: var(--blue);
        color: var(--white);
        border: 2px solid var(--black);
        padding: 8px 15px;
        font-weight: 900;
        font-size: 14px;
        cursor: pointer;
        box-shadow: 2px 2px 0px var(--black);
        transition: 0.1s;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-block;
    }
    .brutal-btn:active {
        box-shadow: 0px 0px 0px var(--black);
        transform: translate(2px, 2px);
    }
    .brutal-btn:disabled, .brutal-btn.disabled {
        background-color: #ccc;
        color: #666;
        cursor: not-allowed;
        box-shadow: 2px 2px 0px #999;
    }
    
    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border: 2px solid var(--black);
        font-weight: 900;
        font-size: 12px;
        text-transform: uppercase;
        box-shadow: 1px 1px 0px var(--black);
    }
    .status-chua-lam { background-color: var(--yellow); color: var(--black); }
    .status-dang-lam { background-color: orange; color: var(--black); }
    .status-hoan-thanh { background-color: var(--green); color: var(--black); }
    .status-het-luot { background-color: #ffcccc; color: var(--black); }

    .quiz-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    /* Custom SweetAlert Brutalist */
    .swal-brutal-popup {
        border: 4px solid var(--black) !important;
        border-radius: 0 !important;
        box-shadow: 8px 8px 0px var(--black) !important;
        padding: 30px !important;
        background: var(--white) !important;
    }
    .swal-brutal-title {
        font-family: 'Inter', sans-serif !important;
        font-weight: 900 !important;
        text-transform: uppercase !important;
        color: var(--pink) !important;
        font-size: 24px !important;
        margin-bottom: 10px !important;
    }
    .swal-brutal-input {
        border: 3px solid var(--black) !important;
        border-radius: 0 !important;
        box-shadow: 4px 4px 0px var(--black) !important;
        font-family: 'Inter', sans-serif !important;
        font-weight: 700 !important;
        font-size: 16px !important;
        padding: 10px 15px !important;
        width: 85% !important;
        margin: 0 auto 20px auto !important;
    }
    .swal-brutal-input:focus {
        outline: none !important;
        border-color: var(--blue) !important;
        box-shadow: 4px 4px 0px var(--blue) !important;
    }
    .swal-brutal-btn {
        font-family: 'Inter', sans-serif !important;
        font-weight: 900 !important;
        border: 3px solid var(--black) !important;
        border-radius: 0 !important;
        box-shadow: 4px 4px 0px var(--black) !important;
        text-transform: uppercase !important;
        padding: 10px 20px !important;
        cursor: pointer !important;
        margin: 0 10px !important;
    }
    .swal-brutal-confirm {
        background-color: var(--pink) !important;
        color: var(--white) !important;
    }
    .swal-brutal-cancel {
        background-color: #ccc !important;
        color: var(--black) !important;
    }
    .swal-brutal-btn:active {
        box-shadow: 0 0 0 0 var(--black) !important;
        transform: translate(4px, 4px) !important;
    }
    .swal-brutal-validation {
        background: var(--yellow) !important;
        color: var(--black) !important;
        font-weight: 900 !important;
        border: 2px solid var(--black) !important;
        border-radius: 0 !important;
    }

    @@media (max-width: 768px) {
        .main-wrapper {
            padding: 15px !important;
        }
        .main-wrapper h1 {
            font-size: 22px !important;
        }
        .brutal-card {
            padding: 15px !important;
        }
    }
</style>

<div class="main-wrapper" style="padding: 30px;">
    <h1 style="color: var(--blue); font-weight: 900; text-transform: uppercase; margin-bottom: 5px; font-size: 32px;">
        <i class="fa-solid fa-file-signature"></i> BÀI THI CỦA TÔI
    </h1>
    <p style="font-weight: 700; color: #555; margin-bottom: 30px;">Danh sách các bài kiểm tra từ các môn học bạn đang tham gia.</p>

    @if (!Model.Quizzes.Any())
    {
        <div class="brutal-card" style="text-align: center; padding: 40px; background-color: #f9f9f9;">
            <i class="fa-regular fa-face-frown" style="font-size: 48px; color: #999; margin-bottom: 15px;"></i>
            <h3 style="margin: 0; color: #555;">Bạn chưa có bài thi nào!</h3>
            <p style="color: #777;">Hãy đăng ký gói học hoặc chờ giảng viên phát hành bài thi mới.</p>
        </div>
    }
    else
    {
        <div class="quiz-grid">
            @foreach (var quiz in Model.Quizzes)
            {
                <div class="brutal-card" style="display: flex; flex-direction: column;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                        <span class="status-badge 
                            @(quiz.Status == "Chưa làm" ? "status-chua-lam" : 
                              quiz.Status == "Đang làm" ? "status-dang-lam" : 
                              quiz.Status == "Hoàn thành" ? "status-hoan-thanh" : "status-het-luot")">
                            @quiz.Status
                        </span>
                        <div style="font-weight: 800; font-size: 12px; color: var(--pink); border: 2px solid var(--black); padding: 2px 6px; box-shadow: 1px 1px 0px var(--black);">
                            <i class="fa-regular fa-clock"></i> @quiz.TimeLimitMinutes Phút
                        </div>
                    </div>
                    
                    <h3 style="margin: 0 0 10px 0; font-size: 18px; font-weight: 900; line-height: 1.3;">
                        @quiz.Title
                    </h3>
                    
                    <div style="font-weight: 700; font-size: 14px; color: #555; margin-bottom: 15px; display: flex; align-items: center; gap: 5px;">
                        <i class="fa-solid fa-book"></i> @quiz.SubjectName
                    </div>

                    <div style="margin-top: auto; border-top: 2px dashed var(--black); padding-top: 15px; display: flex; justify-content: space-between; align-items: center;">
                        <div style="font-weight: 700; font-size: 13px;">
                            Lượt làm: <strong>@quiz.AttemptsCount / @quiz.MaxAttempts</strong>
                        </div>
                        
                        @if (quiz.Status == "Hết lượt")
                        {
                            <a href="/Student/QuizInfo/@quiz.QuizId" class="brutal-btn" style="background-color: #eee; color: var(--black);">Xem Kết Quả</a>
                        }
                        else if (quiz.Status == "Hoàn thành")
                        {
                            <button type="button" class="brutal-btn" style="background-color: var(--yellow); color: var(--black);" onclick="takeQuiz(@quiz.QuizId, @(quiz.HasPassword ? "true" : "false"))">Làm Lại</button>
                        }
                        else if (quiz.Status == "Đang làm")
                        {
                            <button type="button" class="brutal-btn" style="background-color: orange; color: var(--black);" onclick="resumeQuiz(@quiz.QuizId, @(quiz.HasPassword ? "true" : "false"))">Tiếp Tục</button>
                        }
                        else
                        {
                            <button type="button" class="brutal-btn" style="background-color: var(--pink);" onclick="takeQuiz(@quiz.QuizId, @(quiz.HasPassword ? "true" : "false"))">Vào Làm</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Hàm POST data để tạo attempt mới
    function startNewQuizAttempt(quizId, accessCode) {
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '/Student/TakeQuiz/' + quizId + '?handler=Start';
        
        // Add CSRF token manually (ASP.NET Core Razor Pages includes it in all forms, but since we create dynamically, we get it from an existing token if needed, or just let it pass if disabled. Wait, Razor Pages might require AntiForgeryToken! We should include it)
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (antiForgeryToken) {
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = antiForgeryToken;
            form.appendChild(tokenInput);
        }

        if (accessCode) {
            const codeInput = document.createElement('input');
            codeInput.type = 'hidden';
            codeInput.name = 'accessCode';
            codeInput.value = accessCode;
            form.appendChild(codeInput);
        }
        
        document.body.appendChild(form);
        form.submit();
    }

    function resumeQuiz(quizId, hasPassword) {
        if (!hasPassword) {
            window.location.href = '/Student/TakeQuiz/' + quizId;
            return;
        }
        // Giống takeQuiz nhưng dùng redirect thay vì POST
        Swal.fire({
            title: 'BÀI THI CÓ MẬT KHẨU',
            input: 'password',
            inputPlaceholder: 'Nhập mật khẩu truy cập...',
            showCancelButton: true,
            confirmButtonText: 'TIẾP TỤC',
            cancelButtonText: 'QUAY LẠI',
            buttonsStyling: false,
            customClass: {
                popup: 'swal-brutal-popup',
                title: 'swal-brutal-title',
                input: 'swal-brutal-input',
                confirmButton: 'swal-brutal-btn swal-brutal-confirm',
                cancelButton: 'swal-brutal-btn swal-brutal-cancel',
                validationMessage: 'swal-brutal-validation'
            },
            showLoaderOnConfirm: true,
            preConfirm: (pwd) => {
                if (!pwd) {
                    Swal.showValidationMessage('Vui lòng nhập mật khẩu!');
                    return false;
                }
                return fetch(`/Student/QuizList?handler=CheckPassword&quizId=${quizId}&accessCode=${encodeURIComponent(pwd)}`)
                    .then(response => response.ok ? response.json() : Promise.reject('Lỗi mạng'))
                    .then(data => data.success ? pwd : Promise.reject(data.message))
                    .catch(error => { Swal.showValidationMessage(error); return false; });
            },
            allowOutsideClick: () => !Swal.isLoading()
        }).then((result) => {
            if (result.isConfirmed && result.value) {
                window.location.href = '/Student/TakeQuiz/' + quizId + '?AccessCode=' + encodeURIComponent(result.value);
            }
        });
    }

    function takeQuiz(quizId, hasPassword) {
        if (!hasPassword) {
            startNewQuizAttempt(quizId, '');
            return;
        }

        Swal.fire({
            title: 'BÀI THI CÓ MẬT KHẨU',
            input: 'password',
            inputPlaceholder: 'Nhập mật khẩu truy cập...',
            showCancelButton: true,
            confirmButtonText: 'VÀO LÀM',
            cancelButtonText: 'QUAY LẠI',
            buttonsStyling: false,
            customClass: {
                popup: 'swal-brutal-popup',
                title: 'swal-brutal-title',
                input: 'swal-brutal-input',
                confirmButton: 'swal-brutal-btn swal-brutal-confirm',
                cancelButton: 'swal-brutal-btn swal-brutal-cancel',
                validationMessage: 'swal-brutal-validation'
            },
            showLoaderOnConfirm: true,
            preConfirm: (pwd) => {
                if (!pwd) {
                    Swal.showValidationMessage('Vui lòng nhập mật khẩu!');
                    return false;
                }
                return fetch(`/Student/QuizList?handler=CheckPassword&quizId=${quizId}&accessCode=${encodeURIComponent(pwd)}`)
                    .then(response => response.ok ? response.json() : Promise.reject('Lỗi mạng'))
                    .then(data => data.success ? pwd : Promise.reject(data.message))
                    .catch(error => { Swal.showValidationMessage(error); return false; });
            },
            allowOutsideClick: () => !Swal.isLoading()
        }).then((result) => {
            if (result.isConfirmed && result.value) {
                startNewQuizAttempt(quizId, result.value);
            }
        });
    }

    // SignalR cho phép tự động cập nhật danh sách bài thi khi giảng viên thay đổi (thêm/sửa/xóa)
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/courseHub")
        .build();

    connection.on("CourseChanged", function () {
        // Tự động tải lại trang khi có sự thay đổi về bài thi
        window.location.reload();
    });

    connection.start().catch(function (err) {
        return console.error(err.toString());
    });
</script>
