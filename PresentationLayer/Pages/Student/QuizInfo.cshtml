@page "{id:int}"
@model PresentationLayer.Pages.Student.QuizInfoModel
@{
    ViewData["Title"] = "Thông tin bài thi";
    ViewBag.ActiveMenu = "StudentQuizzes";
}

@section Styles {
<style>
    :root {
        --q-pink: #eb2f64;
        --q-yellow: #f4cf45;
        --q-green: #5cb85c;
        --q-blue: #4fa8db;
        --q-black: #000;
        --q-white: #fff;
    }
    .quiz-info-wrapper {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px 60px;
        font-family: 'Be Vietnam Pro', sans-serif;
    }
    .quiz-header-banner {
        background-color: var(--q-pink);
        color: var(--q-white);
        padding: 40px;
        border: 4px solid var(--q-black);
        box-shadow: 8px 8px 0px var(--q-black);
        margin-bottom: 30px;
        position: relative;
    }
    .quiz-header-banner::after {
        content: '';
        position: absolute;
        top: 10px; right: 10px;
        width: 40px; height: 40px;
        background: var(--q-yellow);
        border: 3px solid var(--q-black);
        border-radius: 50%;
    }
    .quiz-title-tag {
        font-size: 36px;
        font-weight: 900;
        text-transform: uppercase;
        margin: 0 0 15px 0;
        line-height: 1.2;
    }
    .quiz-desc {
        font-size: 16px;
        font-weight: 600;
        margin: 0;
        opacity: 0.9;
    }
    
    .quiz-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    .meta-item {
        background: var(--q-white);
        border: 3px solid var(--q-black);
        box-shadow: 4px 4px 0px var(--q-black);
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .meta-item:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px var(--q-black);
    }
    .meta-icon {
        width: 45px; height: 45px;
        background: var(--q-gray);
        border: 2px solid var(--q-black);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        border-radius: 8px;
    }
    .meta-content { display: flex; flex-direction: column; }
    .meta-label { font-size: 12px; font-weight: 800; color: #666; text-transform: uppercase; margin-bottom: 4px; }
    .meta-value { font-size: 16px; font-weight: 900; color: var(--q-black); }
    
    .score-hero-card {
        background-color: var(--q-yellow);
        border: 4px solid var(--q-black);
        box-shadow: 8px 8px 0px var(--q-black);
        padding: 30px 40px;
        margin-bottom: 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transform: rotate(-1deg);
    }
    .score-hero-card:hover { transform: rotate(0deg); }
    .score-title { font-size: 28px; font-weight: 900; text-transform: uppercase; color: var(--q-black); margin: 0 0 5px 0; }
    .score-subtitle { font-size: 14px; font-weight: 700; color: #444; margin: 0; }
    .score-value { font-size: 64px; font-weight: 900; color: var(--q-black); text-shadow: 4px 4px 0px var(--q-white); }
    
    .quiz-action-area {
        background: #f4f4f6;
        border: 3px dashed var(--q-black);
        padding: 40px;
        text-align: center;
        margin-bottom: 50px;
    }
    .btn-start-quiz {
        background-color: var(--q-blue);
        color: var(--q-white);
        border: 4px solid var(--q-black);
        padding: 16px 48px;
        font-weight: 900;
        font-size: 22px;
        text-transform: uppercase;
        box-shadow: 6px 6px 0px var(--q-black);
        cursor: pointer;
        transition: 0.1s;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }
    .btn-start-quiz:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0px var(--q-black); color: var(--q-white); }
    .btn-start-quiz:active { transform: translate(4px, 4px); box-shadow: 0px 0px 0px var(--q-black); }
    
    .brutal-input {
        border: 3px solid var(--q-black);
        padding: 15px;
        font-size: 18px;
        font-weight: 700;
        width: 350px;
        max-width: 100%;
        margin-bottom: 20px;
        text-align: center;
        box-shadow: inset 2px 2px 0px rgba(0,0,0,0.1);
    }
    
    .attempts-header {
        font-size: 24px;
        font-weight: 900;
        text-transform: uppercase;
        border-bottom: 4px solid var(--q-black);
        padding-bottom: 15px;
        margin-bottom: 25px;
        display: flex; align-items: center; gap: 10px;
    }
    .table-container {
        border: 3px solid var(--q-black);
        box-shadow: 6px 6px 0px var(--q-black);
        background: var(--q-white);
        margin-bottom: 40px;
        overflow-x: auto;
    }
    .attempts-table {
        width: 100%;
        border-collapse: collapse;
    }
    .attempts-table th {
        background-color: var(--q-black);
        color: var(--q-white);
        padding: 18px;
        font-weight: 900;
        text-transform: uppercase;
        font-size: 14px;
        text-align: left;
    }
    .attempts-table td {
        padding: 18px;
        border-bottom: 2px solid var(--q-black);
        font-weight: 700;
        font-size: 15px;
        vertical-align: middle;
    }
    .attempts-table tr:last-child td { border-bottom: none; }
    .attempts-table tr:hover td { background-color: #f4f4f6; }
    
    .badge {
        display: inline-block; padding: 6px 12px; border: 2px solid var(--q-black); 
        font-weight: 800; font-size: 12px; text-transform: uppercase; box-shadow: 2px 2px 0px var(--q-black);
    }
    .badge-graded { background: var(--q-green); color: var(--q-white); }
    .badge-inprogress { background: var(--q-yellow); color: var(--q-black); }
    
    .btn-review, .btn-continue {
        border: 2px solid var(--q-black);
        padding: 8px 16px;
        font-weight: 800;
        font-size: 13px;
        text-decoration: none;
        display: inline-block;
        box-shadow: 3px 3px 0px var(--q-black);
        text-transform: uppercase;
        transition: 0.1s;
    }
    .btn-review { background-color: var(--q-white); color: var(--q-black); }
    .btn-review:hover { background-color: var(--q-black); color: var(--q-white); transform: translate(-2px, -2px); box-shadow: 5px 5px 0px var(--q-pink); }
    .btn-continue { background-color: var(--q-pink); color: var(--q-white); }
    .btn-continue:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0px var(--q-black); color: var(--q-white); }
    
    .btn-back {
        background-color: var(--q-black);
        color: var(--q-white);
        border: 3px solid var(--q-black);
        padding: 15px 30px;
        font-weight: 900;
        font-size: 16px;
        text-decoration: none;
        display: inline-block;
        box-shadow: 4px 4px 0px var(--q-pink);
        text-transform: uppercase;
        transition: 0.1s;
    }
    .btn-back:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--q-pink); color: var(--q-white); }
    
    .error-card {
        background-color: var(--q-white);
        border: 4px solid var(--q-pink);
        box-shadow: 6px 6px 0px var(--q-pink);
        padding: 25px;
        font-weight: 800;
        color: var(--q-pink);
        margin-bottom: 30px;
        font-size: 18px;
    }
    
    @@media (max-width: 768px) {
        .quiz-info-wrapper { margin: 20px auto; padding: 0 15px; }
        .score-hero-card { flex-direction: column; text-align: center; gap: 20px; transform: none; }
        .btn-start-quiz { width: 100%; justify-content: center; }
    }
</style>
}

<div class="quiz-info-wrapper" style="overflow-y:auto">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-card">
            <strong><i class="fa-solid fa-triangle-exclamation"></i> Lỗi:</strong> @Model.ErrorMessage
        </div>
    }
    else
    {
        <div class="quiz-header-banner">
            <h1 class="quiz-title-tag"><i class="fa-solid fa-file-signature"></i> @Model.QuizInfo.Title</h1>
            @if (!string.IsNullOrEmpty(Model.QuizInfo.Description))
            {
                <p class="quiz-desc">@Model.QuizInfo.Description</p>
            }
        </div>

        <div class="quiz-meta-grid">
            <div class="meta-item">
                <div class="meta-icon" style="background:#e8f4fd; color:var(--q-blue);"><i class="fa-solid fa-rotate-right"></i></div>
                <div class="meta-content">
                    <span class="meta-label">Số lượt làm</span>
                    <span class="meta-value">@(Model.QuizInfo.MaxAttempts == 0 ? "Không giới hạn" : Model.QuizInfo.MaxAttempts.ToString())</span>
                </div>
            </div>
            <div class="meta-item">
                <div class="meta-icon" style="background:#fef5e7; color:#f39c12;"><i class="fa-solid fa-clock"></i></div>
                <div class="meta-content">
                    <span class="meta-label">Thời gian</span>
                    <span class="meta-value">@Model.QuizInfo.TimeLimitMinutes phút</span>
                </div>
            </div>
            <div class="meta-item">
                <div class="meta-icon" style="background:#eafaf1; color:var(--q-green);"><i class="fa-solid fa-star"></i></div>
                <div class="meta-content">
                    <span class="meta-label">Tính điểm</span>
                    <span class="meta-value">@Model.QuizInfo.GradingMethod</span>
                </div>
            </div>
            @if (Model.QuizInfo.HasPassword)
            {
                <div class="meta-item">
                    <div class="meta-icon" style="background:#fdedf1; color:var(--q-pink);"><i class="fa-solid fa-lock"></i></div>
                    <div class="meta-content">
                        <span class="meta-label">Bảo mật</span>
                        <span class="meta-value">Có mật khẩu</span>
                    </div>
                </div>
            }
        </div>

        @if (true)
        {
            var inProgressAttempt = Model.QuizInfo.Attempts?.FirstOrDefault(a => a.Status == "InProgress");
            bool isExpired = Model.QuizInfo.EndTime.HasValue && DateTime.UtcNow > Model.QuizInfo.EndTime.Value;
            bool canTakeMore = !isExpired && (Model.QuizInfo.MaxAttempts == 0 || (Model.QuizInfo.Attempts?.Count ?? 0) < Model.QuizInfo.MaxAttempts);

            <div class="quiz-action-area">
                @if (inProgressAttempt != null)
                {
                    <h3 style="margin-top: 0; font-weight: 900; color: orange;"><i class="fa-solid fa-spinner"></i> BẠN CÓ BÀI THI ĐANG LÀM DỞ</h3>
                    <a href="/Student/TakeQuiz/@inProgressAttempt.AttemptId" class="btn-start-quiz">
                        <i class="fa-solid fa-play"></i> TIẾP TỤC LÀM BÀI
                    </a>
                }
                else if (canTakeMore)
                {
                    <form method="post" action="/Student/TakeQuiz/@Model.QuizInfo.Id?handler=Start" class="start-quiz-form">
                        @if (Model.QuizInfo.HasPassword)
                        {
                            <div style="margin-bottom: 15px;">
                                <label style="font-weight: 900; font-size: 16px; display: block; margin-bottom: 10px;">
                                    <i class="fa-solid fa-key"></i> NHẬP MẬT KHẨU BÀI THI:
                                </label>
                                <input type="password" name="accessCode" required class="brutal-input" placeholder="Mật khẩu..." />
                            </div>
                        }
                        <button type="submit" class="btn-start-quiz">
                            <i class="fa-solid fa-rocket"></i> BẮT ĐẦU LÀM BÀI
                        </button>
                        @Html.AntiForgeryToken()
                    </form>
                }
                else if (isExpired)
                {
                    <div class="no-more-attempts">
                        <i class="fa-solid fa-clock"></i> Bài thi đã quá hạn thời gian làm bài.
                    </div>
                }
                else
                {
                    <div class="no-more-attempts">
                        <i class="fa-solid fa-ban"></i> Bạn đã hết số lượt làm bài cho phép.
                    </div>
                }
            </div>
        }

        @if (Model.QuizInfo.FinalScore.HasValue)
        {
            <div class="score-hero-card">
                <div>
                    <h2 class="score-title"><i class="fa-solid fa-award"></i> ĐIỂM TỔNG KẾT</h2>
                    <p class="score-subtitle">Được tính theo phương pháp: <strong style="color:var(--q-black);">@Model.QuizInfo.GradingMethod</strong></p>
                </div>
                <div class="score-value">
                    @Model.QuizInfo.FinalScore.Value.ToString("0.00")
                </div>
            </div>
        }

        <div class="attempts-header">Các lượt làm bài của bạn</div>


        @if (Model.QuizInfo.Attempts != null && Model.QuizInfo.Attempts.Any())
        {
            <div class="table-container">
                <table class="attempts-table">

                <thead>
                    <tr>
                        <th>Lượt</th>
                        <th>Trạng Thái</th>
                        <th>Điểm</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int attemptNumber = 1;
                        foreach (var attempt in Model.QuizInfo.Attempts)
                        {
                            <tr>
                                <td style="font-weight: 900; font-size: 16px;">@attemptNumber</td>
                                <td>
                                    @if (attempt.Status == "Graded")
                                    {
                                        <span class="badge badge-graded"><i class="fa-solid fa-check-circle"></i> Đã hoàn thành</span>
                                    }
                                    else if (attempt.Status == "InProgress")
                                    {
                                        <span class="badge badge-inprogress"><i class="fa-solid fa-spinner fa-spin"></i> Đang làm</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#eee;">@attempt.Status</span>
                                    }
                                    <div style="font-size: 12px; color: #555; font-weight: 600; margin-top: 6px;">
                                        <i class="fa-regular fa-clock"></i> Bắt đầu: @attempt.StartTime.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                    @if (attempt.Status == "Graded" && attempt.EndTime.HasValue)
                                    {
                                        <div style="font-size: 12px; color: #555; font-weight: 600;">
                                            <i class="fa-solid fa-flag-checkered"></i> Nộp bài: @attempt.EndTime.Value.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    }
                                </td>
                                <td style="font-size: 18px; font-weight: 900;">
                                    @if (attempt.Status == "Graded" && Model.QuizInfo.ShowScoreAfterSubmit)
                                    {
                                        <span style="color: var(--blue);">@attempt.Score.ToString("0.00")</span>
                                    }
                                    else if (attempt.Status == "Graded")
                                    {
                                        <span style="color: #777; font-style: italic; font-size: 14px;">Ẩn</span>
                                    }
                                    else
                                    {
                                        <span style="color: #ccc;">—</span>
                                    }
                                </td>
                                <td>
                                    @if (attempt.Status == "Graded")
                                    {
                                        <a href="/Student/QuizResult/@attempt.AttemptId" class="btn-review">
                                            <i class="fa-solid fa-eye"></i> Xem lại
                                        </a>
                                    }
                                    else if (attempt.Status == "InProgress")
                                    {
                                        <a href="/Student/TakeQuiz/@attempt.AttemptId" class="btn-continue">
                                            <i class="fa-solid fa-play"></i> Tiếp tục
                                        </a>
                                    }
                                </td>
                            </tr>
                            attemptNumber++;
                        }
                    }
                </tbody>

            </table>

            </div>
        }
        else
        {
            <div class="empty-notice">
                <i class="fa-solid fa-inbox" style="font-size: 32px; margin-bottom: 15px; display: block;"></i>
                Bạn chưa thực hiện lượt làm bài nào.
            </div>
        }

        <a href="/Student/QuizList" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> QUAY LẠI DANH SÁCH
        </a>
    }
</div>
