@page
@model PresentationLayer.Pages.ViewDocumentModel
@{
    ViewData["Title"] = "Chi tiết Tài liệu: " + Model.Document?.Title;
    var hasContent = !string.IsNullOrWhiteSpace(Model.TextContent) && Model.TextContent != "Không có nội dung dạng text cho file này.";
    var hasChunks = Model.SimulatedChunks.Any();
    var fileType = Model.Document?.FileType?.ToLower() ?? "";
    var isViewable = new[] { "txt", "md", "csv", "pdf", "docx", "doc", "pptx", "log" }.Contains(fileType);
    var isStudent = User.IsInRole("Student");
    var isPdfView = Model.IsPdfView;
    var isOfficeType = new[] { "docx", "doc", "pptx", "ppt" }.Contains(fileType);
}

<div class="main-wrapper">
    <div style="padding: 30px;">
        <div style="margin-bottom: 20px;">
            <a href="javascript:history.back()" style="color: var(--black); text-decoration: none; font-weight: 800; font-size: 14px;">
                <i class="fa-solid fa-arrow-left"></i> QUAY LẠI
            </a>
        </div>

        <div style="background: var(--white); border: 4px solid var(--black); box-shadow: 8px 8px 0px var(--black); padding: 30px; margin-bottom: 30px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
                <div>
                    <h1 style="color: var(--pink); font-weight: 900; margin-bottom: 10px; font-size: 24px; text-transform: uppercase;">
                        @Model.Document?.Title
                        @if (Model.Document?.IsDeleted == true)
                        {
                            <span style="background: #dc2626; color: white; padding: 4px 8px; font-size: 14px; vertical-align: middle; margin-left: 10px; border: 2px solid var(--black); box-shadow: 2px 2px 0px var(--black);">
                                <i class="fa-solid fa-trash"></i> ĐÃ XÓA TẠM
                            </span>
                        }
                    </h1>
                    <div style="font-weight: 700; font-size: 14px; color: #555; display: flex; gap: 20px; flex-wrap: wrap;">
                        <span>
                            @{
                                var iconClass = fileType switch {
                                    "pdf"           => "fa-file-pdf",
                                    "docx" or "doc" => "fa-file-word",
                                    "pptx" or "ppt" => "fa-file-powerpoint",
                                    "txt" or "md"   => "fa-file-lines",
                                    "csv"           => "fa-file-csv",
                                    _               => "fa-file"
                                };
                            }
                            <i class="fa-solid @iconClass"></i> Loại file: @fileType.ToUpper()
                        </span>
                        <span><i class="fa-solid fa-clock"></i> Cập nhật: @Model.Document?.UploadedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="fa-solid fa-user"></i> Người tải: @(Model.Document?.UploaderName ?? "Hệ thống")</span>
                        @if (hasChunks)
                        {
                            <span style="color: var(--blue); background: #e8f4fd; padding: 2px 8px; border: 2px solid var(--blue);">
                                <i class="fa-solid fa-cubes"></i> @Model.SimulatedChunks.Count chunks
                            </span>
                        }
                    </div>
                </div>                <a href="@Model.Document?.FileUrl" download target="_blank" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 3px solid var(--black); padding: 10px 20px; font-weight: 900; text-decoration: none; box-shadow: 4px 4px 0px var(--black);">
                    <i class="fa-solid fa-download"></i> TẢI XUỐNG
                </a>
            </div>

            <!-- TAB HEADERS -->
            <div style="display: flex; border-bottom: 3px solid var(--black); margin-bottom: 20px;">
                <div id="tab-content" onclick="switchTab('content')" style="padding: 10px 20px; font-weight: 900; cursor: pointer; background: var(--black); color: var(--white); border: 3px solid var(--black); border-bottom: none; margin-right: 10px;">
                    <i class="fa-solid fa-file-lines"></i> NỘI DUNG
                </div>
                @if (Model.CanViewChunks)
                {
                    <div id="tab-chunks" onclick="switchTab('chunks')" style="padding: 10px 20px; font-weight: 900; cursor: pointer; background: var(--white); color: var(--black); border: 3px solid var(--black); border-bottom: none;">
                        <i class="fa-solid fa-cubes"></i> VECTOR CHUNKS @(hasChunks ? $"({Model.SimulatedChunks.Count})" : "")
                    </div>
                }
            </div>

            <!-- TAB: NỘI DUNG FILE (hiển thị ngay, không cần chunk trước) -->
            <div id="panel-content" style="display: block;">
                @if (isPdfView)
                {
                    @* ─── Xem "chuẩn như lúc up": render bản PDF bằng PDF.js ─── *@
                    @if (Model.HighlightChunkIndex.HasValue)
                    {
                        <div id="pdfHlBanner" style="background:#fef9c3; border:3px solid var(--black); box-shadow:3px 3px 0 var(--black); padding:10px 16px; font-weight:800; font-size:13px; margin-bottom:14px;">
                            <i class="fa-solid fa-location-crosshairs" style="color:#d97706;"></i>
                            Đang xem vị trí trích dẫn từ Chat AI — <strong>Đoạn #@Model.HighlightChunkIndex</strong> sẽ được tô vàng trên bản tài liệu bên dưới.
                        </div>
                    }
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; flex-wrap: wrap; gap: 8px;">
                        <p style="font-style: italic; color: #555; font-weight: 600; margin: 0;">
                            Bản tài liệu gốc <strong>@fileType.ToUpper()</strong> hiển thị đúng định dạng như lúc tải lên.
                        </p>
                    </div>
                    <div id="pdfViewer" data-pdf-url="@Model.PdfUrl"
                         style="background: #525659; border: 2px solid var(--black); padding: 16px; max-height: 760px; overflow-y: auto;">
                        <div id="pdfStatus" style="text-align:center; color:#eee; font-weight:800; padding:40px 10px;">
                            <i class="fa-solid fa-spinner fa-spin"></i> Đang tải bản xem tài liệu…
                        </div>
                        <div id="pdfPages"></div>
                    </div>
                }
                else
                {
                    @* ─── Không có bản PDF: rơi về chế độ xem text (vẫn highlight reference) ─── *@
                    @if (Model.HighlightChunkIndex.HasValue)
                    {
                        @if (Model.HighlightFound)
                        {
                            <div style="background:#fef9c3; border:3px solid var(--black); box-shadow:3px 3px 0 var(--black); padding:10px 16px; font-weight:800; font-size:13px; margin-bottom:14px;">
                                <i class="fa-solid fa-location-crosshairs" style="color:#d97706;"></i>
                                Đang xem vị trí trích dẫn từ Chat AI — <strong>Đoạn #@Model.HighlightChunkIndex</strong> được tô vàng bên dưới.
                            </div>
                        }
                        else
                        {
                            <div style="background:#fee2e2; border:3px solid var(--black); box-shadow:3px 3px 0 var(--black); padding:10px 16px; font-weight:800; font-size:13px; margin-bottom:14px;">
                                <i class="fa-solid fa-triangle-exclamation" style="color:#dc2626;"></i>
                                Không định vị được chính xác Đoạn #@Model.HighlightChunkIndex trong nội dung hiển thị (tài liệu có thể đã được tải lại). Bạn vẫn có thể đọc toàn bộ nội dung bên dưới.
                            </div>
                        }
                    }
                    @if (isOfficeType)
                    {
                        <div style="background:#e8f4fd; border:2px solid var(--blue); padding:10px 16px; font-weight:700; font-size:12.5px; margin-bottom:14px; color:#0b4f77;">
                            <i class="fa-solid fa-circle-info"></i>
                            File @fileType.ToUpper() chưa hiển thị được đúng định dạng gốc vì máy chủ chưa cài LibreOffice để convert sang PDF. Đang hiển thị nội dung dạng text.
                        </div>
                    }
                    @if (hasContent)
                    {
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                            <p style="font-style: italic; color: #555; font-weight: 600; margin: 0;">
                                Nội dung văn bản trích xuất từ file <strong>@fileType.ToUpper()</strong>.
                            </p>
                            <span style="font-size: 12px; color: #888; font-weight: 700;">
                                @Model.TextContent.Length.ToString("N0") ký tự
                            </span>
                        </div>
                        <div id="docContentBox" style="background: #1e1e1e; border: 2px solid var(--black); padding: 20px; max-height: 600px; overflow-y: auto; font-family: 'Courier New', monospace; font-size: 13px; line-height: 1.7; color: #d4d4d4; white-space: pre-wrap; word-wrap: break-word;">@if (Model.HighlightFound)
                        {<text>@Model.TextContent[..Model.HighlightStart]<mark id="chunkHighlight" style="background:#fde047; color:#111; padding:1px 0; outline:3px solid #f59e0b;">@Model.TextContent.Substring(Model.HighlightStart, Model.HighlightLength)</mark>@Model.TextContent[(Model.HighlightStart + Model.HighlightLength)..]</text>}
                        else
                        {@Model.TextContent}</div>
                    }
                    else
                    {
                        <div style="padding: 40px; text-align: center; border: 2px dashed #000; background: var(--bg);">
                            <i class="fa-solid fa-file-circle-question" style="font-size: 48px; color: #ccc; margin-bottom: 15px; display: block;"></i>
                            <p style="font-weight: 800; font-size: 16px; margin-bottom: 10px;">Không thể hiển thị nội dung</p>
                            <p style="color: #777; font-size: 14px;">
                                @if (!isViewable)
                                {
                                    <text>File <strong>@fileType.ToUpper()</strong> chưa được hỗ trợ trích xuất text.</text>
                                }
                                else
                                {
                                    <text>File chưa có nội dung. Hãy tải lại file để hệ thống trích xuất text.</text>
                                }
                            </p>
                            <a href="@Model.Document?.FileUrl" target="_blank" style="color: var(--blue); font-weight: 800;">
                                <i class="fa-solid fa-external-link-alt"></i> Mở file gốc
                            </a>
                        </div>
                    }
                }
            </div>

            <!-- TAB: VECTOR CHUNKS -->
            @if (Model.CanViewChunks)
            {
            <div id="panel-chunks" style="display: none;">
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div style="background-color: #d4edda; color: #155724; border: 3px solid #155724; padding: 10px; font-weight: 800; margin-bottom: 20px;">
                        <i class="fa-solid fa-check-circle"></i> @Model.SuccessMessage
                    </div>
                }

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <p style="font-style: italic; color: #555; font-weight: 600; margin: 0;">
                        Các đoạn văn bản (Chunks) đã Vector Embedding bằng Gemini AI.
                    </p>
                    @if (!hasChunks && hasContent)
                    {
                        <form method="post" asp-page-handler="ProcessEmbedding" asp-route-id="@Model.Document?.Id">
                            <button type="submit" class="brutal-btn" style="background-color: var(--pink); color: var(--white); border: 2px solid var(--black); padding: 8px 15px; font-weight: 900; box-shadow: 2px 2px 0px var(--black);">
                                <i class="fa-solid fa-brain"></i> THỰC HIỆN BĂM &amp; NHÚNG VECTOR
                            </button>
                        </form>
                    }
                    else if (hasChunks)
                    {
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <span style="background: var(--blue); color: white; padding: 5px 12px; font-weight: 900; font-size: 13px; border: 2px solid var(--black);">
                                <i class="fa-solid fa-check"></i> ĐÃ VECTOR HÓA
                            </span>
                            <form id="reprocessForm" method="post" asp-page-handler="ReprocessEmbedding" asp-route-id="@Model.Document?.Id" style="margin: 0;">
                                <button type="button" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 2px solid var(--black); padding: 5px 12px; font-weight: 900; font-size: 13px; box-shadow: 2px 2px 0px var(--black); cursor: pointer;" onclick="document.getElementById('reprocessModal').style.display='flex'">
                                    <i class="fa-solid fa-rotate-right"></i> THỰC HIỆN LẠI CHUNK
                                </button>
                            </form>
                        </div>
                    }
                </div>

                @if (hasChunks)
                {
                    <div style="display: flex; flex-direction: column; gap: 12px; max-height: 600px; overflow-y: auto; padding-right: 8px;">
                        @for (int i = 0; i < Model.SimulatedChunks.Count; i++)
                        {
                            <div style="background: var(--white); border: 2px dashed var(--black); padding: 15px; position: relative;">
                                <div style="position: absolute; top: -11px; left: 10px; background: var(--blue); color: white; padding: 2px 10px; font-weight: 900; font-size: 10px; border: 2px solid var(--black); letter-spacing: 1px;">
                                    CHUNK #@(i + 1) &nbsp;|&nbsp; @Model.SimulatedChunks[i].Split(' ').Length từ
                                </div>
                                <div style="font-family: 'Courier New', monospace; font-size: 13px; color: #333; line-height: 1.6; margin-top: 10px; white-space: pre-wrap;">@Model.SimulatedChunks[i]</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding: 40px; text-align: center; border: 2px dashed #000; background: var(--bg);">
                        <i class="fa-solid fa-brain" style="font-size: 48px; color: #ccc; margin-bottom: 15px; display: block;"></i>
                        <p style="font-weight: 800; font-size: 16px; margin-bottom: 10px;">Chưa có dữ liệu Vector</p>
                        @if (hasContent)
                        {
                            <p style="color: #777; font-size: 14px;">Nhấn nút "Thực hiện Băm & Nhúng Vector" ở trên để tạo.</p>
                        }
                        else
                        {
                            <p style="color: #777; font-size: 14px;">Cần có nội dung text trước khi tạo Vector.</p>
                        }
                    </div>
                }
            </div>
            } @* end @if (Model.CanViewChunks) *@

        </div>
    </div>
</div>

<!-- MODAL XÁC NHẬN RE-CHUNK -->
<div id="reprocessModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: var(--white); border: 4px solid var(--black); padding: 30px; box-shadow: 8px 8px 0px var(--black); width: 450px; max-width: 90%;">
        <h2 style="font-weight: 900; color: #b45309; margin-bottom: 10px; text-transform: uppercase;">
            <i class="fa-solid fa-rotate-right"></i> XÁC NHẬN XỬ LÝ LẠI
        </h2>
        <p style="font-weight: 700; color: #555; margin-bottom: 20px; font-size: 15px; line-height: 1.5;">
            Bạn có chắc muốn thực hiện băm và nhúng vector lại? Quá trình này sẽ <strong style="color: #dc2626;">xóa các chunk cũ</strong> và băm lại nội dung từ đầu.
        </p>

        <!-- THANH TIẾN ĐỘ -->
        <div id="reprocessProgressContainer" style="display: none; margin-bottom: 20px;">
            <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Tiến trình xử lý:</label>
            <div style="width: 100%; background-color: #eee; border: 3px solid var(--black); height: 25px; position: relative;">
                <div id="reprocessProgressBar" style="width: 0%; height: 100%; background-color: var(--yellow); transition: width 0.3s ease;"></div>
                <div id="reprocessProgressText" style="position: absolute; top: 0; left: 0; width: 100%; text-align: center; font-weight: 900; font-size: 12px; line-height: 19px; color: var(--black);">0%</div>
            </div>
            <p style="font-size: 11px; color: #888; margin-top: 5px; font-weight: 600; text-align: center;">Đang kết nối Gemini AI để tạo Vector...</p>
        </div>

        <div id="reprocessModalActions" style="display: flex; gap: 10px; justify-content: flex-end;">
            <button type="button" onclick="document.getElementById('reprocessModal').style.display='none'" class="brutal-btn" style="background: #ccc; border: 3px solid var(--black); padding: 8px 15px; font-weight: 900;">HỦY</button>
            <button type="button" onclick="startReprocess()" class="brutal-btn" style="background: var(--yellow); color: var(--black); border: 3px solid var(--black); padding: 8px 15px; font-weight: 900;">XÁC NHẬN</button>
        </div>
    </div>
</div>

<script>
    // Tự cuộn đến vị trí trích dẫn khi mở từ Chat AI (?chunk=N)
    window.addEventListener('DOMContentLoaded', function () {
        var mark = document.getElementById('chunkHighlight');
        if (mark) {
            setTimeout(function () { mark.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 150);
        }
    });

    function switchTab(tab) {
        var panelContent = document.getElementById('panel-content');
        var panelChunks = document.getElementById('panel-chunks');
        var tabContent = document.getElementById('tab-content');
        var tabChunks = document.getElementById('tab-chunks');

        if(tab === 'content') {
            if(panelContent) panelContent.style.display = 'block';
            if(panelChunks) panelChunks.style.display = 'none';
            if(tabContent) { tabContent.style.background = 'var(--black)'; tabContent.style.color = 'var(--white)'; }
            if(tabChunks) { tabChunks.style.background = 'var(--white)'; tabChunks.style.color = 'var(--black)'; }
        } else {
            if(panelContent) panelContent.style.display = 'none';
            if(panelChunks) panelChunks.style.display = 'block';
            if(tabChunks) { tabChunks.style.background = 'var(--black)'; tabChunks.style.color = 'var(--white)'; }
            if(tabContent) { tabContent.style.background = 'var(--white)'; tabContent.style.color = 'var(--black)'; }
        }
    }

    function startReprocess() {
        document.getElementById('reprocessModalActions').style.display = 'none';
        document.getElementById('reprocessProgressContainer').style.display = 'block';
        
        let progress = 0;
        const progressBar = document.getElementById('reprocessProgressBar');
        const progressText = document.getElementById('reprocessProgressText');
        
        // Mô phỏng tiến độ tăng dần
        const interval = setInterval(function() {
            if (progress < 95) {
                progress += Math.floor(Math.random() * 5) + 1; // Tăng 1-5%
                if (progress > 95) progress = 95;
                progressBar.style.width = progress + '%';
                progressText.innerText = progress + '%';
            }
        }, 500);

        // Submit form
        document.getElementById('reprocessForm').submit();
    }
</script>

@if (isPdfView)
{
    <style>
        #pdfPages .pdf-page { position: relative; margin: 0 auto 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.4); background: #fff; }
        #pdfPages .pdf-page:last-child { margin-bottom: 0; }
        #pdfPages canvas { display: block; }
        .pdf-hl-layer { position: absolute; top: 0; left: 0; pointer-events: none; }
        .pdf-hl-box { position: absolute; background: rgba(253,224,71,0.45); outline: 2px solid #f59e0b; border-radius: 2px; mix-blend-mode: multiply; }
    </style>
    <script src="/lib/pdfjs/pdf.min.js"></script>
    <script>
        window.__pdfHighlightText = @Json.Serialize(Model.HighlightChunkText ?? "");
        (function () {
            var viewerEl = document.getElementById('pdfViewer');
            if (!viewerEl) return;
            var url = viewerEl.getAttribute('data-pdf-url');
            var pagesEl = document.getElementById('pdfPages');
            var statusEl = document.getElementById('pdfStatus');
            var bannerEl = document.getElementById('pdfHlBanner');

            if (typeof pdfjsLib === 'undefined') {
                if (statusEl) statusEl.innerHTML = 'Không tải được thư viện xem PDF.';
                return;
            }
            pdfjsLib.GlobalWorkerOptions.workerSrc = '/lib/pdfjs/pdf.worker.min.js';

            // Chuẩn hoá mạnh để so khớp giữa 2 bộ trích xuất text khác nhau (PdfPig vs PDF.js):
            // CHỈ GIỮ LẠI CHỮ VÀ SỐ, BỎ QUA MỌI DẤU CÁCH VÀ KÝ TỰ ĐẶC BIỆT.
            // Quan trọng: bỏ luôn dấu tiếng Việt — hai bộ trích xuất có thể trả NFC ("ế")
            // hoặc NFD ("e" + dấu tổ hợp), nếu không sẽ lệch ở mọi từ có dấu.
            function norm(s) {
                return (s || '')
                    .normalize('NFD')
                    .replace(/\p{M}+/gu, '')    // bỏ dấu tổ hợp
                    .toLowerCase()
                    .replace(/đ/g, 'd')                 // đ không tách được bằng NFD
                    .replace(/[^\p{L}\p{N}]+/gu, '');
            }

            var targetNorm = norm(window.__pdfHighlightText);
            var wantHighlight = targetNorm.length >= 12;
            var firstHighlightEl = null;
            var pageRefs = [];   // {viewport, hlLayer} theo thứ tự trang
            var globalText = ''; // text đã chuẩn hoá của TOÀN BỘ tài liệu
            var globalMap = [];  // {start, end, item, pageIdx}

            pdfjsLib.getDocument(url).promise.then(function (pdf) {
                if (statusEl) statusEl.style.display = 'none';
                var chain = Promise.resolve();
                for (var p = 1; p <= pdf.numPages; p++) {
                    (function (pageNum) {
                        chain = chain.then(function () { return renderPage(pdf, pageNum); });
                    })(p);
                }
                return chain;
            }).then(function () {
                if (wantHighlight) locateAndHighlight();
                if (firstHighlightEl) {
                    firstHighlightEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else if (wantHighlight && bannerEl) {
                    bannerEl.style.background = '#fee2e2';
                    bannerEl.innerHTML = '<i class="fa-solid fa-triangle-exclamation" style="color:#dc2626;"></i> '
                        + 'Không định vị được chính xác đoạn trích dẫn trên bản tài liệu. Bạn vẫn có thể đọc toàn bộ nội dung bên dưới.';
                }
            }).catch(function (err) {
                if (statusEl) { statusEl.style.display = 'block'; statusEl.innerHTML = 'Không tải được bản xem PDF: ' + (err && err.message ? err.message : err); }
            });

            function renderPage(pdf, pageNum) {
                return pdf.getPage(pageNum).then(function (page) {
                    var scale = 1.5;
                    var viewport = page.getViewport({ scale: scale });

                    var pageContainer = document.createElement('div');
                    pageContainer.className = 'pdf-page';
                    pageContainer.style.width = viewport.width + 'px';
                    pageContainer.style.height = viewport.height + 'px';

                    var canvas = document.createElement('canvas');
                    canvas.width = viewport.width;
                    canvas.height = viewport.height;
                    pageContainer.appendChild(canvas);

                    var hlLayer = document.createElement('div');
                    hlLayer.className = 'pdf-hl-layer';
                    hlLayer.style.width = viewport.width + 'px';
                    hlLayer.style.height = viewport.height + 'px';
                    pageContainer.appendChild(hlLayer);

                    pagesEl.appendChild(pageContainer);

                    var pageIdx = pageRefs.length;
                    pageRefs.push({ viewport: viewport, hlLayer: hlLayer });

                    var renderTask = page.render({ canvasContext: canvas.getContext('2d'), viewport: viewport });
                    return renderTask.promise.then(function () {
                        if (!wantHighlight) return;
                        // Gom text của MỌI trang vào một chuỗi chung: chunk có thể nằm vắt qua
                        // ranh giới trang, khớp riêng từng trang sẽ không bao giờ tìm thấy.
                        return page.getTextContent().then(function (tc) {
                            collectPageText(tc, pageIdx);
                        });
                    });
                });
            }

            function collectPageText(textContent, pageIdx) {
                var items = textContent.items;
                for (var i = 0; i < items.length; i++) {
                    var t = norm(items[i].str);
                    if (!t) continue;
                    var start = globalText.length;
                    globalText += t;
                    globalMap.push({ start: start, end: globalText.length, item: items[i], pageIdx: pageIdx });
                }
            }

            /// Tìm chunk trong text toàn tài liệu rồi tô vàng.
            /// Thử nhiều độ dài cửa sổ, và với mỗi độ dài thì trượt vị trí bắt đầu dọc chunk —
            /// PDF.js có thể đảo thứ tự đọc ở đầu chunk (header/footer, 2 cột, bảng) khiến
            /// cách khớp prefix cũ hỏng dù phần giữa chunk vẫn khớp được.
            function locateAndHighlight() {
                var lengths = [targetNorm.length, 300, 200, 120, 80, 50, 30];
                for (var li = 0; li < lengths.length; li++) {
                    var len = Math.min(lengths[li], targetNorm.length);
                    if (len < 20) continue;
                    var step = Math.max(1, Math.floor(len / 2));
                    for (var s = 0; s + len <= targetNorm.length; s += step) {
                        var idx = globalText.indexOf(targetNorm.substr(s, len));
                        if (idx < 0) continue;
                        // Nới highlight ra cả chunk, không chỉ phần cửa sổ khớp được.
                        markRange(Math.max(0, idx - s), Math.min(globalText.length, idx - s + targetNorm.length));
                        return;
                    }
                }
            }

            function markRange(mStart, mEnd) {
                for (var k = 0; k < globalMap.length; k++) {
                    var m = globalMap[k];
                    if (m.end <= mStart || m.start >= mEnd) continue; // không giao nhau
                    var ref = pageRefs[m.pageIdx];
                    if (ref) drawBox(m.item, ref.viewport, ref.hlLayer);
                }
            }

            function drawBox(item, viewport, hlLayer) {
                var tx = pdfjsLib.Util.transform(viewport.transform, item.transform);
                var fontHeight = Math.hypot(tx[2], tx[3]) || Math.abs(tx[3]) || 10;
                var left = tx[4];
                var top = tx[5] - fontHeight;
                var width = (item.width || 0) * viewport.scale;
                if (width <= 0) return;

                var box = document.createElement('div');
                box.className = 'pdf-hl-box';
                box.style.left = left + 'px';
                box.style.top = top + 'px';
                box.style.width = width + 'px';
                box.style.height = (fontHeight * 1.15) + 'px';
                hlLayer.appendChild(box);
                if (!firstHighlightEl) firstHighlightEl = box;
            }
        })();
    </script>
}
