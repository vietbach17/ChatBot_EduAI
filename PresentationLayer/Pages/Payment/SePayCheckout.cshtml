@page
@model PresentationLayer.Pages.Payment.SePayCheckoutModel
@{
    ViewData["Title"] = "Thanh toán qua chuyển khoản";
    Layout = "_Layout";
}

<style>
    .checkout-container {
        padding: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
    }
    .brutal-card {
        background: var(--white);
        border: var(--border);
        box-shadow: 8px 8px 0px 0px var(--black);
        width: 100%;
        max-width: 500px;
        display: flex;
        flex-direction: column;
    }
    .brutal-header {
        background: var(--pink);
        color: var(--white);
        padding: 20px;
        text-align: center;
        border-bottom: var(--border);
        font-weight: 900;
        font-size: 22px;
        text-transform: uppercase;
    }
    .brutal-body {
        padding: 30px;
        text-align: center;
    }
    .qr-wrapper {
        display: inline-block;
        padding: 15px;
        background: var(--white);
        border: var(--border);
        box-shadow: var(--shadow);
        margin-bottom: 25px;
    }
    .qr-wrapper img {
        display: block;
        width: 250px;
        height: 250px;
        object-fit: contain;
    }
    .info-box {
        background: var(--bg);
        border: var(--border);
        padding: 15px;
        text-align: left;
        margin-bottom: 25px;
    }
    .info-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-weight: 800;
        font-size: 15px;
    }
    .info-row:last-child {
        margin-bottom: 0;
    }
    .info-label {
        color: #555;
    }
    .info-value {
        color: var(--black);
    }
    .warning-box {
        background: var(--yellow);
        border: var(--border);
        padding: 15px;
        font-weight: 800;
        font-size: 14px;
        margin-bottom: 25px;
        display: flex;
        gap: 10px;
        align-items: center;
        text-align: left;
    }
    .actions {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    .btn-action {
        text-decoration: none;
        padding: 15px;
        font-weight: 900;
        text-transform: uppercase;
        border: var(--border);
        box-shadow: var(--shadow);
        transition: 0.1s;
        text-align: center;
        display: block;
    }
    .btn-action.primary {
        background: var(--blue);
        color: var(--white);
    }
    .btn-action.secondary {
        background: #ccc;
        color: var(--black);
    }
    .btn-action:active {
        transform: translate(4px, 4px);
        box-shadow: 0 0 0 0 var(--black);
    }
</style>

<div class="checkout-container">
    <div class="brutal-card">
        <div class="brutal-header">
            <i class="fa-solid fa-qrcode"></i> Thanh toán VietQR
        </div>
        <div class="brutal-body">
            <p style="font-weight: 800; margin-bottom: 20px;">Mở ứng dụng ngân hàng và quét mã bên dưới</p>
            
            <div class="qr-wrapper">
                <img src="@Model.QrCodeUrl" alt="VietQR Code" />
            </div>

            <div class="info-box">
                <div class="info-row">
                    <span class="info-label">Ngân hàng:</span>
                    <span class="info-value">@Model.BankId</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Số tài khoản:</span>
                    <span class="info-value" style="color: var(--blue);">@Model.AccountNo</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Số tiền:</span>
                    <span class="info-value" style="color: var(--pink);">@String.Format("{0:N0} VNĐ", double.Parse(Model.Amount))</span>
                </div>
                <div class="info-row" style="border-top: 2px dashed var(--black); padding-top: 10px; margin-top: 10px;">
                    <span class="info-label">Nội dung CK:</span>
                    <span class="info-value" style="color: var(--green); font-size: 18px;">@Model.Content</span>
                </div>
            </div>

            <div class="warning-box">
                <i class="fa-solid fa-triangle-exclamation" style="font-size: 24px;"></i>
                <span>Vui lòng giữ nguyên nội dung chuyển khoản <strong>@Model.Content</strong> để hệ thống duyệt tự động.</span>
            </div>

            <div class="actions">
                <a href="@Model.ReturnUrl" class="btn-action primary">Tôi đã chuyển khoản xong</a>
                <a href="/Subscription/Index" class="btn-action secondary">Hủy giao dịch</a>
            </div>
        </div>
    </div>
</div>
