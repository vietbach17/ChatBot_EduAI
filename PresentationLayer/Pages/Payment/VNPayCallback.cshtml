@page
@model PresentationLayer.Pages.Payment.VNPayCallbackModel
@{
    ViewData["Title"] = "Kết quả thanh toán";
    ViewBag.ActiveMenu = "Subscription";
}

@section Styles {
<style>
    .result-card {
        background: var(--white);
        border: 3px solid var(--black);
        box-shadow: 6px 6px 0px var(--black);
        padding: 30px;
        max-width: 600px;
        margin: 40px auto;
        text-align: center;
    }
    .result-icon {
        font-size: 64px;
        margin-bottom: 20px;
    }
    .result-icon.success {
        color: var(--green);
    }
    .result-icon.failed {
        color: var(--pink);
    }
    .back-btn {
        display: inline-block;
        background-color: var(--blue);
        color: var(--white);
        padding: 12px 24px;
        font-size: 15px;
        font-weight: 800;
        border: 3px solid var(--black);
        box-shadow: 3px 3px 0px var(--black);
        cursor: pointer;
        text-decoration: none;
        text-transform: uppercase;
        margin-top: 25px;
        transition: transform 0.1s, box-shadow 0.1s;
    }
    .back-btn:active {
        transform: translate(3px, 3px);
        box-shadow: 0px 0px 0px var(--black);
    }
</style>
}

<div class="main-wrapper">
    <div class="result-card">
        @if (Model.IsSuccess)
        {
            <div class="result-icon success">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <h2 style="font-weight: 900; font-size: 26px; text-transform: uppercase; margin-bottom: 10px; color: var(--green);">
                Thanh toán thành công!
            </h2>
        }
        else
        {
            <div class="result-icon failed">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <h2 style="font-weight: 900; font-size: 26px; text-transform: uppercase; margin-bottom: 10px; color: var(--pink);">
                Thanh toán thất bại
            </h2>
        }

        <p style="font-size: 15px; font-weight: 700; color: #555; margin-bottom: 25px; padding: 0 10px;">
            @Model.Message
        </p>

        @if (Model.Transaction != null)
        {
            <div style="background: #f8fafc; border: 2px dashed #cbd5e1; padding: 18px; text-align: left; font-weight: 700; font-size: 14px; display: inline-block; width: 100%;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span>Mã hóa đơn:</span>
                    <span style="font-family: monospace; color: #334155;">#@Model.Transaction.Id</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Transaction.TransactionCode))
                {
                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                        <span>Mã giao dịch VNPay:</span>
                        <span style="font-family: monospace; color: #334155;">@Model.Transaction.TransactionCode</span>
                    </div>
                }
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span>Gói đã mua:</span>
                    <span style="color: var(--blue);">@Model.Transaction.PlanName?.ToUpper()</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span>Số tiền:</span>
                    <span style="color: var(--pink);">@Model.Transaction.Amount.ToString("N0") đ</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Phương thức:</span>
                    <span>@Model.Transaction.PaymentMethod</span>
                </div>
            </div>
        }

        <div>
            <a href="/" class="back-btn">
                <i class="fa-solid fa-house"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>
