@page
@model PresentationLayer.Pages.Payment.CallbackModel
@{
    ViewData["Title"] = "Kết Quả Thanh Toán";
}

<div class="main-wrapper" style="padding: 40px;">
    <div style="max-width: 600px; margin: 0 auto; background: var(--white); border: 3px solid var(--black); box-shadow: 6px 6px 0px var(--black); padding: 30px; text-align: center;">
        
        @if (Model.IsSuccess)
        {
            <div style="font-size: 48px; color: var(--green); margin-bottom: 20px;">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <h1 style="font-weight: 900; margin-bottom: 10px;">Thanh Toán Thành Công!</h1>
            <p style="font-size: 16px; font-weight: 700; color: #555; margin-bottom: 30px;">@Model.Message</p>
            <a href="/Subscription/Index" class="btn-primary" style="display: inline-block; padding: 12px 24px; font-weight: 900; text-decoration: none; border: 3px solid var(--black); box-shadow: 3px 3px 0px var(--black); background: var(--pink); color: var(--white);">QUAY VỀ TRANG HỘI VIÊN</a>
        }
        else
        {
            <div style="font-size: 48px; color: var(--pink); margin-bottom: 20px;">
                <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <h1 style="font-weight: 900; margin-bottom: 10px;">Thanh Toán Thất Bại!</h1>
            <p style="font-size: 16px; font-weight: 700; color: #555; margin-bottom: 30px;">@Model.Message</p>
            <a href="/Subscription/Index" class="btn-primary" style="display: inline-block; padding: 12px 24px; font-weight: 900; text-decoration: none; border: 3px solid var(--black); box-shadow: 3px 3px 0px var(--black); background: #eee; color: var(--black);">QUAY LẠI</a>
        }
    </div>
</div>
