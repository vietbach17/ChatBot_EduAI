<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - EduManager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;800;900&display=swap');
        
        :root {
            --pink: #eb2f64; --yellow: #f4cf45; --green: #5cb85c; 
            --blue: #4fa8db; --black: #000; --white: #fff; --bg: #f4f4f6;
            --border: 3px solid var(--black);
            --shadow: 4px 4px 0px 0px var(--black);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Montserrat', sans-serif; }
        
        body {
            background-color: var(--bg);
            display: flex; height: 100vh; color: var(--black);
            background-image: radial-gradient(#d1d1d1 2px, transparent 2px);
            overflow: hidden;
        }

        .sidebar {
            width: 260px; background: var(--white); border-right: var(--border);
            padding: 30px 20px; display: flex; flex-direction: column; gap: 15px;
            height: 100vh; flex-shrink: 0;
        }
        .logo { color: var(--pink); font-size: 22px; font-weight: 900; margin-bottom: 20px; }
        .nav-item {
            padding: 12px 15px; font-weight: 800; color: var(--black);
            text-decoration: none; display: flex; align-items: center; gap: 12px;
            border: 3px solid transparent; transition: 0.1s;
        }
        .nav-item.active {
            background: var(--pink); color: var(--white);
            border-color: var(--black); box-shadow: var(--shadow);
        }
        .nav-item:not(.active):hover { border-color: var(--black); transform: translate(-2px, -2px); box-shadow: var(--shadow); }

        .user-profile {
            margin-top: auto; 
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px;
            background-color: var(--white);
            border: 3px solid var(--black);
            box-shadow: 4px 4px 0px 0px var(--black);
        }
        .avatar-box {
            width: 36px;
            height: 36px;
            background-color: var(--pink); 
            border: 2px solid var(--black);
            display: flex; align-items: center; justify-content: center;
            color: var(--white); font-size: 14px; flex-shrink: 0;
        }
        .user-info { display: flex; flex-direction: column; overflow: hidden; }
        .user-info .username { font-weight: 800; font-size: 12px; color: var(--black); white-space: nowrap; text-overflow: ellipsis; overflow: hidden; }
        .user-info .role { font-weight: 700; font-size: 10px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }

        .brutal-btn { transition: 0.1s; cursor: pointer; display: inline-block; }
        .brutal-btn:active { transform: translate(2px, 2px); box-shadow: 0 0 0 0 var(--black) !important; }
        
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    
    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
        @{
            var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
        }

        <div class="logo"><i class="fa-solid fa-graduation-cap"></i> EduManager</div>

        @if (userRole == "Admin")
        {
            <div style="margin-top: 5px; margin-bottom: 5px; font-size: 11px; font-weight: 900; color: #999; letter-spacing: 1px;">QUáº¢N TRá»Š VIÃŠN</div>
            <a asp-page="/Auth/Profile" class="nav-item active"><i class="fa-solid fa-user"></i> Há»’ SÆ </a>
        }
        else if (userRole == "Lecturer")
        {
            <div style="margin-top: 5px; margin-bottom: 5px; font-size: 11px; font-weight: 900; color: #999; letter-spacing: 1px;">GIáº¢NG VIÃŠN</div>
            <a asp-page="/Auth/Profile" class="nav-item active"><i class="fa-solid fa-user"></i> Há»’ SÆ </a>
        }
        else
        {
            <div style="margin-top: 5px; margin-bottom: 5px; font-size: 11px; font-weight: 900; color: #999; letter-spacing: 1px;">SINH VIÃŠN</div>
            <a asp-page="/Auth/Profile" class="nav-item active"><i class="fa-solid fa-user"></i> Há»’ SÆ </a>
        }
        
        <a asp-page="/Auth/Profile" class="user-profile" style="text-decoration: none; cursor: pointer; transition: 0.1s;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="avatar-box">
                    <i class="fa-solid fa-user"></i> 
                </div>
                <div class="user-info">
                    <div class="username">@User.Identity.Name</div>
                    <div class="role">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
            }
        </a>
        <a asp-page="/Auth/Logout" class="nav-item" style="border:dashed 2px var(--black);">ÄÄƒng xuáº¥t</a>      
    </div>

    <!-- MAIN CONTENT -->
    @RenderBody()

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
