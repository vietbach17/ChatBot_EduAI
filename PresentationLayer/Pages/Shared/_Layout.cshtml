<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - EduManager</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@500;700;800;900&display=swap');
        
        :root {
            --pink: #eb2f64; --yellow: #f4cf45; --green: #5cb85c; 
            --blue: #4fa8db; --black: #000; --white: #fff; --bg: #f4f4f6;
            --border: 3px solid var(--black);
            --shadow: 4px 4px 0px 0px var(--black);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Be Vietnam Pro', sans-serif; }
        
        body {
            background-color: var(--bg);
            display: flex; height: 100vh; color: var(--black);
            background-image: radial-gradient(#d1d1d1 2px, transparent 2px);
            overflow: hidden;
        }

        .sidebar {
            width: 280px; background: var(--white); border-right: var(--border);
            padding: 30px 20px; display: flex; flex-direction: column; gap: 15px;
            height: 100vh; flex-shrink: 0;
        }
        .logo { color: var(--pink); font-size: 22px; font-weight: 900; margin-bottom: 20px; }
        .nav-item {
            padding: 12px 15px; font-weight: 800; color: var(--black); font-size: 14px;
            text-decoration: none; display: flex; align-items: center; gap: 12px;
            border: 3px solid transparent; transition: 0.1s;
        }
        .nav-item.active {
            background: var(--pink); color: var(--white);
            border-color: var(--black); box-shadow: var(--shadow);
        }
        .nav-item:not(.active):hover { border-color: var(--black); transform: translate(-2px, -2px); box-shadow: var(--shadow); }

        .user-profile {
            margin-top: auto; 
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px;
            background-color: var(--white);
            border: 3px solid var(--black);
            box-shadow: 4px 4px 0px 0px var(--black);
        }
        .avatar-box {
            width: 36px;
            height: 36px;
            background-color: var(--pink); 
            border: 2px solid var(--black);
            display: flex; align-items: center; justify-content: center;
            color: var(--white); font-size: 14px; flex-shrink: 0;
        }
        .user-info { display: flex; flex-direction: column; overflow: hidden; }
        .user-info .username { font-weight: 800; font-size: 12px; color: var(--black); white-space: nowrap; text-overflow: ellipsis; overflow: hidden; }
        .user-info .role { font-weight: 700; font-size: 10px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }

        .brutal-btn { transition: 0.1s; cursor: pointer; display: inline-block; }
        .brutal-btn:active { transform: translate(2px, 2px); box-shadow: 0 0 0 0 var(--black) !important; }
        
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    
    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
        @{
            var userRole = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
            var activePage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        }

        <div class="logo"><i class="fa-solid fa-graduation-cap"></i> EduManager</div>

        @if (userRole == "Admin")
        {
            <div style="margin-top: 5px; margin-bottom: 5px; font-size: 11px; font-weight: 900; color: #999; letter-spacing: 1px;">QUẢN TRỊ VIÊN</div>
            <a asp-page="/Admin/Dashboard" class="nav-item @(ViewBag.ActiveMenu == "AdminDashboard" ? "active" : "")"><i class="fa-solid fa-chart-pie"></i> DASHBOARD</a>
            <a asp-page="/Admin/Users" class="nav-item @(ViewBag.ActiveMenu == "AdminUsers" ? "active" : "")"><i class="fa-solid fa-users-gear"></i> QL NGƯỜI DÙNG</a>
            <a asp-page="/Admin/Subjects" class="nav-item @(ViewBag.ActiveMenu == "AdminSubjects" ? "active" : "")"><i class="fa-solid fa-book-open-reader"></i> QL MÔN HỌC</a>
            <a asp-page="/Admin/Subscriptions" class="nav-item @(ViewBag.ActiveMenu == "AdminSubscriptions" ? "active" : "")"><i class="fa-solid fa-users"></i> QL NGƯỜI ĐĂNG KÝ</a>
            <a asp-page="/Admin/Plans" class="nav-item @(ViewBag.ActiveMenu == "AdminPlans" ? "active" : "")"><i class="fa-solid fa-tags"></i> QL LOẠI GÓI</a>
            <a asp-page="/Admin/PaymentHistory" class="nav-item @(ViewBag.ActiveMenu == "PaymentHistory" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i> LỊCH SỬ TT</a>
            <a asp-page="/Admin/QuestionBanks" class="nav-item @(ViewBag.ActiveMenu == "QuestionBanks" ? "active" : "")"><i class="fa-solid fa-clock-rotate-left"></i> LỊCH SỬ CÂU HỎI</a>
            <a asp-page="/Admin/Reports" class="nav-item @(ViewBag.ActiveMenu == "AdminReports" ? "active" : "")"><i class="fa-solid fa-flag"></i> QL BÁO CÁO</a>
        }
        else if (userRole == "Lecturer")
        {
            <div style="margin-top: 5px; margin-bottom: 5px; font-size: 11px; font-weight: 900; color: #999; letter-spacing: 1px;">GIẢNG VIÊN</div>
            <a asp-page="/Lecturer/MySubjects" class="nav-item @(ViewBag.ActiveMenu == "LecturerSubjects" ? "active" : "")"><i class="fa-solid fa-chalkboard-user"></i> MÔN PHỤ TRÁCH</a>
            <a asp-page="/Lecturer/AllSubjects" class="nav-item @(ViewBag.ActiveMenu == "LecturerAllSubjects" ? "active" : "")"><i class="fa-solid fa-book-open"></i> TẤT CẢ MÔN HỌC</a>
            <a asp-page="/Lecturer/MyDocuments" class="nav-item @(ViewBag.ActiveMenu == "LecturerDocuments" ? "active" : "")"><i class="fa-regular fa-file-lines"></i> TÀI LIỆU CỦA TÔI</a>
            <a asp-page="/Lecturer/QuestionBank" class="nav-item @(ViewBag.ActiveMenu == "QuestionBank" ? "active" : "")"><i class="fa-solid fa-database"></i> NGÂN HÀNG CÂU HỎI</a>
            <a asp-page="/Lecturer/AIGenerateQuestions" class="nav-item @(ViewBag.ActiveMenu == "AIGenerateQuestions" ? "active" : "")"><i class="fa-solid fa-robot"></i> AI TẠO CÂU HỎI</a>
            <a asp-page="/Report/MyReports" class="nav-item @(ViewBag.ActiveMenu == "Reports" ? "active" : "")"><i class="fa-solid fa-headset"></i> BÁO CÁO & HỖ TRỢ</a>

        }
        else
        {
            <div style="margin-top: 5px; margin-bottom: 5px; font-size: 11px; font-weight: 900; color: #999; letter-spacing: 1px;">SINH VIÊN</div>
            <a asp-page="/Index" class="nav-item @(ViewBag.ActiveMenu == "Overview" ? "active" : "")"><i class="fa-solid fa-border-all"></i> TỔNG QUAN</a>
            <a asp-page="/StudentDocument/Subjects" class="nav-item @(ViewBag.ActiveMenu == "Subjects" ? "active" : "")"><i class="fa-solid fa-book-open"></i> MÔN HỌC</a>
            <a asp-page="/StudentDocument/Documents"  class="nav-item @(ViewBag.ActiveMenu == "Docs" ? "active" : "")"><i class="fa-regular fa-file-lines"></i> TÀI LIỆU</a>
            <a asp-page="/Student/QuizList" class="nav-item @(ViewBag.ActiveMenu == "StudentQuizzes" ? "active" : "")"><i class="fa-solid fa-file-signature"></i> BÀI THI</a>
            <a asp-page="/Chat/Index"  class="nav-item @(ViewBag.ActiveMenu == "AI" ? "active" : "")"><i class="fa-solid fa-robot"></i> CHAT AI</a>
            <a asp-page="/Subscription/Index" class="nav-item @(ViewBag.ActiveMenu == "Subscription" ? "active" : "")"><i class="fa-solid fa-crown"></i> GÓI HỘI VIÊN</a>
            <a asp-page="/PaymentHistory/Index" class="nav-item @(ViewBag.ActiveMenu == "PaymentHistory" ? "active" : "")"><i class="fa-solid fa-file-invoice-dollar"></i> LỊCH SỬ TT</a>
            <a asp-page="/Report/MyReports" class="nav-item @(ViewBag.ActiveMenu == "Reports" ? "active" : "")"><i class="fa-solid fa-headset"></i> BÁO CÁO & HỖ TRỢ</a>
        }
        
        <a asp-page="/Auth/Profile" class="user-profile" style="text-decoration: none; cursor: pointer; transition: 0.1s;">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="avatar-box">
                    <i class="fa-solid fa-user"></i> 
                </div>
                <div class="user-info">
                    <div class="username">@User.Identity.Name</div>
                    <div class="role">@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
            }
        </a>
        <a asp-page="/Auth/Logout" class="nav-item" style="border:dashed 2px var(--black); text-align: center;">Đăng xuất</a>      
    </div>

    <!-- MAIN CONTENT -->
    @RenderBody()

    <!-- GLOBAL BRUTAL CONFIRM MODAL -->
    <div id="brutalConfirmModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); z-index: 99999; justify-content: center; align-items: center; backdrop-filter: blur(2px);">
        <div style="background: var(--white); border: 4px solid var(--black); box-shadow: 8px 8px 0px var(--black); width: 400px; max-width: 90%; text-align: center; display: flex; flex-direction: column;">
            <div style="background: var(--yellow); padding: 15px; border-bottom: 4px solid var(--black);">
                <h3 style="margin: 0; font-weight: 900; font-size: 20px; text-transform: uppercase; color: var(--black);">
                    <i class="fa-solid fa-triangle-exclamation"></i> XÁC NHẬN
                </h3>
            </div>
            <div style="padding: 30px 20px;">
                <p id="brutalConfirmMessage" style="font-weight: 800; font-size: 16px; color: var(--black); margin: 0; line-height: 1.5;"></p>
            </div>
            <div style="padding: 20px; border-top: 4px solid var(--black); background: var(--bg); display: flex; justify-content: center; gap: 15px;">
                <button type="button" onclick="__brutalConfirmNo()" class="brutal-btn" style="background: #ccc; color: var(--black); border: 2px solid var(--black); padding: 10px 20px; font-weight: 900; box-shadow: 2px 2px 0px var(--black); cursor: pointer;">HỦY BỎ</button>
                <button type="button" onclick="__brutalConfirmYes()" class="brutal-btn" style="background: var(--pink); color: var(--white); border: 2px solid var(--black); padding: 10px 20px; font-weight: 900; box-shadow: 2px 2px 0px var(--black); cursor: pointer;">XÁC NHẬN</button>
            </div>
        </div>
    </div>

    <!-- GLOBAL BRUTAL ALERT MODAL -->
    <div id="brutalAlertModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); z-index: 99999; justify-content: center; align-items: center; backdrop-filter: blur(2px);">
        <div style="background: var(--white); border: 4px solid var(--black); box-shadow: 8px 8px 0px var(--black); width: 400px; max-width: 90%; text-align: center; display: flex; flex-direction: column;">
            <div style="background: var(--pink); padding: 15px; border-bottom: 4px solid var(--black);">
                <h3 style="margin: 0; font-weight: 900; font-size: 20px; text-transform: uppercase; color: var(--white);">
                    <i class="fa-solid fa-circle-info"></i> THÔNG BÁO
                </h3>
            </div>
            <div style="padding: 30px 20px;">
                <p id="brutalAlertMessage" style="font-weight: 800; font-size: 16px; color: var(--black); margin: 0; line-height: 1.5;"></p>
            </div>
            <div style="padding: 20px; border-top: 4px solid var(--black); background: var(--bg); display: flex; justify-content: center;">
                <button type="button" onclick="document.getElementById('brutalAlertModal').style.display='none'" class="brutal-btn" style="background: var(--black); color: var(--white); border: 2px solid var(--black); padding: 10px 30px; font-weight: 900; box-shadow: 2px 2px 0px var(--pink); cursor: pointer;">ĐÓNG</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        // Global Brutal Confirm Logic
        window.__brutalConfirmCallback = null;
        function brutalConfirm(message, callback) {
            document.getElementById('brutalConfirmMessage').innerText = message;
            document.getElementById('brutalConfirmModal').style.display = 'flex';
            window.__brutalConfirmCallback = callback;
        }
        function __brutalConfirmYes() {
            document.getElementById('brutalConfirmModal').style.display = 'none';
            if (window.__brutalConfirmCallback) {
                window.__brutalConfirmCallback();
                window.__brutalConfirmCallback = null;
            }
        }
        function __brutalConfirmNo() {
            document.getElementById('brutalConfirmModal').style.display = 'none';
            window.__brutalConfirmCallback = null;
        }

        // Global Brutal Alert Logic
        function brutalAlert(message) {
            document.getElementById('brutalAlertMessage').innerText = message;
            document.getElementById('brutalAlertModal').style.display = 'flex';
        }

        // Intercept all forms with data-confirm
        document.addEventListener('submit', function(e) {
            const form = e.target;
            const msg = form.getAttribute('data-confirm');
            if (msg) {
                e.preventDefault();
                brutalConfirm(msg, function() {
                    form.removeAttribute('data-confirm');
                    form.submit();
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
