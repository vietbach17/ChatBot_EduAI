@page "{id:int}"
@model PresentationLayer.Pages.Lecturer.ManageSubjectModel
@{
    ViewData["Title"] = "Quản lý môn học " + Model.Subject?.Code;
    ViewBag.ActiveMenu = "LecturerSubjects";
    // Helper: chuyển UTC → Giờ Việt Nam (UTC+7)
    var vnZone = TimeZoneInfo.FindSystemTimeZoneById(
        System.Runtime.InteropServices.RuntimeInformation.IsOSPlatform(System.Runtime.InteropServices.OSPlatform.Windows)
            ? "SE Asia Standard Time" : "Asia/Ho_Chi_Minh");
    string ToVnTime(DateTime utc) => TimeZoneInfo.ConvertTimeFromUtc(utc, vnZone).ToString("dd/MM/yyyy HH:mm");
}

<div class="main-wrapper">
    <div style="padding: 30px;">
        <div style="margin-bottom: 20px;">
            @if (Model.IsAdmin)
            {
                <a asp-page="/Admin/Subjects" style="color: var(--black); text-decoration: none; font-weight: 800; font-size: 14px;">
                    <i class="fa-solid fa-arrow-left"></i> QUAY LẠI QUẢN LÝ MÔN HỌC
                </a>
            }
            else
            {
                <a asp-page="/Lecturer/MySubjects" style="color: var(--black); text-decoration: none; font-weight: 800; font-size: 14px;">
                    <i class="fa-solid fa-arrow-left"></i> QUAY LẠI MÔN PHỤ TRÁCH
                </a>
            }
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
            <h1 style="color: var(--blue); font-weight: 900; font-size: 28px; text-transform: uppercase;">
                [@Model.Subject.Code] @Model.Subject.Name
            </h1>

            @if(Model.IsOwner || Model.IsAdmin)
            {
                <div style="display: flex; gap: 10px;">
                    <button type="button" onclick="document.getElementById('activityLogModal').style.display='flex'" class="brutal-btn" style="background-color: #fff; color: var(--black); border: 2px solid var(--black); padding: 8px 15px; font-weight: 900; box-shadow: 2px 2px 0px var(--black);">
                        <i class="fa-solid fa-clock-rotate-left"></i> LỊCH SỬ
                    </button>
                    @if (Model.IsOwner)
                    {
                        <a asp-page="/Lecturer/CreateQuiz" asp-route-subjectId="@Model.Subject.Id" class="brutal-btn" style="background-color: var(--pink); color: var(--white); border: 2px solid var(--black); padding: 8px 15px; font-weight: 900; box-shadow: 2px 2px 0px var(--black); text-decoration: none; display: inline-flex; align-items: center; gap: 5px;">
                            <i class="fa-solid fa-file-signature"></i> TẠO BÀI THI
                        </a>
                        <button type="button" onclick="openChapterModal(0, '')" class="brutal-btn" style="background-color: var(--green); color: var(--black); border: 2px solid var(--black); padding: 8px 15px; font-weight: 900; box-shadow: 2px 2px 0px var(--black);">
                            <i class="fa-solid fa-plus"></i> THÊM CHƯƠNG
                        </button>
                        <button type="button" onclick="openUploadModal()" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 2px solid var(--black); padding: 8px 15px; font-weight: 900; box-shadow: 2px 2px 0px var(--black);">
                            <i class="fa-solid fa-upload"></i> TẢI TÀI LIỆU
                        </button>
                    }
                </div>
            }
        </div>
        <p style="font-weight: 700; color: #555; margin-bottom: 30px;">Quản lý cấu trúc chương học và tài liệu</p>

        <div id="manage-subject-container">
            <!-- Danh sách bài thi (Quizzes) -->
            @if (Model.Quizzes != null && Model.Quizzes.Any())
            {
                <div style="background-color: var(--white); border: var(--border); box-shadow: 4px 4px 0px var(--black); padding: 20px; margin-bottom: 20px;">
                    <h2 style="font-weight: 900; font-size: 18px; color: var(--pink); border-bottom: 2px dashed #ccc; padding-bottom: 10px; margin-bottom: 15px;">DANH SÁCH BÀI THI</h2>
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        @foreach (var quiz in Model.Quizzes)
                        {
                            <div style="background-color: var(--bg); border: 2px solid var(--black); padding: 10px 15px; display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <div style="font-weight: 800; font-size: 15px; margin-bottom: 5px;">@quiz.Title</div>
                                    <div style="font-size: 12px; color: #555;">
                                        Thời gian: <strong>@quiz.TimeLimitMinutes phút</strong> | Số lượng mã đề: <strong>@quiz.NumVariants</strong> | Tạo ngày: <strong>@quiz.CreatedAt.ToString("dd/MM/yyyy")</strong>
                                    </div>
                                </div>
                                <div>
                                    <a href="/Lecturer/QuizResults?QuizId=@quiz.Id" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 2px solid var(--black); padding: 5px 10px; font-weight: 900; box-shadow: 2px 2px 0px var(--black); text-decoration: none; font-size: 12px;">
                                        <i class="fa-solid fa-chart-simple"></i> THỐNG KÊ
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Tài liệu chung của môn học (Không thuộc chương nào) -->
            @{ var subjectDocs = Model.Subject.Documents.Where(d => d.ChapterId == null).ToList(); }
            @if (subjectDocs.Any())
        {
            <div style="background-color: var(--white); border: var(--border); box-shadow: 4px 4px 0px var(--black); padding: 20px; margin-bottom: 20px;">
                <h2 style="font-weight: 900; font-size: 18px; color: var(--blue); border-bottom: 2px dashed #ccc; padding-bottom: 10px; margin-bottom: 15px;">TÀI LIỆU CHUNG</h2>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    @foreach (var doc in subjectDocs)
                    {
                        <div style="background-color: var(--bg); border: 2px solid var(--black); padding: 10px 15px;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div style="display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 14px;">
                                    @{
                                        var ftColorG = doc.FileType?.ToLower() switch {
                                            "pdf"  => "#d93856",
                                            "docx" or "doc" => "#2b579a",
                                            "pptx" or "ppt" => "#d04423",
                                            _      => "#6b7280"
                                        };
                                    }
                                    <span style="color: @ftColorG; font-weight:900; font-size: 12px;">[@doc.FileType?.ToUpper()]</span>
                                    @doc.Title
                                </div>
                                <div style="display: flex; gap: 8px; align-items: center;">
                                    <a href="/ViewDocument?id=@doc.Id" style="font-weight: 800; font-size: 12px; color: var(--blue); white-space: nowrap;">
                                        <i class="fa-solid fa-eye"></i> Xem
                                    </a>
                                    <a href="@doc.FileUrl" target="_blank" style="font-weight: 800; font-size: 12px; color: var(--pink); white-space: nowrap;">
                                        <i class="fa-solid fa-download"></i> Tải
                                    </a>
                                    @if(Model.IsOwner)
                                    {
                                        <button type="button" onclick="openMoveDocModal(@doc.Id, '@doc.Title')" style="background: none; border: none; cursor: pointer; font-weight: 800; font-size: 12px; color: var(--green); padding: 0;">
                                            <i class="fa-solid fa-arrows-up-down-left-right"></i> Chuyển
                                        </button>
                                        <form method="post" asp-page-handler="DeleteDocument" asp-route-id="@Model.Subject.Id" asp-route-docId="@doc.Id"
                                              data-confirm="Bạn có chắc chắn muốn xóa tài liệu này?" style="display:inline;">
                                            <button type="submit" style="background: none; border: none; cursor: pointer; font-weight: 800; font-size: 12px; color: #dc2626; padding: 0;">
                                                <i class="fa-solid fa-trash"></i> Xóa
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                            <div style="margin-top: 6px; font-size: 11px; color: #888; font-weight: 600; display: flex; gap: 15px;">
                                <span><i class="fa-solid fa-user-clock"></i> Upload bởi: <strong>@(doc.UploaderName ?? "Không rõ")</strong></span>
                                <span><i class="fa-solid fa-clock"></i> @ToVnTime(doc.UploadedAt) (GMT+7)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div style="display: flex; flex-direction: column; gap: 20px;">
            @foreach (var chapter in Model.Subject.Chapters.OrderBy(c => c.OrderIndex))
            {
                <div style="background-color: var(--white); border: var(--border); box-shadow: 4px 4px 0px var(--black); padding: 20px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px dashed #ccc; padding-bottom: 10px; margin-bottom: 15px;">
                        <h2 style="font-weight: 900; font-size: 18px; color: var(--pink);">@chapter.Title</h2>

                        @if(Model.IsOwner)
                        {
                            <div style="display: flex; gap: 5px;">
                                <button type="button" onclick="openChapterModal(@chapter.Id, '@chapter.Title')" class="brutal-btn" style="background-color: var(--white); color: var(--black); border: 2px solid var(--black); padding: 4px 10px; font-weight: 800; font-size: 12px; box-shadow: 2px 2px 0px var(--black);">
                                    <i class="fa-solid fa-pen"></i> SỬA
                                </button>
                                <button type="button" onclick="openDeleteChapterModal(@chapter.Id, '@chapter.Title', @chapter.Documents.Count)" class="brutal-btn" style="background-color: #ff4d4f; color: white; border: 2px solid var(--black); padding: 4px 10px; font-weight: 800; font-size: 12px; box-shadow: 2px 2px 0px var(--black);">
                                    <i class="fa-solid fa-trash"></i> XÓA
                                </button>
                            </div>
                        }
                    </div>

                    <div id="hidden-docs-@chapter.Id" style="display: none;">
                        @if (chapter.Documents.Any())
                        {
                            <div style="max-height: 150px; overflow-y: auto; border: 2px solid var(--black); padding: 10px; margin-bottom: 10px; background: #f9f9f9; box-shadow: inset 2px 2px 0px rgba(0,0,0,0.1);">
                                @foreach(var d in chapter.Documents)
                                {
                                    <div style="font-size: 13px; font-weight: 700; margin-bottom: 5px; border-bottom: 1px dashed #ccc; padding-bottom: 5px; color: var(--black);">
                                        <i class="fa-solid fa-file" style="color: var(--blue);"></i> [@(d.FileType?.ToUpper() ?? "FILE")] @d.Title
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        @foreach (var doc in chapter.Documents)
                        {
                            <div style="background-color: var(--bg); border: 2px solid var(--black); padding: 10px 15px;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <div style="display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 14px;">
                                        @{
                                            var ftColor = doc.FileType?.ToLower() switch {
                                                "pdf"  => "#d93856",
                                                "docx" or "doc" => "#2b579a",
                                                "pptx" or "ppt" => "#d04423",
                                                _      => "#6b7280"
                                            };
                                        }
                                        <span style="color: @ftColor; font-weight:900; font-size: 12px;">[@doc.FileType?.ToUpper()]</span>
                                        @doc.Title
                                    </div>
                                    <div style="display: flex; gap: 8px; align-items: center;">
                                        <a href="/ViewDocument?id=@doc.Id" style="font-weight: 800; font-size: 12px; color: var(--blue); white-space: nowrap;">
                                            <i class="fa-solid fa-eye"></i> Xem
                                        </a>
                                        <a href="@doc.FileUrl" target="_blank" style="font-weight: 800; font-size: 12px; color: var(--pink); white-space: nowrap;">
                                            <i class="fa-solid fa-download"></i> Tải
                                        </a>
                                        @if(Model.IsOwner)
                                        {
                                            <button type="button" onclick="openMoveDocModal(@doc.Id, '@doc.Title')" style="background: none; border: none; cursor: pointer; font-weight: 800; font-size: 12px; color: var(--green); padding: 0;">
                                                <i class="fa-solid fa-arrows-up-down-left-right"></i> Chuyển
                                            </button>
                                            <form method="post" asp-page-handler="DeleteDocument" asp-route-id="@Model.Subject.Id" asp-route-docId="@doc.Id"
                                                  data-confirm="Xóa tài liệu '@doc.Title'? Hành động này không thể hoàn tác!" style="display:inline;">
                                                <button type="submit" style="background: none; border: none; cursor: pointer; font-weight: 800; font-size: 12px; color: #dc2626; padding: 0;">
                                                    <i class="fa-solid fa-trash"></i> Xóa
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                                <!-- Lịch sử upload -->
                                <div style="margin-top: 6px; font-size: 11px; color: #888; font-weight: 600; display: flex; gap: 15px;">
                                    <span><i class="fa-solid fa-user-clock"></i> Upload bởi: <strong>@(doc.UploaderName ?? "Không rõ")</strong></span>
                                    <span><i class="fa-solid fa-clock"></i> @ToVnTime(doc.UploadedAt) (GMT+7)</span>
                                </div>
                            </div>
                        }

                        @if (!chapter.Documents.Any())
                        {
                            <div style="font-style: italic; color: #777; font-size: 13px; font-weight: 600;">Chưa có tài liệu nào trong chương này.</div>
                        }
                    </div>
                </div>
            }

            @if (!Model.Subject.Chapters.Any())
            {
                <div style="padding: 40px; text-align: center; border: 3px dashed #000; background: #fff; font-weight: 800; font-style: italic;">
                    Chưa có chương học nào.
                </div>
            }
    </div>
</div>

@if((Model.IsOwner || Model.IsAdmin) && Model.ActivityLogs != null)
{
    <!-- MODAL LỊCH SỬ -->
    <div id="activityLogModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: var(--white); border: 4px solid var(--black); padding: 30px; box-shadow: 8px 8px 0px var(--black); width: 800px; max-width: 90%; max-height: 80vh; overflow-y: auto; position: relative;">
            <button type="button" onclick="document.getElementById('activityLogModal').style.display='none'" style="position: absolute; top: 15px; right: 20px; background: none; border: none; font-size: 24px; font-weight: 900; cursor: pointer;">&times;</button>
            <h2 style="font-weight: 900; font-size: 22px; color: var(--green); border-bottom: 2px dashed #ccc; padding-bottom: 10px; margin-bottom: 20px; text-transform: uppercase;">
                <i class="fa-solid fa-clock-rotate-left"></i> LỊCH SỬ THAY ĐỔI TÀI LIỆU
            </h2>
            
            @if(Model.ActivityLogs.Any())
            {
                <table style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr style="background-color: var(--black); color: var(--white); font-weight: 800; font-size: 14px;">
                            <th style="padding: 10px; border: 2px solid var(--black);">Thời gian</th>
                            <th style="padding: 10px; border: 2px solid var(--black);">Giảng viên</th>
                            <th style="padding: 10px; border: 2px solid var(--black);">Hành động</th>
                            <th style="padding: 10px; border: 2px solid var(--black);">Tài liệu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.ActivityLogs)
                        {
                            <tr style="border: 2px solid var(--black); font-weight: 700; font-size: 13px;">
                                <td style="padding: 10px; border: 2px solid var(--black);">@ToVnTime(log.Timestamp)</td>
                                <td style="padding: 10px; border: 2px solid var(--black);">@log.UserName</td>
                                <td style="padding: 10px; border: 2px solid var(--black);">
                                    @if(log.Action == "Uploaded") { <span style="color: var(--blue);"><i class="fa-solid fa-upload"></i> Đã tải lên</span> }
                                    else if(log.Action == "Deleted") { <span style="color: #dc2626;"><i class="fa-solid fa-trash"></i> Đã xóa</span> }
                                    else if(log.Action == "Moved") { <span style="color: var(--green);"><i class="fa-solid fa-arrows-up-down-left-right"></i> Đã chuyển</span> }
                                    else { @log.Action }
                                </td>
                                <td style="padding: 10px; border: 2px solid var(--black);">
                                    @log.DocumentTitle
                                    @if (log.DocumentId.HasValue)
                                    {
                                        <a href="/ViewDocument?id=@log.DocumentId" target="_blank" style="margin-left: 10px; font-size: 12px; color: var(--blue); font-weight: 900; text-decoration: none; border: 1px solid var(--black); padding: 2px 6px; background-color: var(--white); box-shadow: 1px 1px 0px var(--black);">
                                            <i class="fa-solid fa-eye"></i> Xem
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="font-style: italic; color: #777; font-size: 14px; font-weight: 600; text-align: center; padding: 20px;">
                    Chưa có lịch sử thay đổi tài liệu nào.
                </div>
            }
        </div>
    </div>
}

@if(Model.IsOwner)
{
    <!-- MODAL CHƯƠNG -->
    <div id="chapterModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: var(--white); border: 4px solid var(--black); padding: 30px; box-shadow: 8px 8px 0px var(--black); width: 400px; max-width: 90%;">
            <h2 id="chapterModalTitle" style="font-weight: 900; color: var(--pink); margin-bottom: 20px; text-transform: uppercase;">THÊM CHƯƠNG MỚI</h2>

            <form id="chapterForm" method="post" asp-page-handler="AddChapter" asp-route-id="@Model.Subject.Id">
                <input type="hidden" id="updateChapterId" asp-for="UpdateChapterModel.Id" value="0" />

                <div style="margin-bottom: 20px;">
                    <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Tên chương</label>
                    <input type="text" id="chapterTitleInput" name="CreateChapterModel.Title" required style="width: 100%; border: 3px solid var(--black); padding: 10px; font-weight: 700; outline: none; font-size: 16px;" placeholder="Ví dụ: Chương 1: Mở đầu" />
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="closeModals()" class="brutal-btn" style="background: #ccc; border: 3px solid var(--black); padding: 10px 20px; font-weight: 900;">HỦY</button>
                    <button type="submit" class="brutal-btn" style="background: var(--pink); color: white; border: 3px solid var(--black); padding: 10px 20px; font-weight: 900;">LƯU CHƯƠNG</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL UPLOAD -->
    <div id="uploadModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: var(--white); border: 4px solid var(--black); padding: 30px; box-shadow: 8px 8px 0px var(--black); width: 450px; max-width: 90%;">
            <h2 style="font-weight: 900; color: var(--blue); margin-bottom: 20px; text-transform: uppercase;">TẢI LÊN TÀI LIỆU</h2>

            <form id="uploadForm" onsubmit="handleUpload(event, @Model.Subject.Id)">
                <!-- Fake inputs mapped to ASP names for FormData to pick up automatically -->
                @Html.AntiForgeryToken()
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Tên tài liệu</label>
                    <input type="text" name="UploadDocumentModel.Title" required style="width: 100%; border: 3px solid var(--black); padding: 10px; font-weight: 700; outline: none; font-size: 14px;" placeholder="Tên tài liệu hiển thị" />
                </div>

                <div style="margin-bottom: 15px;">
                    <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Chương (Tùy chọn)</label>
                    <select name="UploadDocumentModel.ChapterId" style="width: 100%; border: 3px solid var(--black); padding: 10px; font-weight: 700; outline: none; font-size: 14px; background: white;">
                        <option value="">-- Tài liệu chung (Không thuộc chương nào) --</option>
                        @foreach(var c in Model.Subject.Chapters.OrderBy(x => x.OrderIndex))
                        {
                            <option value="@c.Id">@c.Title</option>
                        }
                    </select>
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Chọn File</label>
                    <input type="file" name="UploadDocumentModel.File" required accept=".pdf,.doc,.docx,.ppt,.pptx,.txt,.md,.csv" style="width: 100%; border: 3px solid var(--black); padding: 10px; font-weight: 700; background: white; font-size: 14px;" />
                    <p style="font-size: 11px; color: #888; margin-top: 5px; font-weight: 600;">Hỗ trợ: PDF, DOCX, PPTX, TXT, MD, CSV</p>
                </div>
                
                <div id="uploadProgressContainer" style="display: none; margin-bottom: 20px;">
                    <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Tiến trình xử lý:</label>
                    <div style="width: 100%; background-color: #eee; border: 3px solid var(--black); height: 25px; position: relative;">
                        <div id="uploadProgressBar" style="width: 0%; height: 100%; background-color: var(--green); transition: width 0.3s ease;"></div>
                        <div id="uploadProgressText" style="position: absolute; top: 0; left: 0; width: 100%; text-align: center; font-weight: 900; font-size: 12px; line-height: 19px; mix-blend-mode: difference; color: white;">0%</div>
                    </div>
                    <p style="font-size: 11px; color: #888; margin-top: 5px; font-weight: 600; text-align: center;">Đang trích xuất và băm dữ liệu ... Vui lòng đợi.</p>
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="closeModals()" class="brutal-btn" style="background: #ccc; border: 3px solid var(--black); padding: 10px 20px; font-weight: 900;">HỦY</button>
                    <button type="submit" id="uploadSubmitBtn" class="brutal-btn" style="background: var(--blue); color: white; border: 3px solid var(--black); padding: 10px 20px; font-weight: 900;">TẢI LÊN</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL XÓA CHƯƠNG -->
    <div id="deleteChapterModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: var(--white); border: 4px solid var(--black); padding: 30px; box-shadow: 8px 8px 0px var(--black); width: 450px; max-width: 90%;">
            <h2 style="font-weight: 900; color: #dc2626; margin-bottom: 10px; text-transform: uppercase;">XÓA CHƯƠNG</h2>
            <p id="deleteChapterPrompt" style="font-weight: 700; color: #555; margin-bottom: 20px;"></p>

            <form id="deleteChapterForm" method="post" asp-page-handler="DeleteChapter" asp-route-id="@Model.Subject.Id">
                <input type="hidden" id="deleteChapterIdInput" name="chapterId" value="0" />
                <input type="hidden" id="deleteChapterOptionInput" name="DeleteChapterModel.Option" value="keep" />
                
                <div id="deleteChapterDocList"></div>

                <div style="display: flex; gap: 10px; justify-content: flex-end; flex-wrap: wrap; margin-top: 10px;">
                    <button type="button" onclick="closeModals()" class="brutal-btn" style="background: #ccc; border: 3px solid var(--black); padding: 8px 15px; font-weight: 900; flex: 1; min-width: 100px;">HỦY</button>
                    <button type="button" id="btnDeleteEmpty" onclick="submitDeleteChapter('keep')" class="brutal-btn" style="display: none; background: #dc2626; color: white; border: 3px solid var(--black); padding: 8px 15px; font-weight: 900; flex: 1; min-width: 150px;">XÁC NHẬN XÓA</button>
                    <button type="button" id="btnMoveAndKeep" onclick="submitDeleteChapter('keep')" class="brutal-btn" style="display: none; background: var(--blue); color: white; border: 3px solid var(--black); padding: 8px 15px; font-weight: 900; font-size: 13px; flex: 1; min-width: 200px;">XÓA & ĐƯA TÀI LIỆU RA CHUNG</button>
                    <button type="button" id="btnDeleteAll" onclick="submitDeleteChapter('delete')" class="brutal-btn" style="display: none; background: #dc2626; color: white; border: 3px solid var(--black); padding: 8px 15px; font-weight: 900; font-size: 13px; flex: 1; min-width: 200px;">XÓA CHƯƠNG & XÓA CẢ TÀI LIỆU</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL CHUYỂN TÀI LIỆU -->
    <div id="moveDocModal" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: var(--white); border: 4px solid var(--black); padding: 30px; box-shadow: 8px 8px 0px var(--black); width: 450px; max-width: 90%;">
            <h2 style="font-weight: 900; color: var(--green); margin-bottom: 20px; text-transform: uppercase;">CHUYỂN VỊ TRÍ TÀI LIỆU</h2>
            <p style="font-weight: 700; color: #555; margin-bottom: 15px;">Đang chuyển tài liệu: <strong id="moveDocTitle" style="color: var(--black);"></strong></p>

            <form method="post" asp-page-handler="MoveDocument" asp-route-id="@Model.Subject.Id">
                <input type="hidden" id="moveDocumentId" name="MoveDocumentModel.DocumentId" value="0" />
                
                <div style="margin-bottom: 20px;">
                    <label style="font-weight: 800; font-size: 14px; display: block; margin-bottom: 5px;">Chọn nơi chuyển đến</label>
                    <select name="MoveDocumentModel.ToChapterId" style="width: 100%; border: 3px solid var(--black); padding: 10px; font-weight: 700; outline: none; font-size: 14px; background: white;">
                        <option value="">-- Tài liệu chung (Không thuộc chương nào) --</option>
                        @foreach(var c in Model.Subject.Chapters.OrderBy(x => x.OrderIndex))
                        {
                            <option value="@c.Id">@c.Title</option>
                        }
                    </select>
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="closeModals()" class="brutal-btn" style="background: #ccc; border: 3px solid var(--black); padding: 10px 20px; font-weight: 900;">HỦY</button>
                    <button type="submit" class="brutal-btn" style="background: var(--green); color: white; border: 3px solid var(--black); padding: 10px 20px; font-weight: 900;">CHUYỂN</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script>
        function openChapterModal(id, title) {
            document.getElementById('chapterModal').style.display = 'flex';
            document.getElementById('updateChapterId').value = id;
            if(id > 0) {
                document.getElementById('chapterModalTitle').innerText = "CẬP NHẬT CHƯƠNG";
                document.getElementById('chapterForm').action = "?handler=UpdateChapter";
                document.getElementById('chapterTitleInput').name = "UpdateChapterModel.Title";
                document.getElementById('chapterTitleInput').value = title;
            } else {
                document.getElementById('chapterModalTitle').innerText = "THÊM CHƯƠNG MỚI";
                document.getElementById('chapterForm').action = "?handler=AddChapter";
                document.getElementById('chapterTitleInput').name = "CreateChapterModel.Title";
                document.getElementById('chapterTitleInput').value = "";
            }
        }

        function openUploadModal(chapterId) {
            document.getElementById('uploadModal').style.display = 'flex';
            const chapterSelect = document.querySelector('select[name="UploadDocumentModel.ChapterId"]');
            if (chapterId) {
                chapterSelect.value = chapterId;
            } else {
                chapterSelect.value = "";
            }
        }

        function openDeleteChapterModal(id, title, docCount) {
            document.getElementById('deleteChapterModal').style.display = 'flex';
            document.getElementById('deleteChapterIdInput').value = id;
            
            const docListContainer = document.getElementById('deleteChapterDocList');
            const hiddenDocs = document.getElementById('hidden-docs-' + id);
            
            if (docCount > 0) {
                document.getElementById('deleteChapterPrompt').innerHTML = `Bạn đang xóa chương <strong style="color:var(--pink);">${title}</strong>. Có <strong style="color:var(--pink);">${docCount}</strong> tài liệu đang nằm trong chương này:`;
                docListContainer.innerHTML = hiddenDocs ? hiddenDocs.innerHTML : '';
                docListContainer.style.display = 'block';

                document.getElementById('btnDeleteEmpty').style.display = 'none';
                document.getElementById('btnMoveAndKeep').style.display = 'inline-block';
                document.getElementById('btnDeleteAll').style.display = 'inline-block';
            } else {
                document.getElementById('deleteChapterPrompt').innerHTML = `Bạn có chắc muốn xóa chương <strong style="color:var(--pink);">${title}</strong>? Chương này hiện không có tài liệu nào.`;
                docListContainer.style.display = 'none';
                
                document.getElementById('btnDeleteEmpty').style.display = 'inline-block';
                document.getElementById('btnMoveAndKeep').style.display = 'none';
                document.getElementById('btnDeleteAll').style.display = 'none';
            }
        }

        function submitDeleteChapter(option) {
            document.getElementById('deleteChapterOptionInput').value = option;
            document.getElementById('deleteChapterForm').submit();
        }

        function openMoveDocModal(docId, docTitle) {
            document.getElementById('moveDocModal').style.display = 'flex';
            document.getElementById('moveDocumentId').value = docId;
            document.getElementById('moveDocTitle').innerText = docTitle;
        }

        function closeModals() {
            document.getElementById('chapterModal').style.display = 'none';
            document.getElementById('uploadModal').style.display = 'none';
            document.getElementById('deleteChapterModal').style.display = 'none';
            document.getElementById('moveDocModal').style.display = 'none';
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/courseHub")
            .build();

        connection.on("CourseChanged", function () {
            fetch(window.location.href)
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newContent = doc.getElementById('manage-subject-container').innerHTML;
                    document.getElementById('manage-subject-container').innerHTML = newContent;
                });
        });

        connection.on("UploadProgress", function (percent) {
            const progressBar = document.getElementById('uploadProgressBar');
            const progressText = document.getElementById('uploadProgressText');
            if (progressBar && progressText) {
                progressBar.style.width = percent + '%';
                progressText.innerText = percent + '%';
            }
        });

        async function handleUpload(event, subjectId) {
            event.preventDefault();
            const form = document.getElementById('uploadForm');
            const submitBtn = document.getElementById('uploadSubmitBtn');
            const progressContainer = document.getElementById('uploadProgressContainer');
            const progressBar = document.getElementById('uploadProgressBar');
            const progressText = document.getElementById('uploadProgressText');
            
            submitBtn.disabled = true;
            submitBtn.innerText = 'ĐANG XỬ LÝ...';
            progressContainer.style.display = 'block';
            progressBar.style.width = '0%';
            progressText.innerText = '0%';

            // Đảm bảo connection đã được init trước khi gửi form (tránh crash)
            const formData = new FormData(form);
            if (typeof connection !== 'undefined' && connection.connectionId) {
                formData.append("UploadDocumentModel.ConnectionId", connection.connectionId);
            }

            try {
                const response = await fetch(`?handler=UploadFile&id=${subjectId}`, {
                    method: 'POST',
                    body: formData
                });
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Đã xảy ra lỗi trong quá trình tải lên hoặc xử lý.');
                    submitBtn.disabled = false;
                    submitBtn.innerText = 'TẢI LÊN';
                    progressContainer.style.display = 'none';
                }
            } catch (err) {
                console.error(err);
                alert('Lỗi mạng hoặc server không phản hồi.');
                submitBtn.disabled = false;
                submitBtn.innerText = 'TẢI LÊN';
                progressContainer.style.display = 'none';
            }
        }

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
