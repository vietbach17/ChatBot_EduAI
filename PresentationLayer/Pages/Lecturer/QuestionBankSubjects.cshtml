@page
@model PresentationLayer.Pages.Lecturer.QuestionBankSubjectsModel
@{
    ViewData["Title"] = "Ngân Hàng Câu Hỏi - Chọn Môn Học";
    ViewBag.ActiveMenu = "QuestionBank";
}

<div class="main-wrapper">
    <div style="padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
            <h1 style="color: var(--blue); font-weight: 900; font-size: 28px; text-transform: uppercase; margin: 0;">
                <i class="fa-solid fa-database"></i> NGÂN HÀNG CÂU HỎI
            </h1>
        </div>
        <p style="font-weight: 700; color: #555; margin-bottom: 30px;">Chọn môn học bạn phụ trách để quản lý ngân hàng câu hỏi của môn đó</p>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            var isError = Model.StatusMessage.StartsWith("Error");
            var displayMsg = Model.StatusMessage.Substring(Model.StatusMessage.IndexOf(":") + 1).Trim();
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 18px; margin-bottom: 20px; font-weight: 800; border: 3px solid var(--black); box-shadow: 3px 3px 0px var(--black); background: @(isError ? "var(--pink)" : "var(--green)"); color: var(--white);">
                <span><i class="fa-solid @(isError ? "fa-circle-exclamation" : "fa-circle-check")"></i> @displayMsg</span>
                <button style="background:none; border:none; color:inherit; font-weight:900; cursor:pointer;" onclick="this.parentElement.remove()">X</button>
            </div>
        }

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
            @foreach (var item in Model.Subjects)
            {
                <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px; display: flex; flex-direction: column;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 5px;">
                        <div style="font-weight: 900; font-size: 24px; color: var(--black);">@item.Subject.Code</div>
                        <span style="font-weight: 900; font-size: 12px; background: var(--yellow); border: 2px solid var(--black); padding: 3px 8px; white-space: nowrap;">
                            @item.QuestionCount CÂU HỎI
                        </span>
                    </div>
                    <div style="font-weight: 700; font-size: 16px; color: #555; margin-bottom: 20px; flex: 1;">@item.Subject.Name</div>

                    <a asp-page="/Lecturer/QuestionBank" asp-route-SubjectId="@item.Subject.Id" class="brutal-btn" style="background-color: var(--blue); color: var(--white); border: 2px solid var(--black); padding: 10px 15px; font-weight: 800; text-align: center; text-decoration: none; box-shadow: 2px 2px 0px var(--black); margin-top: auto;">
                        <i class="fa-solid fa-database"></i> VÀO NGÂN HÀNG CÂU HỎI
                    </a>
                </div>
            }

            @if (!Model.Subjects.Any())
            {
                <div style="grid-column: 1 / -1; padding: 40px; text-align: center; border: 3px dashed #000; background: #fff; font-weight: 800; font-style: italic;">
                    Bạn chưa được phân công phụ trách môn học nào.
                </div>
            }
        </div>
    </div>
</div>
