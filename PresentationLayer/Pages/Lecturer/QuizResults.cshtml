@page
@model PresentationLayer.Pages.Lecturer.QuizResultsModel
@{
    ViewData["Title"] = "Kết quả thi: " + Model.Statistics.QuizTitle;
    var vnZone = TimeZoneInfo.FindSystemTimeZoneById(
        System.Runtime.InteropServices.RuntimeInformation.IsOSPlatform(System.Runtime.InteropServices.OSPlatform.Windows)
            ? "SE Asia Standard Time" : "Asia/Ho_Chi_Minh");
    string ToVnTime(DateTime utc) => TimeZoneInfo.ConvertTimeFromUtc(utc, vnZone).ToString("dd/MM/yyyy HH:mm");
}

<style>
    .brutal-card {
        background-color: var(--white);
        border: 2px solid var(--black);
        box-shadow: 4px 4px 0px var(--black);
        padding: 20px;
        margin-bottom: 20px;
    }
    .brutal-btn {
        background-color: var(--yellow);
        color: var(--black);
        border: 2px solid var(--black);
        padding: 8px 15px;
        font-weight: 900;
        font-size: 14px;
        cursor: pointer;
        box-shadow: 2px 2px 0px var(--black);
        transition: 0.1s;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-block;
    }
    .brutal-btn:active {
        box-shadow: 0px 0px 0px var(--black);
        transform: translate(2px, 2px);
    }
    .stat-box {
        flex: 1;
        padding: 15px;
        border: 2px solid var(--black);
        text-align: center;
    }
    .stat-title {
        font-weight: 800;
        font-size: 12px;
        text-transform: uppercase;
        color: #555;
    }
    .stat-value {
        font-weight: 900;
        font-size: 24px;
        color: var(--black);
        margin-top: 5px;
    }
    .brutal-table {
        width: 100%;
        border-collapse: collapse;
        border: 2px solid var(--black);
    }
    .brutal-table th, .brutal-table td {
        border: 2px solid var(--black);
        padding: 10px;
        text-align: left;
    }
    .brutal-table th {
        background-color: var(--pink);
        color: var(--white);
        font-weight: 800;
        text-transform: uppercase;
    }
    .brutal-table tr:nth-child(even) {
        background-color: #f9f9f9;
    }

    /* Print styles */
    @@media print {
        .no-print { display: none !important; }
        .print-only { display: block !important; }
        body { font-family: Arial, sans-serif; font-size: 12px; }
        .brutal-table { border: 1px solid #000; }
        .brutal-table th, .brutal-table td { border: 1px solid #000; padding: 6px; }
        .brutal-table th { background-color: #eee !important; color: #000 !important; }
        .stat-box { border: 1px solid #ccc !important; box-shadow: none !important; }
        .brutal-card { border: none !important; box-shadow: none !important; padding: 0 !important; }
        .main-wrapper { padding: 0 !important; }
        h1, h2 { color: #000 !important; }
    }
    .print-only { display: none; }
</style>

<div class="main-wrapper" style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;" class="no-print">
        <h1 style="color: var(--blue); font-weight: 900; text-transform: uppercase; margin: 0;">
            KẾT QUẢ THI: @Model.Statistics.QuizTitle
        </h1>
        <button class="brutal-btn" onclick="printReport()" style="background-color: var(--green);">
            <i class="fa-solid fa-file-export"></i> Xuất Báo Cáo
        </button>
    </div>

    <!-- Print header (only shown when printing) -->
    <div class="print-only" style="margin-bottom: 20px;">
        <h1 style="text-align: center; font-size: 18px;">BÁO CÁO KẾT QUẢ THI</h1>
        <h2 style="text-align: center; font-size: 15px; font-weight: normal;">@Model.Statistics.QuizTitle</h2>
        <p style="text-align: right; font-size: 11px; color: #555;">Ngày xuất: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="brutal-card" style="background-color: #ffcccc; color: red;">
            <strong>Lỗi:</strong> @Model.ErrorMessage
        </div>
    }
    else
    {
        <!-- STATISTICS GRID -->
        <div style="display: flex; gap: 15px; margin-bottom: 20px;">
            <div class="stat-box" style="background-color: #e0f7fa;">
                <div class="stat-title">Lượt Nộp Bài</div>
                <div class="stat-value">@Model.Statistics.TotalAttempts</div>
            </div>
            <div class="stat-box" style="background-color: #e8f5e9;">
                <div class="stat-title">Điểm Trung Bình</div>
                <div class="stat-value">@Model.Statistics.AverageScore.ToString("0.0")</div>
            </div>
            <div class="stat-box" style="background-color: #fff3e0;">
                <div class="stat-title">Điểm Cao Nhất</div>
                <div class="stat-value">@Model.Statistics.HighestScore.ToString("0.0")</div>
            </div>
            <div class="stat-box" style="background-color: #ffebee;">
                <div class="stat-title">Điểm Thấp Nhất</div>
                <div class="stat-value">@Model.Statistics.LowestScore.ToString("0.0")</div>
            </div>
        </div>

        <!-- ATTEMPTS TABLE -->
        <div class="brutal-card">
            <h2 style="font-weight: 800; margin-top: 0; margin-bottom: 15px;">Danh Sách Sinh Viên</h2>
            <table class="brutal-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">STT</th>
                        <th>Họ Tên Sinh Viên</th>
                        <th>Thời Gian Nộp</th>
                        <th>Thời Lượng</th>
                        <th>Điểm Số</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Statistics.Attempts != null && Model.Statistics.Attempts.Any())
                    {
                        int index = 1;
                        foreach (var attempt in Model.Statistics.Attempts)
                        {
                            <tr>
                                <td>@index</td>
                                <td style="font-weight: 700;">@attempt.StudentName</td>
                                <td>@(attempt.EndTime.HasValue ? ToVnTime(attempt.EndTime.Value) : "-")</td>
                                <td>
                                    @if(attempt.EndTime.HasValue)
                                    {
                                        var duration = attempt.EndTime.Value - attempt.StartTime;
                                        <span>@Math.Round(duration.TotalMinutes, 1) phút</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td><strong style="color: var(--blue);">@attempt.Score.ToString("0.0")</strong></td>
                                <td>
                                    @if(attempt.Status == "Graded")
                                    {
                                        <span style="color: green; font-weight: 700;">Đã chấm</span>
                                    }
                                    else if (attempt.Status == "InProgress")
                                    {
                                        <span style="color: orange; font-weight: 700;">Đang làm</span>
                                    }
                                    else
                                    {
                                        <span>@attempt.Status</span>
                                    }
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" style="text-align: center; font-style: italic; color: #777;">Chưa có sinh viên nào nộp bài.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    function printReport() {
        // Đánh dấu tất cả phần tử con trực tiếp của body không phải main content
        const mainWrapper = document.querySelector('.main-wrapper');
        const bodyChildren = Array.from(document.body.children);
        
        const hidden = [];
        bodyChildren.forEach(el => {
            if (el !== mainWrapper && el.tagName !== 'SCRIPT' && el.tagName !== 'STYLE') {
                hidden.push({ el, display: el.style.display });
                el.style.display = 'none';
            }
        });
        
        window.print();
        
        // Restore
        hidden.forEach(({ el, display }) => {
            el.style.display = display;
        });
    }
</script>
