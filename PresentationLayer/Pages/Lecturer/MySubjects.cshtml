@page
@model PresentationLayer.Pages.Lecturer.MySubjectsModel
@{
    ViewData["Title"] = "Môn học phụ trách";
    ViewBag.ActiveMenu = "LecturerSubjects";
}

@section Styles {
    <style>
        .modal {
            display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;
        }
        .modal-content {
            background-color: var(--white); border: var(--border); box-shadow: 8px 8px 0px var(--black);
            padding: 30px; width: 450px; position: relative;
        }
        .close-btn {
            position: absolute; top: 10px; right: 15px; font-size: 24px; font-weight: 900; cursor: pointer; color: var(--black);
        }
        .form-group { margin-bottom: 15px; display: flex; flex-direction: column; gap: 5px; }
        .form-group label { font-weight: 800; font-size: 12px; }
        .form-group input, .form-group select {
            border: 2px solid var(--black); padding: 10px; font-weight: 700; outline: none;
        }
    </style>
}

<div class="main-wrapper">
    <div style="padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h1 style="color: var(--blue); font-weight: 900; font-size: 28px; text-transform: uppercase; margin: 0;">
                MÔN HỌC PHỤ TRÁCH
            </h1>
        </div>

        <div id="subjects-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
            @foreach (var subject in Model.Subjects)
            {
                <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px; display: flex; flex-direction: column;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 5px;">
                        <div style="font-weight: 900; font-size: 24px; color: var(--black);">@subject.Code</div>
                        <!-- No actions here, Lecturer can only view and manage documents -->
                    </div>
                    <div style="font-weight: 700; font-size: 16px; color: #555; margin-bottom: 20px; flex: 1;">@subject.Name</div>
                    
                    <a asp-page="/Lecturer/ManageSubject" asp-route-id="@subject.Id" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 2px solid var(--black); padding: 10px 15px; font-weight: 800; text-align: center; text-decoration: none; box-shadow: 2px 2px 0px var(--black); margin-top: auto;">
                        <i class="fa-solid fa-folder-open"></i> QUẢN LÝ TÀI LIỆU
                    </a>
                </div>
            }

            @if (!Model.Subjects.Any())
            {
                <div style="grid-column: 1 / -1; padding: 40px; text-align: center; border: 3px dashed #000; background: #fff; font-weight: 800; font-style: italic;">
                    Bạn chưa được phân công phụ trách môn học nào.
                </div>
            }
        </div>
    </div>
</div>



@section Scripts {
    <script>


        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/courseHub")
            .build();

        connection.on("CourseChanged", function () {
            fetch(window.location.href)
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newContent = doc.getElementById('subjects-container').innerHTML;
                    document.getElementById('subjects-container').innerHTML = newContent;
                });
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
