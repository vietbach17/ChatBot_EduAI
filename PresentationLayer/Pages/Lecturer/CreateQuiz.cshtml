@page
@model PresentationLayer.Pages.Lecturer.CreateQuizModel
@{
    ViewData["Title"] = "Tạo Bài Thi Mới";
}

<style>
    .brutal-card {
        background-color: var(--white);
        border: 2px solid var(--black);
        box-shadow: 4px 4px 0px var(--black);
        padding: 20px;
        margin-bottom: 20px;
    }
    .brutal-input {
        width: 100%;
        padding: 10px;
        border: 2px solid var(--black);
        font-family: inherit;
        font-size: 16px;
        margin-top: 5px;
        margin-bottom: 15px;
        transition: 0.1s;
    }
    .brutal-input:focus {
        outline: none;
        border-color: var(--pink);
        box-shadow: 2px 2px 0px var(--pink);
    }
    .brutal-btn {
        background-color: var(--yellow);
        color: var(--black);
        border: 2px solid var(--black);
        padding: 10px 20px;
        font-weight: 900;
        font-size: 16px;
        cursor: pointer;
        box-shadow: 3px 3px 0px var(--black);
        transition: 0.1s;
        text-transform: uppercase;
    }
    .brutal-btn:active {
        box-shadow: 0px 0px 0px var(--black);
        transform: translate(3px, 3px);
    }
    .btn-pink { background-color: var(--pink); color: white; }
    
    .dual-pane {
        display: flex;
        gap: 20px;
        align-items: flex-start;
    }
    .left-pane { flex: 6; }
    .right-pane {
        flex: 4;
        position: sticky;
        top: 20px;
        height: 85vh;
        overflow-y: auto;
    }
    
    .variant-card {
        border: 2px dashed #888;
        padding: 15px;
        margin-bottom: 15px;
        cursor: pointer;
        transition: 0.2s;
    }
    .variant-card.active {
        border: 2px solid var(--pink);
        background-color: #fff0f5;
    }
    
    .question-item {
        border: 1px solid #ccc;
        padding: 10px;
        margin-bottom: 10px;
        background: white;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .question-item:hover {
        border-color: var(--black);
        background-color: #f9f9f9;
    }
</style>

<div class="main-wrapper" style="padding: 20px;">
    <h1 style="color: var(--pink); font-weight: 900; text-transform: uppercase; margin-bottom: 20px;">Tạo Bài Thi Mới</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successPopup" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 9999;">
            <div class="brutal-card" style="background-color: var(--green); text-align: center; max-width: 450px; border: 4px solid var(--black); box-shadow: 8px 8px 0px var(--black);">
                <h2 style="margin-top: 0; font-weight: 900; font-size: 24px;">THÀNH CÔNG! 🎉</h2>
                <p style="font-weight: 700; font-size: 16px;">@TempData["SuccessMessage"]</p>
                <p style="font-size: 13px; font-style: italic; margin-top: 5px;">(Trang đã được làm mới để bạn có thể tạo bài thi tiếp theo nếu muốn)</p>
                <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px;">
                    <a href="/Lecturer/ManageSubject/@Model.SubjectId" class="brutal-btn" style="background-color: var(--white); text-decoration: none; font-size: 14px;">Về DS Bài thi</a>
                    <button type="button" class="brutal-btn" style="background-color: var(--yellow); font-size: 14px;" onclick="document.getElementById('successPopup').style.display='none'">Tạo bài mới</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="brutal-card" style="background-color: #ffcccc; color: red;">
            <strong>Lỗi:</strong> @Model.ErrorMessage
        </div>
    }

    <form method="post" id="quizForm">
        <input type="hidden" asp-for="SubjectId" />
        <input type="hidden" id="VariantsJson" name="VariantsJson" value="[]" />

        <div class="dual-pane">
            <!-- LEFT PANE: CONFIGURATION -->
            <div class="left-pane">
                <div class="brutal-card">
                    <h2 style="font-weight: 800; margin-bottom: 15px;">1. Thông tin chung</h2>
                    
                    <label style="font-weight: 700;">Tên bài thi</label>
                    <input type="text" asp-for="QuizInput.Title" class="brutal-input" required placeholder="VD: Kiểm tra giữa kỳ AI..." />

                    <label style="font-weight: 700;">Mô tả</label>
                    <textarea asp-for="QuizInput.Description" class="brutal-input" rows="3" placeholder="Ghi chú thêm cho sinh viên..."></textarea>

                    <label style="font-weight: 700;">Cách thiết lập thời gian</label>
                    <div style="margin-bottom: 15px;">
                        <label style="margin-right: 15px; cursor: pointer;">
                            <input type="radio" name="TimeMode" value="custom" checked onchange="toggleTimeMode()" /> Tự chọn
                        </label>
                        <label style="cursor: pointer;">
                            <input type="radio" name="TimeMode" value="fptu" onchange="toggleTimeMode()" /> Theo lịch học trường FPTU
                        </label>
                    </div>

                    <div id="fptuTimeContainer" style="display: none; padding: 15px; border: 2px solid var(--black); background: #f9f9f9; margin-bottom: 15px;">
                        <label style="font-weight: 700;">Chọn ngày kiểm tra</label>
                        <input type="date" id="fptuDate" class="brutal-input" onchange="applyFptuTime()" />
                        
                        <label style="font-weight: 700; margin-top: 10px; display: block;">Chọn Slot</label>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 5px;">
                            <label style="padding: 10px; border: 1px solid var(--black); background: #fff; cursor: pointer; font-size: 14px;">
                                <input type="radio" name="FptuSlot" value="1" onchange="applyFptuTime()" /> Slot 1 (07:00 - 09:15)
                            </label>
                            <label style="padding: 10px; border: 1px solid var(--black); background: #fff; cursor: pointer; font-size: 14px;">
                                <input type="radio" name="FptuSlot" value="2" onchange="applyFptuTime()" /> Slot 2 (09:30 - 11:45)
                            </label>
                            <label style="padding: 10px; border: 1px solid var(--black); background: #fff; cursor: pointer; font-size: 14px;">
                                <input type="radio" name="FptuSlot" value="3" onchange="applyFptuTime()" /> Slot 3 (12:30 - 14:45)
                            </label>
                            <label style="padding: 10px; border: 1px solid var(--black); background: #fff; cursor: pointer; font-size: 14px;">
                                <input type="radio" name="FptuSlot" value="4" onchange="applyFptuTime()" /> Slot 4 (15:00 - 17:15)
                            </label>
                        </div>
                    </div>

                    <div style="display: flex; gap: 15px;">
                        <div style="flex: 1;">
                            <label style="font-weight: 700;">Thời gian bắt đầu (Tùy chọn)</label>
                            <input type="datetime-local" asp-for="QuizInput.StartTime" class="brutal-input" id="QuizInput_StartTime" />
                        </div>
                        <div style="flex: 1;">
                            <label style="font-weight: 700;">Thời gian kết thúc (Tùy chọn)</label>
                            <input type="datetime-local" asp-for="QuizInput.EndTime" class="brutal-input" id="QuizInput_EndTime" />
                        </div>
                    </div>

                    <div style="display: flex; gap: 15px;">
                        <div style="flex: 1;">
                            <label style="font-weight: 700;">Thời lượng (phút)</label>
                            <input type="number" asp-for="QuizInput.TimeLimitMinutes" class="brutal-input" min="1" required />
                        </div>
                        <div style="flex: 1;">
                            <label style="font-weight: 700;">Số lần thi tối đa</label>
                            <input type="number" asp-for="QuizInput.MaxAttempts" class="brutal-input" min="1" required />
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 15px;">
                        <div style="display: flex; gap: 20px; align-items: center;">
                            <label style="font-weight: 700; display: flex; align-items: center; gap: 5px;">
                                <input type="checkbox" asp-for="QuizInput.IsShuffled" style="width: 20px; height: 20px;" />
                                Đảo vị trí đáp án (A,B,C,D)
                            </label>
                            <label style="font-weight: 700; display: flex; align-items: center; gap: 5px;">
                                <input type="checkbox" asp-for="QuizInput.ShowScoreAfterSubmit" id="cbShowScore" style="width: 20px; height: 20px;" onchange="toggleScoreTiming()" />
                                Cho phép xem điểm & đáp án
                            </label>
                        </div>
                        
                        <div id="scoreTimingContainer" style="padding-left: 25px;">
                            <label style="font-weight: 700; font-size: 14px; color: #555;">Thời điểm được xem:</label>
                            <select asp-for="QuizInput.ScoreDisplayTiming" class="brutal-input" style="margin-top: 5px; margin-bottom: 0;">
                                <option value="Immediately">Ngay sau khi làm xong</option>
                                <option value="AfterEndTime">Ngay sau khi đã qua thời gian triển khai (EndTime)</option>
                            </select>
                        </div>
                    </div>

                    <label style="font-weight: 700;">Cách tính điểm</label>
                    <select asp-for="QuizInput.GradingMethod" class="brutal-input">
                        <option value="Highest">Lấy điểm cao nhất</option>
                        <option value="Average">Lấy điểm trung bình</option>
                        <option value="Latest">Lấy điểm lần cuối</option>
                    </select>

                    <label style="font-weight: 700;">Mật khẩu bài thi (không bắt buộc)</label>
                    <input type="text" asp-for="QuizInput.AccessCode" class="brutal-input" placeholder="Để trống nếu không cần mật khẩu..." autocomplete="off" />
                </div>

                <div class="brutal-card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <h2 style="font-weight: 800; margin: 0;">2. Cấu trúc Mã Đề</h2>
                        <button type="button" class="brutal-btn btn-pink" onclick="addVariant()" style="padding: 5px 10px; font-size: 14px;">+ Thêm Mã Đề</button>
                    </div>
                    
                    <div id="variants-container">
                        <!-- Variants will be rendered here by JS -->
                    </div>
                </div>

                <button type="submit" class="brutal-btn" style="width: 100%; font-size: 20px; padding: 15px;" onclick="prepareSubmit()">
                    🚀 LƯU VÀ PHÁT HÀNH BÀI THI
                </button>
            </div>

            <!-- RIGHT PANE: QUESTION BANK -->
            <div class="right-pane brutal-card" style="background-color: #f4f4f4;">
                <h3 style="font-weight: 800; margin-top: 0;">Ngân Hàng Câu Hỏi</h3>
                
                <div style="display: flex; gap: 10px; margin-bottom: 10px; align-items: stretch;">
                    <input type="number" id="autoAddCount" class="brutal-input" style="margin: 0; flex: 1;" min="1" placeholder="Nhập số câu..." />
                    <button type="button" class="brutal-btn" style="padding: 0 15px; font-size: 14px; white-space: nowrap;" onclick="autoAddQuestions()">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> Lấy ngẫu nhiên
                    </button>
                </div>

                <input type="text" id="searchInput" class="brutal-input" placeholder="Tìm kiếm câu hỏi..." onkeyup="renderQuestions()" />
                
                <div id="questions-list" style="margin-top: 10px;">
                    <!-- Questions will be rendered here by JS -->
                </div>
            </div>
        </div>
    </form>
</div>

<!-- DATA SCRIPT -->
<script>
    const bankQuestions = @Html.Raw(Model.QuestionsJson);
    let variants = [
        { index: 1, questionIds: [] } // Default 1 variant
    ];
    let activeVariantIndex = 1;

    function toggleScoreTiming() {
        const cb = document.getElementById('cbShowScore');
        const container = document.getElementById('scoreTimingContainer');
        if (cb && container) {
            container.style.display = cb.checked ? 'block' : 'none';
        }
    }

    function renderQuestions() {
        const container = document.getElementById('questions-list');
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        
        const activeVariant = variants.find(v => v.index === activeVariantIndex);
        const selectedIds = activeVariant ? activeVariant.questionIds : [];

        container.innerHTML = '';

        bankQuestions.forEach(q => {
            if (q.questionText.toLowerCase().includes(searchTerm)) {
                const isSelected = selectedIds.includes(q.id);
                const div = document.createElement('div');
                div.className = 'question-item';
                
                div.innerHTML = `
                    <div style="flex: 1; font-size: 13px;">
                        <strong style="color: var(--pink)">[${q.difficulty || 'Normal'}]</strong> 
                        ${q.questionText.substring(0, 80)}...
                    </div>
                    ${isSelected
                        ? `<button type="button" onclick="removeFromActiveVariant(${q.id})" style="background: var(--pink); color: white; border: none; padding: 5px 10px; cursor: pointer; font-weight: bold;">-</button>`
                        : `<button type="button" onclick="addToActiveVariant(${q.id})" style="background: var(--black); color: white; border: none; padding: 5px 10px; cursor: pointer; font-weight: bold;">+</button>`
                    }
                `;
                container.appendChild(div);
            }
        });
    }

    function renderVariants() {
        const container = document.getElementById('variants-container');
        container.innerHTML = '';

        variants.forEach(v => {
            const div = document.createElement('div');
            div.className = 'variant-card ' + (v.index === activeVariantIndex ? 'active' : '');
            div.onclick = () => { activeVariantIndex = v.index; renderVariants(); renderQuestions(); };
            
            div.innerHTML = `
                <div style="font-weight: 800; font-size: 16px; margin-bottom: 10px;">
                    Mã đề ${v.index} <span style="font-weight: normal; font-size: 14px; color: #666;">(${v.questionIds.length} câu)</span>
                </div>
                <div style="font-size: 13px; color: #444;">
                    ${v.questionIds.length === 0 ? '<i>Nhấn vào câu hỏi ở cột phải để thêm vào mã đề này.</i>' : 'Các ID: ' + v.questionIds.join(', ')}
                </div>
            `;
            container.appendChild(div);
        });
    }

    function addVariant() {
        const newIndex = variants.length > 0 ? Math.max(...variants.map(v => v.index)) + 1 : 1;
        variants.push({ index: newIndex, questionIds: [] });
        activeVariantIndex = newIndex;
        renderVariants();
        renderQuestions();
    }

    function addToActiveVariant(qId) {
        const variant = variants.find(v => v.index === activeVariantIndex);
        if (variant) {
            if (!variant.questionIds.includes(qId)) {
                variant.questionIds.push(qId);
                renderVariants();
                renderQuestions();
            } else {
                brutalAlert("Câu hỏi này đã có trong mã đề hiện tại!");
            }
        }
    }

    function removeFromActiveVariant(qId) {
        const variant = variants.find(v => v.index === activeVariantIndex);
        if (variant) {
            variant.questionIds = variant.questionIds.filter(id => id !== qId);
            renderVariants();
            renderQuestions();
        }
    }

    function autoAddQuestions() {
        const countInput = document.getElementById('autoAddCount').value;
        const count = parseInt(countInput);
        if (isNaN(count) || count <= 0) {
            brutalAlert("Vui lòng nhập số lượng câu hỏi hợp lệ!");
            return;
        }

        const variant = variants.find(v => v.index === activeVariantIndex);
        if (!variant) return;

        const availableQuestions = bankQuestions.filter(q => !variant.questionIds.includes(q.id));
        
        if (availableQuestions.length === 0) {
            brutalAlert("Mã đề này đã có tất cả câu hỏi trong ngân hàng!");
            return;
        }

        const toAdd = Math.min(count, availableQuestions.length);
        if (toAdd < count) {
            brutalAlert(`Ngân hàng chỉ còn ${toAdd} câu chưa được thêm vào mã đề này. Hệ thống sẽ tự động thêm ${toAdd} câu đó.`);
        }

        // Lấy ngẫu nhiên
        const shuffled = availableQuestions.sort(() => 0.5 - Math.random());
        const selected = shuffled.slice(0, toAdd);

        selected.forEach(q => variant.questionIds.push(q.id));
        renderVariants();
        renderQuestions();
        document.getElementById('autoAddCount').value = ""; // Reset
    }

    function prepareSubmit() {
        // Prepare the JSON to match List<VariantQuestionsDto>
        const payload = variants.map(v => ({
            VariantIndex: v.index,
            QuestionIds: v.questionIds
        }));
        document.getElementById('VariantsJson').value = JSON.stringify(payload);
    }

    function toggleTimeMode() {
        const modeInput = document.querySelector('input[name="TimeMode"]:checked');
        if (!modeInput) return;
        const mode = modeInput.value;
        const fptuContainer = document.getElementById('fptuTimeContainer');
        if (mode === 'fptu') {
            fptuContainer.style.display = 'block';
        } else {
            fptuContainer.style.display = 'none';
        }
    }

    function applyFptuTime() {
        const dateInput = document.getElementById('fptuDate').value;
        const slotInput = document.querySelector('input[name="FptuSlot"]:checked');

        if (!dateInput || !slotInput) return;

        const slot = slotInput.value;
        let startTimeStr = "";
        let endTimeStr = "";

        switch (slot) {
            case "1": startTimeStr = "07:00"; endTimeStr = "09:15"; break;
            case "2": startTimeStr = "09:30"; endTimeStr = "11:45"; break;
            case "3": startTimeStr = "12:30"; endTimeStr = "14:45"; break;
            case "4": startTimeStr = "15:00"; endTimeStr = "17:15"; break;
        }

        // Format is YYYY-MM-DDTHH:mm
        document.getElementById('QuizInput_StartTime').value = dateInput + "T" + startTimeStr;
        document.getElementById('QuizInput_EndTime').value = dateInput + "T" + endTimeStr;
    }

    // Initialize
    renderQuestions();
    renderVariants();
    toggleScoreTiming();
    toggleTimeMode();
</script>
