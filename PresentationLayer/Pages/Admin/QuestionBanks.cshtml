@page
@model PresentationLayer.Pages.Admin.QuestionBanksModel
@{
    ViewData["Title"] = "Quản lý Lịch sử Ngân hàng Câu hỏi";
    Layout = "_Layout";
}
<style>
    .nav-tabs {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
    }
    .nav-tab {
        padding: 10px 20px;
        font-weight: 900;
        border: 3px solid var(--black);
        cursor: pointer;
        background: var(--white);
        color: var(--black);
        box-shadow: 4px 4px 0px var(--black);
        transition: 0.1s;
        text-transform: uppercase;
        font-size: 14px;
    }
    .nav-tab:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px var(--black);
    }
    .nav-tab:active {
        transform: translate(2px, 2px);
        box-shadow: 0px 0px 0px var(--black);
    }
    .nav-tab.active {
        background: var(--pink);
        color: var(--white);
    }

    .tab-content {
        display: none;
    }
    .tab-content.active {
        display: block;
    }

    .btn-view {
        background-color: var(--blue);
        color: var(--white);
        border: 2px solid var(--black);
        padding: 6px 12px;
        font-weight: 800;
        cursor: pointer;
        box-shadow: 2px 2px 0px var(--black);
        text-decoration: none;
        font-size: 12px;
        display: inline-block;
        transition: 0.1s;
    }
    .btn-view:active {
        transform: translate(2px, 2px);
        box-shadow: 0px 0px 0px var(--black);
    }

    .action-badge {
        display: inline-block;
        padding: 5px 10px;
        border: 2px solid var(--black);
        font-weight: 800;
        text-transform: uppercase;
        font-size: 12px;
        box-shadow: 2px 2px 0px var(--black);
    }
    .action-created { background-color: var(--green); color: var(--black); }
    .action-edited { background-color: var(--yellow); color: var(--black); }
    .action-deleted { background-color: var(--red); color: var(--white); }
    .action-restored { background-color: var(--blue); color: var(--white); }
    .action-harddeleted { background-color: #555; color: var(--white); }

    /* Modal Style */
    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0; top: 0;
        width: 100%; height: 100%;
        background-color: rgba(0,0,0,0.6);
        align-items: center; justify-content: center;
    }
    .modal-content {
        background-color: var(--white);
        padding: 30px;
        border: 4px solid var(--black);
        box-shadow: 8px 8px 0px var(--black);
        width: 80%;
        max-width: 800px;
        position: relative;
    }
    .close-modal {
        position: absolute;
        top: 15px; right: 20px;
        font-size: 24px;
        font-weight: 900;
        cursor: pointer;
    }
    pre {
        background: #f4f4f4;
        border: 2px solid var(--black);
        padding: 10px;
        overflow-x: auto;
        font-weight: 600;
        font-size: 14px;
        white-space: pre-wrap;
    }
</style>

<div class="main-wrapper">
    <div style="padding: 30px;">
        <h1 style="color: var(--pink); font-weight: 900; font-size: 28px; text-transform: uppercase; margin-bottom: 20px;">
            <i class="fa-solid fa-clock-rotate-left"></i> LỊCH SỬ NGÂN HÀNG CÂU HỎI
        </h1>

        <div class="nav-tabs">
            <div class="nav-tab active" onclick="switchTab('manual')">Hoạt động cá nhân</div>
            <div class="nav-tab" onclick="switchTab('ai')">Tạo tự động bằng AI</div>
        </div>

        <div style="background-color: var(--white); border: 3px solid var(--black); box-shadow: 4px 4px 0px var(--black); padding: 20px;">
            <!-- Tab 1: Hoạt động thủ công -->
            <div id="manual" class="tab-content active">
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 3px solid var(--black);">
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 130px;">THỜI GIAN</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 150px;">NGƯỜI THỰC HIỆN</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 120px;">HÀNH ĐỘNG</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 100px;">ID CÂU HỎI</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 250px;">TRÍCH ĐOẠN NỘI DUNG</th>
                                <th style="padding: 10px; text-align: center; font-weight: 900; min-width: 150px;">CHI TIẾT</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.ManualLogs)
                            {
                                <tr style="border-bottom: 1px dashed #ccc;">
                                    <td style="padding: 10px; font-weight: 700;">@log.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="padding: 10px; font-weight: 800;">@log.UserName</td>
                                    <td style="padding: 10px;">
                                        <span class="action-badge action-@log.Action.ToLower()">@log.Action</span>
                                    </td>
                                    <td style="padding: 10px; font-weight: 800;">@(log.QuestionBankId.HasValue ? log.QuestionBankId.Value.ToString() : "N/A")</td>
                                    <td style="padding: 10px; font-weight: 500;">@log.QuestionSnippet</td>
                                    <td style="padding: 10px; text-align: center;">
                                        @if (!string.IsNullOrEmpty(log.OldContentJson))
                                        {
                                            <button class="btn-view" onclick="viewJson(this)" data-json="@log.OldContentJson">
                                                <i class="fa-solid fa-eye"></i> XEM NỘI DUNG CŨ
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.ManualLogs.Any())
                {
                    <div style="padding: 20px; text-align: center; font-style: italic; color: #777;">Chưa có hoạt động nào.</div>
                }

                <!-- Pagination cho Manual -->
                <div style="display:flex; justify-content:space-between; align-items:center; font-weight:800; margin-top: 20px;">
                    <div>Trang @Model.CurrentPage / @Model.TotalPages</div>
                    <div>
                        @if (Model.CurrentPage > 1)
                        {
                            <a href="?page=@(Model.CurrentPage - 1)" class="btn-view" style="margin-right:5px;"><i class="fa-solid fa-angle-left"></i> TRƯỚC</a>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <a href="?page=@(Model.CurrentPage + 1)" class="btn-view">SAU <i class="fa-solid fa-angle-right"></i></a>
                        }
                    </div>
                </div>
            </div>

            <!-- Tab 2: Hoạt động bằng AI -->
            <div id="ai" class="tab-content">
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 3px solid var(--black);">
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 130px;">THỜI GIAN</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 150px;">NGƯỜI THỰC HIỆN</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 150px;">CHỦ ĐỀ</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 120px;">LOẠI</th>
                                <th style="padding: 10px; text-align: left; font-weight: 900; min-width: 100px;">SỐ LƯỢNG</th>
                                <th style="padding: 10px; text-align: center; font-weight: 900; min-width: 150px;">CHI TIẾT</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.AILogs)
                            {
                                <tr style="border-bottom: 1px dashed #ccc;">
                                    <td style="padding: 10px; font-weight: 700;">@log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td style="padding: 10px; font-weight: 800;">@log.LecturerUsername</td>
                                    <td style="padding: 10px; font-weight: 700;">@log.Topic</td>
                                    <td style="padding: 10px; font-weight: 700;">@log.QuestionType</td>
                                    <td style="padding: 10px; font-weight: 800;">@log.Quantity câu</td>
                                    <td style="padding: 10px; text-align: center;">
                                        <button class="btn-view"
                                                onclick="viewAiSet(this)"
                                                data-json="@log.GeneratedQuestionsJson"
                                                data-subject="@(!string.IsNullOrEmpty(log.SubjectCode) ? $"[{log.SubjectCode}] {log.SubjectName}" : "Không rõ")"
                                                data-lecturer="@(!string.IsNullOrEmpty(log.LecturerUsername) ? log.LecturerUsername : "Không rõ")"
                                                data-topic="@log.Topic"
                                                data-difficulty="@log.Difficulty"
                                                data-type="@log.QuestionType"
                                                data-created="@log.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")">
                                            <i class="fa-solid fa-eye"></i> XEM BỘ CÂU HỎI
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.AILogs.Any())
                {
                    <div style="padding: 20px; text-align: center; font-style: italic; color: #777;">Chưa có hoạt động nào.</div>
                }
            </div>
        </div>
    </div>
</div>

<div id="jsonModal" class="modal">
    <div class="modal-content">
        <span class="close-modal" onclick="closeModal()">&times;</span>
        <h3 style="color: var(--pink); border-bottom: 3px solid var(--black); padding-bottom:10px; margin-top:0;">
            <i class="fa-solid fa-code"></i> Chi tiết dữ liệu
        </h3>
        <pre id="jsonContent"></pre>
    </div>
</div>

<!-- MODAL XEM BỘ CÂU HỎI AI (định dạng đẹp) -->
<div id="aiSetModal" class="modal">
    <div class="modal-content" style="width: 90%; max-width: 900px; margin: 3% auto; padding: 0; overflow: hidden;">
        <div style="background: var(--black); color: var(--white); padding: 18px 25px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-weight: 900; font-size: 20px; text-transform: uppercase;">
                <i class="fa-solid fa-clock-rotate-left"></i> Chi tiết gói câu hỏi AI
            </span>
            <span class="close-modal" style="position: static; color: var(--white);" onclick="closeAiSet()">&times;</span>
        </div>
        <div style="padding: 25px; max-height: 75vh; overflow-y: auto;">
            <!-- Meta info -->
            <div id="aiSetMeta" style="border: 3px solid var(--black); padding: 18px; margin-bottom: 20px; background: #fafafa; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; font-weight: 800; font-size: 14px;">
                <!-- JS populated -->
            </div>
            <!-- Questions -->
            <div id="aiSetQuestions" style="display: flex; flex-direction: column; gap: 18px;">
                <!-- JS populated -->
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tabId) {
        document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

        event.target.classList.add('active');
        document.getElementById(tabId).classList.add('active');
    }

    function viewJson(btn) {
        var rawJson = btn.getAttribute('data-json');
        try {
            var jsonObj = JSON.parse(rawJson);
            document.getElementById('jsonContent').textContent = JSON.stringify(jsonObj, null, 4);
        } catch (e) {
            document.getElementById('jsonContent').textContent = rawJson;
        }
        document.getElementById('jsonModal').style.display = 'block';
    }

    function closeModal() {
        document.getElementById('jsonModal').style.display = 'none';
    }

    window.onclick = function(event) {
        if (event.target == document.getElementById('jsonModal')) {
            closeModal();
        }
        if (event.target == document.getElementById('aiSetModal')) {
            closeAiSet();
        }
    }

    function escapeHtml(text) {
        if (!text) return "";
        return String(text)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    function closeAiSet() {
        document.getElementById('aiSetModal').style.display = 'none';
    }

    // Hiển thị bộ câu hỏi AI theo định dạng đẹp (giống trang giảng viên)
    function viewAiSet(btn) {
        const rawJson = btn.getAttribute('data-json');
        const subject = btn.getAttribute('data-subject');
        const lecturer = btn.getAttribute('data-lecturer');
        const topic = btn.getAttribute('data-topic');
        const difficulty = btn.getAttribute('data-difficulty');
        const type = btn.getAttribute('data-type');
        const created = btn.getAttribute('data-created');

        const diffText = difficulty === 'Easy' ? 'Dễ' : difficulty === 'Medium' ? 'Trung bình' : difficulty === 'Hard' ? 'Khó' : difficulty;
        const typeText = type === 'MultipleChoice' ? 'Trắc nghiệm (4 lựa chọn)' : type === 'TrueFalse' ? 'Đúng / Sai' : 'Tất cả / Hỗn hợp';

        const meta = document.getElementById('aiSetMeta');
        meta.innerHTML = `
            <div>Môn học: <span style="color: var(--pink);">${escapeHtml(subject)}</span></div>
            <div>Chủ đề: <span style="color: var(--pink);">${escapeHtml(topic)}</span></div>
            <div>Độ khó: <span style="color: var(--pink);">${escapeHtml(diffText)}</span></div>
            <div>Loại câu hỏi: <span style="color: var(--pink);">${escapeHtml(typeText)}</span></div>
            <div>Giảng viên: <span style="color: var(--pink);">${escapeHtml(lecturer)}</span></div>
            <div>Thời gian tạo: <span style="color: var(--pink);">${escapeHtml(created)}</span></div>
        `;

        const list = document.getElementById('aiSetQuestions');
        list.innerHTML = '';

        let questions;
        try {
            questions = JSON.parse(rawJson);
        } catch (e) {
            list.innerHTML = `<div style="color: red; font-weight: 800;">Không thể đọc dữ liệu câu hỏi.</div>`;
            document.getElementById('aiSetModal').style.display = 'block';
            return;
        }

        questions.forEach((q, idx) => {
            const qDiv = document.createElement('div');
            qDiv.style.cssText = 'border: 3px solid var(--black); box-shadow: 4px 4px 0px var(--black); padding: 18px; background: var(--white);';

            let optionsHtml = '';
            const labels = ['A', 'B', 'C', 'D'];
            if (q.questionType === 'MultipleChoice' && q.options) {
                optionsHtml = `<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 12px;">`;
                q.options.forEach((opt, oIdx) => {
                    const isCorrect = labels[oIdx] === q.correctAnswer;
                    optionsHtml += `
                        <div style="border: 2px solid var(--black); padding: 10px; font-weight: 700; ${isCorrect ? 'background:#d7f9ee;' : ''}">
                            <strong>${labels[oIdx]}.</strong> ${escapeHtml(opt)}
                        </div>`;
                });
                optionsHtml += `</div>`;
            } else {
                optionsHtml = `
                    <div style="display: flex; gap: 12px; margin-top: 12px;">
                        <div style="border: 2px solid var(--black); padding: 10px; font-weight: 700; flex: 1; text-align: center; ${q.correctAnswer === 'True' ? 'background:#d7f9ee;' : ''}">ĐÚNG (True)</div>
                        <div style="border: 2px solid var(--black); padding: 10px; font-weight: 700; flex: 1; text-align: center; ${q.correctAnswer === 'False' ? 'background:#d7f9ee;' : ''}">SAI (False)</div>
                    </div>`;
            }

            qDiv.innerHTML = `
                <div style="font-weight: 800; font-size: 15px; line-height: 1.5;">
                    Câu ${idx + 1}: ${escapeHtml(q.content)}
                </div>
                ${optionsHtml}
                <div style="margin-top: 14px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                    <span class="action-badge" style="background:#eee; font-size:11px; box-shadow: 1px 1px 0px var(--black);">Loại: ${q.questionType === 'MultipleChoice' ? 'Trắc nghiệm' : 'Đúng/Sai'}</span>
                    <span class="action-badge" style="background:#dbe9ff; font-size:11px; box-shadow: 1px 1px 0px var(--black); border-style: dashed;">Tags: ${escapeHtml(q.tags || 'AI')}</span>
                </div>
            `;
            list.appendChild(qDiv);
        });

        document.getElementById('aiSetModal').style.display = 'block';
    }
</script>
