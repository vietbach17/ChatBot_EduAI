@page
@model PresentationLayer.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Quản lý Người dùng";
    ViewBag.ActiveMenu = "AdminUsers";
}

@section Styles {
    <style>
        .modal {
            display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;
        }
        .modal-content {
            background-color: var(--white); border: var(--border); box-shadow: 8px 8px 0px var(--black);
            padding: 30px; width: 400px; position: relative;
        }
        .close-btn {
            position: absolute; top: 10px; right: 15px; font-size: 24px; font-weight: 900; cursor: pointer; color: var(--black);
        }
        .form-group { margin-bottom: 15px; display: flex; flex-direction: column; gap: 5px; }
        .form-group label { font-weight: 800; font-size: 12px; }
        .form-group input, .form-group select {
            border: 2px solid var(--black); padding: 10px; font-weight: 700; outline: none;
        }
    </style>
}

<div class="main-wrapper">
    <div style="padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h1 style="color: var(--pink); font-weight: 900; font-size: 28px; text-transform: uppercase;">
                QUẢN LÝ NGƯỜI DÙNG
            </h1>
            <button onclick="document.getElementById('createModal').style.display='flex'" class="brutal-btn" style="background-color: var(--pink); color: var(--white); border: 2px solid var(--black); padding: 10px 20px; font-weight: 900; box-shadow: 2px 2px 0px var(--black);">
                <i class="fa-solid fa-plus"></i> THÊM NGƯỜI DÙNG
            </button>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background:#d4edda; border:2px solid #28a745; color:#155724; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
                <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["WarnMessage"] != null)
        {
            <div style="background:#fff3cd; border:2px solid #f4cf45; color:#856404; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
                <i class="fa-solid fa-triangle-exclamation"></i> @TempData["WarnMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div style="background:#f8d7da; border:2px solid #eb2f64; color:#721c24; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
                <i class="fa-solid fa-circle-xmark"></i> @TempData["ErrorMessage"]
            </div>
        }

        <!-- Danh sách User -->
        <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 3px solid var(--black);">
                        <th style="padding: 10px; text-align: left; font-weight: 900;">ID</th>
                        <th style="padding: 10px; text-align: left; font-weight: 900;">TÀI KHOẢN</th>
                        <th style="padding: 10px; text-align: left; font-weight: 900;">EMAIL</th>
                        <th style="padding: 10px; text-align: left; font-weight: 900;">VAI TRÒ</th>
                        <th style="padding: 10px; text-align: center; font-weight: 900;">TRẠNG THÁI</th>
                        <th style="padding: 10px; text-align: center; font-weight: 900;">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr style="border-bottom: 1px dashed #ccc; background-color: @(user.IsDeleted ? "#fbeaea" : "transparent");">
                            <td style="padding: 10px; font-weight: 700;">@user.Id</td>
                            <td style="padding: 10px; font-weight: 700;">@user.Username</td>
                            <td style="padding: 10px; font-weight: 700;">@(user.Email ?? "-")</td>
                            <td style="padding: 10px; font-weight: 800;">
                                @if(user.Role == "Admin") { <span style="color: var(--pink);">@user.Role</span> }
                                else if(user.Role == "Lecturer") { <span style="color: var(--blue);">@user.Role</span> }
                                else { <span style="color: var(--green);">@user.Role</span> }
                            </td>
                            <td style="padding: 10px; text-align: center; font-weight: 800;">
                                @if(user.IsDeleted) { <span style="color: red;">Đã Xóa</span> }
                                else { <span style="color: var(--green);">Hoạt động</span> }
                            </td>
                            <td style="padding: 10px; text-align: center;">
                                @if(user.Username != User.Identity?.Name)
                                {
                                    <div style="display: flex; gap: 5px; justify-content: center;">
                                        @if(!user.IsDeleted)
                                        {
                                            <button type="button" class="brutal-btn" style="background-color: var(--blue); color: white; border: 2px solid var(--black); padding: 5px 10px; font-weight: 800; font-size: 12px; cursor: pointer; box-shadow: 2px 2px 0px var(--black);" 
                                                    onclick="openUpdateModal(@user.Id, '@user.Username', '@(user.Email ?? "")', '@user.Role')">
                                                <i class="fa-solid fa-pen"></i> SỬA
                                            </button>
                                            <form method="post" asp-page-handler="DeleteUser" style="display:inline;" data-confirm="Bạn có chắc muốn xóa user này?">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="brutal-btn" style="background-color: #ff4d4f; color: white; border: 2px solid var(--black); padding: 5px 10px; font-weight: 800; font-size: 12px; cursor: pointer; box-shadow: 2px 2px 0px var(--black);">
                                                    <i class="fa-solid fa-trash"></i> XÓA
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="RestoreUser" style="display:inline;" data-confirm="Bạn có chắc chắn muốn khôi phục user này không?">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 2px solid var(--black); padding: 5px 10px; font-weight: 800; font-size: 12px; cursor: pointer; box-shadow: 2px 2px 0px var(--black);">
                                                    <i class="fa-solid fa-rotate-left"></i> KHÔI PHỤC
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Create -->
<div id="createModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="document.getElementById('createModal').style.display='none'">&times;</span>
        <h2 style="font-weight: 900; margin-bottom: 20px; color: var(--pink);">THÊM NGƯỜI DÙNG</h2>
        <form method="post" asp-page-handler="AddUser">
            <div class="form-group">
                <label>Tài khoản</label>
                <input type="text" asp-for="CreateModel.Username" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" asp-for="CreateModel.Email" />
            </div>
            <div class="form-group">
                <label>Mật khẩu</label>
                <input type="password" asp-for="CreateModel.Password" required />
            </div>
            <div class="form-group">
                <label>Phân quyền</label>
                <select asp-for="CreateModel.Role">
                    <option value="Student">Sinh viên</option>
                    <option value="Lecturer">Giảng viên</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button type="submit" class="brutal-btn" style="width: 100%; background-color: var(--pink); color: var(--white); border: 2px solid var(--black); padding: 10px; font-weight: 900; box-shadow: 2px 2px 0px var(--black); margin-top: 10px;">
                <i class="fa-solid fa-plus"></i> THÊM MỚI
            </button>
        </form>
    </div>
</div>

<!-- Modal Update -->
<div id="updateModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="document.getElementById('updateModal').style.display='none'">&times;</span>
        <h2 style="font-weight: 900; margin-bottom: 20px; color: var(--blue);">CẬP NHẬT NGƯỜI DÙNG</h2>
        <form method="post" asp-page-handler="UpdateUser">
            <input type="hidden" id="updateId" asp-for="UpdateModel.Id" />
            <div class="form-group">
                <label>Tài khoản</label>
                <input type="text" id="updateUsername" asp-for="UpdateModel.Username" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="updateEmail" asp-for="UpdateModel.Email" />
            </div>
            <div class="form-group">
                <label>Mật khẩu (Bỏ trống nếu không đổi)</label>
                <input type="password" asp-for="UpdateModel.Password" />
            </div>
            <div class="form-group">
                <label>Phân quyền</label>
                <select id="updateRole" asp-for="UpdateModel.Role">
                    <option value="Student">Sinh viên</option>
                    <option value="Lecturer">Giảng viên</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            <button type="submit" class="brutal-btn" style="width: 100%; background-color: var(--blue); color: var(--white); border: 2px solid var(--black); padding: 10px; font-weight: 900; box-shadow: 2px 2px 0px var(--black); margin-top: 10px;">
                <i class="fa-solid fa-save"></i> LƯU THAY ĐỔI
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openUpdateModal(id, username, email, role) {
            document.getElementById('updateId').value = id;
            document.getElementById('updateUsername').value = username;
            document.getElementById('updateEmail').value = email;
            document.getElementById('updateRole').value = role;
            document.getElementById('updateModal').style.display = 'flex';
        }
    </script>
}
