@page
@model PresentationLayer.Pages.Admin.PaymentHistoryModel
@{
    ViewData["Title"] = "Quản lý Giao dịch";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Quản lý Giao dịch</h2>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tìm kiếm (Tên/Email)</label>
                    <input type="text" name="SearchTerm" class="form-control" placeholder="Nhập từ khóa..." value="@Model.SearchTerm" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Cổng thanh toán</label>
                    <select name="SelectedMethod" class="form-select" asp-for="SelectedMethod">
                        <option value="">Tất cả cổng</option>
                        <option value="VNPay">VNPay</option>
                        <option value="PayOS">PayOS</option>
                        <option value="SePay">SePay</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="SelectedStatus" class="form-select" asp-for="SelectedStatus">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Success">Thành công</option>
                        <option value="Pending">Đang xử lý</option>
                        <option value="Failed">Thất bại</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã GD</th>
                    <th>Khách hàng</th>
                    <th>Ngày TT</th>
                    <th>Gói</th>
                    <th>Số tiền</th>
                    <th>Phương thức</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Histories != null && Model.Histories.Any())
                {
                    foreach (var item in Model.Histories)
                    {
                        <tr>
                            <td><span class="text-muted">#@item.TransactionCode</span></td>
                            <td class="fw-bold">@item.UserName</td>
                            <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-secondary">@item.PlanName</span></td>
                            <td class="text-danger fw-bold">@item.Amount.ToString("N0") đ</td>
                            <td>@item.Method</td>
                            <td>
                                @if (item.Status == "Success") { <span class="badge bg-success">Thành công</span> }
                                else if (item.Status == "Failed") { <span class="badge bg-danger">Thất bại</span> }
                                else { <span class="badge bg-warning text-dark">Đang xử lý</span> }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-light border" data-bs-toggle="modal" data-bs-target="#adminInvoiceModal-@item.TransactionId">
                                    Chi tiết
                                </button>

                                <!-- Modal Admin Chi Tiết -->
                                <div class="modal fade" id="adminInvoiceModal-@item.TransactionId" tabindex="-1" aria-hidden="true">
                                  <div class="modal-dialog">
                                    <div class="modal-content">
                                      <div class="modal-header bg-dark text-white">
                                        <h5 class="modal-title">Giao dịch #@item.TransactionCode</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                      </div>
                                      <div class="modal-body">
                                        <ul class="list-group list-group-flush">
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                Khách hàng: <span class="fw-bold">@item.UserName</span>
                                            </li>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                Gói dịch vụ: <span class="badge bg-primary rounded-pill">@item.PlanName</span>
                                            </li>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                Số tiền: <span class="text-danger fw-bold">@item.Amount.ToString("N0") VNĐ</span>
                                            </li>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                Cổng thanh toán: <span>@item.Method</span>
                                            </li>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                Trạng thái: <span>@item.Status</span>
                                            </li>
                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                Ngày GD: <span>@item.Date.ToString("dd/MM/yyyy HH:mm:ss")</span>
                                            </li>
                                        </ul>
                                      </div>
                                    </div>
                                  </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">Không tìm thấy giao dịch nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
