@page
@model PresentationLayer.Pages.Admin.ChunkSettingsModel
@{
    ViewData["Title"] = "Cấu hình Chunk File";
    ViewBag.ActiveMenu = "AdminChunkSettings";
}

@section Styles {
<style>
    .form-group { margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-weight: 900; font-size: 14px; text-transform: uppercase; color: var(--black); }
    .form-group input {
        border: 3px solid var(--black); 
        padding: 15px; 
        font-weight: 700;
        font-size: 18px;
        outline: none; 
        font-family: inherit;
        box-shadow: inset 2px 2px 0px rgba(0,0,0,0.05);
        transition: 0.1s;
    }
    .form-group input:focus {
        border-color: var(--blue);
        box-shadow: 4px 4px 0px var(--blue);
    }
    .form-group .hint { font-size: 13px; font-weight: 700; color: #666; margin-top: 4px; }
    
    .settings-container {
        max-width: 650px;
        margin: 40px auto;
    }
    .setting-card {
        background: var(--white); 
        border: 4px solid var(--black); 
        box-shadow: 8px 8px 0px var(--black);
        padding: 40px;
    }
    
    .btn-brutal-primary {
        background: var(--pink); 
        color: var(--white); 
        border: 4px solid var(--black); 
        padding: 16px; 
        font-weight: 900; 
        font-size: 16px;
        text-transform: uppercase;
        box-shadow: 6px 6px 0px var(--black);
        cursor: pointer;
        transition: 0.1s;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }
    .btn-brutal-primary:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0px var(--black); }
    .btn-brutal-primary:active { transform: translate(4px, 4px); box-shadow: 0px 0px 0px var(--black); }

    .btn-brutal-secondary {
        background: var(--white); 
        color: var(--black); 
        border: 3px dashed var(--black); 
        padding: 14px; 
        font-weight: 900; 
        font-size: 14px;
        text-transform: uppercase;
        box-shadow: 4px 4px 0px var(--black);
        cursor: pointer;
        transition: 0.1s;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 20px;
    }
    .btn-brutal-secondary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--black); background: #f9f9f9; }
    .btn-brutal-secondary:active { transform: translate(2px, 2px); box-shadow: 0px 0px 0px var(--black); }
</style>
}

<div class="main-wrapper">
<div style="padding: 30px;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h1 style="color:var(--pink); font-weight:900; font-size:28px; text-transform:uppercase;">
            <i class="fa-solid fa-scissors"></i> CẤU HÌNH CHUNK FILE
        </h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:#d4edda; border:2px solid #28a745; color:#155724; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:#f8d7da; border:2px solid var(--pink); color:#721c24; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
            <i class="fa-solid fa-circle-xmark"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="settings-container">
        <!-- Form cấu hình -->
        <div class="setting-card">
            <h2 style="font-weight:900; margin-bottom:30px; color:var(--blue); font-size:24px; text-transform:uppercase; border-bottom: 3px solid var(--black); padding-bottom: 15px;">
                <i class="fa-solid fa-sliders"></i> TEMPLATE MẶC ĐỊNH
            </h2>
            <form method="post" asp-page-handler="Save">
                <div class="form-group">
                    <label asp-for="MaxWords">Số từ tối đa mỗi chunk *</label>
                    <input type="number" asp-for="MaxWords" min="@Model.MinMaxWords" max="@Model.MaxMaxWordsLimit" required />
                    <span class="hint"><i class="fa-solid fa-circle-info"></i> Giới hạn từ @Model.MinMaxWords đến @Model.MaxMaxWordsLimit từ. Mặc định: <strong>@Model.DefaultMaxWords</strong>.</span>
                </div>
                <div class="form-group">
                    <label asp-for="OverlapWords">Số từ chồng lấn (overlap) *</label>
                    <input type="number" asp-for="OverlapWords" min="0" max="@Model.MaxOverlapWordsLimit" required />
                    <span class="hint"><i class="fa-solid fa-circle-info"></i> Từ 0 đến @Model.MaxOverlapWordsLimit từ và phải nhỏ hơn số từ tối đa mỗi chunk. Mặc định: <strong>@Model.DefaultOverlapWords</strong>.</span>
                </div>

                <h2 style="font-weight:900; margin:35px 0 25px; color:var(--blue); font-size:24px; text-transform:uppercase; border-bottom: 3px solid var(--black); padding-bottom: 15px;">
                    <i class="fa-solid fa-lock"></i> GIỚI HẠN CHO GIẢNG VIÊN
                </h2>
                <p style="font-weight:700; font-size:13px; color:#666; margin-bottom:20px; line-height:1.6;">
                    Giảng viên tự cấu hình số từ mỗi chunk cho tài liệu của mình, nhưng không được vượt ra ngoài khoảng dưới đây.
                </p>

                <div class="form-group">
                    <label asp-for="LecturerMinWords">Giới hạn dưới (min) *</label>
                    <input type="number" asp-for="LecturerMinWords" min="@Model.MinMaxWords" max="@Model.MaxMaxWordsLimit" required />
                    <span class="hint"><i class="fa-solid fa-circle-info"></i> Số từ mỗi chunk nhỏ nhất Giảng viên được đặt. Mặc định: <strong>@Model.DefaultLecturerMinWords</strong>.</span>
                </div>
                <div class="form-group" style="margin-bottom: 30px;">
                    <label asp-for="LecturerMaxWords">Giới hạn trên (max) *</label>
                    <input type="number" asp-for="LecturerMaxWords" min="@Model.MinMaxWords" max="@Model.MaxMaxWordsLimit" required />
                    <span class="hint"><i class="fa-solid fa-circle-info"></i> Số từ mỗi chunk lớn nhất Giảng viên được đặt, phải lớn hơn hoặc bằng giới hạn dưới. Mặc định: <strong>@Model.DefaultLecturerMaxWords</strong>.</span>
                </div>

                <button type="submit" class="btn-brutal-primary">
                    <i class="fa-solid fa-save"></i> LƯU CẤU HÌNH
                </button>
            </form>
            
            <form method="post" asp-page-handler="Reset" 
                  data-confirm="Khôi phục cấu hình chunk về mặc định (@Model.DefaultMaxWords từ/chunk, chồng lấn @Model.DefaultOverlapWords từ)?">
                <button type="submit" class="btn-brutal-secondary">
                    <i class="fa-solid fa-rotate-left"></i> KHÔI PHỤC MẶC ĐỊNH
                </button>
            </form>
        </div>
    </div>

</div>
</div>
