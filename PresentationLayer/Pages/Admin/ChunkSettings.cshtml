@page
@model PresentationLayer.Pages.Admin.ChunkSettingsModel
@{
    ViewData["Title"] = "Cấu hình Chunk File";
    ViewBag.ActiveMenu = "AdminChunkSettings";
}

@section Styles {
<style>
    .form-group { margin-bottom: 14px; display: flex; flex-direction: column; gap: 5px; }
    .form-group label { font-weight: 800; font-size: 12px; text-transform: uppercase; }
    .form-group input {
        border: 2px solid var(--black); padding: 10px; font-weight: 700;
        outline: none; font-family: inherit;
    }
    .form-group .hint { font-size: 12px; font-weight: 700; color: #777; }
    .setting-card {
        background: var(--white); border: var(--border); box-shadow: var(--shadow);
        padding: 24px;
    }
    .info-table td { padding: 8px 10px; font-size: 13px; font-weight: 700; border-bottom: 1px dashed #ccc; vertical-align: top; }
    .info-table td:first-child { font-weight: 900; white-space: nowrap; }
</style>
}

<div class="main-wrapper">
<div style="padding: 30px;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h1 style="color:var(--pink); font-weight:900; font-size:28px; text-transform:uppercase;">
            <i class="fa-solid fa-scissors"></i> CẤU HÌNH CHUNK FILE
        </h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background:#d4edda; border:2px solid #28a745; color:#155724; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
            <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background:#f8d7da; border:2px solid var(--pink); color:#721c24; padding:12px 16px; font-weight:800; margin-bottom:16px; font-size:13px;">
            <i class="fa-solid fa-circle-xmark"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; align-items:start;">

        <!-- Form cấu hình -->
        <div class="setting-card">
            <h2 style="font-weight:900; margin-bottom:20px; color:var(--blue); font-size:18px;">
                <i class="fa-solid fa-sliders"></i> THÔNG SỐ CHUNK
            </h2>
            <form method="post" asp-page-handler="Save">
                <div class="form-group">
                    <label asp-for="MaxWords">Số từ tối đa mỗi chunk *</label>
                    <input type="number" asp-for="MaxWords" min="@Model.MinMaxWords" max="@Model.MaxMaxWordsLimit" required />
                    <span class="hint">Từ @Model.MinMaxWords đến @Model.MaxMaxWordsLimit từ. Mặc định: @Model.DefaultMaxWords.</span>
                </div>
                <div class="form-group">
                    <label asp-for="OverlapWords">Số từ chồng lấn (overlap) *</label>
                    <input type="number" asp-for="OverlapWords" min="0" max="@Model.MaxOverlapWordsLimit" required />
                    <span class="hint">Từ 0 đến @Model.MaxOverlapWordsLimit từ và phải nhỏ hơn số từ tối đa mỗi chunk. Mặc định: @Model.DefaultOverlapWords.</span>
                </div>
                <div style="display:flex; gap:10px; margin-top:16px;">
                    <button type="submit" class="brutal-btn"
                            style="flex:1; background:var(--pink); color:white; border:2px solid var(--black); padding:12px; font-weight:900; box-shadow:2px 2px 0 var(--black);">
                        <i class="fa-solid fa-save"></i> LƯU CẤU HÌNH
                    </button>
                </div>
            </form>
            <form method="post" asp-page-handler="Reset" style="margin-top:10px;"
                  data-confirm="Khôi phục cấu hình chunk về mặc định (@Model.DefaultMaxWords từ/chunk, chồng lấn @Model.DefaultOverlapWords từ)?">
                <button type="submit" class="brutal-btn"
                        style="width:100%; background:var(--white); color:var(--black); border:2px solid var(--black); padding:10px; font-weight:900; box-shadow:2px 2px 0 var(--black);">
                    <i class="fa-solid fa-rotate-left"></i> KHÔI PHỤC MẶC ĐỊNH
                </button>
            </form>
        </div>

        <!-- Giải thích -->
        <div class="setting-card">
            <h2 style="font-weight:900; margin-bottom:20px; color:var(--blue); font-size:18px;">
                <i class="fa-solid fa-circle-info"></i> CHUNK LÀ GÌ?
            </h2>
            <p style="font-size:13px; font-weight:700; color:#555; margin-bottom:14px;">
                Khi giảng viên tải tài liệu (PDF/DOCX/PPTX) lên, hệ thống trích xuất văn bản rồi chia nhỏ
                thành các <strong>chunk</strong> để tạo Embedding AI phục vụ tìm kiếm ngữ nghĩa khi chat.
            </p>
            <table class="info-table" style="width:100%; border-collapse:collapse;">
                <tr>
                    <td>Số từ tối đa</td>
                    <td>Chunk lớn chứa nhiều ngữ cảnh hơn nhưng embedding kém tập trung; chunk nhỏ tìm kiếm chính xác hơn nhưng dễ mất mạch nội dung.</td>
                </tr>
                <tr>
                    <td>Số từ chồng lấn</td>
                    <td>Số từ cuối của chunk trước được lặp lại ở đầu chunk sau, giúp giữ mạch ngữ cảnh khi nội dung bị cắt giữa chừng.</td>
                </tr>
            </table>
            <div style="margin-top:16px; background:#fff3cd; border:2px solid #f59e0b; color:#856404; padding:12px 14px; font-size:13px; font-weight:700;">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <strong>Lưu ý:</strong> Cấu hình mới chỉ áp dụng cho tài liệu được tải lên / xử lý lại sau khi lưu.
                Các tài liệu đã xử lý trước đó vẫn giữ nguyên chunk cũ.
            </div>
        </div>

    </div>

</div>
</div>
