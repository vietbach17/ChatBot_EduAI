@page
@model PresentationLayer.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewBag.ActiveMenu = "AdminDashboard";
}

<div class="main-wrapper">
    <style>
        .analytics-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
            margin-bottom: 30px;
        }

        .chart-card {
            background-color: var(--white);
            border: var(--border);
            box-shadow: var(--shadow);
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            position: relative;
        }

        .chart-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            border-bottom: 2px dashed #ccc;
            padding-bottom: 12px;
        }

        .btn-toggle-group {
            display: flex;
            gap: 5px;
        }

        .brutal-btn-sm {
            padding: 5px 10px;
            font-weight: 800;
            font-size: 11px;
            text-transform: uppercase;
            border: 2px solid var(--black);
            background: var(--white);
            box-shadow: 1.5px 1.5px 0px var(--black);
            cursor: pointer;
            text-decoration: none;
            color: var(--black);
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .brutal-btn-sm.active {
            background: var(--pink);
            color: var(--white);
            box-shadow: 1.5px 1.5px 0px var(--black);
        }

        .brutal-btn-sm:active {
            transform: translate(1.5px, 1.5px);
            box-shadow: 0px 0px 0px var(--black);
        }

        .user-table-wrapper {
            background-color: var(--white);
            border: var(--border);
            box-shadow: var(--shadow);
            padding: 25px;
            margin-bottom: 30px;
        }

        .user-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        .user-table th, .user-table td {
            border: 2px solid var(--black);
            padding: 12px 15px;
            text-align: left;
            font-weight: 700;
        }

        .user-table th {
            background-color: var(--black);
            color: var(--white);
            font-weight: 900;
            text-transform: uppercase;
            font-size: 13px;
        }

        .user-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .role-badge {
            padding: 3px 8px;
            font-size: 10px;
            font-weight: 900;
            border: 1.5px solid var(--black);
            text-transform: uppercase;
            display: inline-block;
        }

        .role-admin { background: var(--pink); color: var(--white); }
        .role-lecturer { background: var(--blue); color: var(--white); }
        .role-student { background: var(--yellow); color: var(--black); }

        @@media (max-width: 992px) {
            .analytics-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .main-wrapper > div {
                padding: 15px !important;
            }
            .chart-toolbar {
                flex-direction: column;
                align-items: flex-start;
            }
            .user-table-wrapper {
                padding: 15px;
            }
            .user-table-container {
                overflow-x: auto;
            }
        }
    </style>

    <div style="padding: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 5px solid var(--black); padding-bottom: 10px; margin-bottom: 30px; flex-wrap: wrap; gap: 12px;">
            <h1 style="color: var(--pink); font-weight: 900; font-size: 28px; text-transform: uppercase; margin: 0;">
                TỔNG QUAN HỆ THỐNG
            </h1>
            <a href="/Admin/Notifications" style="background-color: var(--yellow); color: var(--black); font-size: 14px; font-weight: 900; padding: 8px 16px; text-transform: uppercase; border: 2px solid var(--black); box-shadow: 3px 3px 0px var(--black); text-decoration: none; display: flex; align-items: center; gap: 8px; transition: transform 0.1s, box-shadow 0.1s;" onmousedown="this.style.transform='translate(3px, 3px)'; this.style.boxShadow='0px 0px 0px var(--black)';" onmouseup="this.style.transform='none'; this.style.boxShadow='3px 3px 0px var(--black)';">
                <i class="fa-solid fa-bell"></i> GỬI THÔNG BÁO
            </a>
        </div>

        <!-- Metrics cards -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px;">
            <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <i class="fa-solid fa-money-bill-wave" style="font-size: 40px; color: var(--pink); margin-bottom: 10px;"></i>
                <div style="font-size: 32px; font-weight: 900; color: var(--black);">@Model.EstimatedRevenue.ToString("N0")<span style="font-size: 20px;">đ</span></div>
                <div style="font-weight: 800; color: #555; text-transform: uppercase; font-size: 14px;">Doanh thu (Tháng)</div>
            </div>
            <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <i class="fa-solid fa-users" style="font-size: 40px; color: var(--blue); margin-bottom: 10px;"></i>
                <div style="font-size: 36px; font-weight: 900; color: var(--black);">@Model.TotalUsers</div>
                <div style="font-weight: 800; color: #555; text-transform: uppercase; font-size: 14px;">Người dùng</div>
            </div>
            <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <i class="fa-solid fa-book" style="font-size: 40px; color: var(--green); margin-bottom: 10px;"></i>
                <div style="font-size: 36px; font-weight: 900; color: var(--black);">@Model.TotalSubjects</div>
                <div style="font-weight: 800; color: #555; text-transform: uppercase; font-size: 14px;">Môn học</div>
            </div>
            <div style="background-color: var(--white); border: var(--border); box-shadow: var(--shadow); padding: 20px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <i class="fa-solid fa-file-pdf" style="font-size: 40px; color: var(--yellow); margin-bottom: 10px;"></i>
                <div style="font-size: 36px; font-weight: 900; color: var(--black);">@Model.TotalDocuments</div>
                <div style="font-weight: 800; color: #555; text-transform: uppercase; font-size: 14px;">Tài liệu</div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="analytics-grid">
            <div class="chart-card">
                <div class="chart-toolbar">
                    <h3 style="font-weight: 900; font-size: 18px; text-transform: uppercase; margin: 0; color: var(--blue);">
                        <i class="fa-solid fa-robot"></i> Thống Kê Tiêu Thụ Token
                    </h3>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <div class="btn-toggle-group">
                            <button onclick="changeTokenType('bar')" id="btn-token-bar" class="brutal-btn-sm active"><i class="fa-solid fa-chart-bar"></i> Cột</button>
                            <button onclick="changeTokenType('line')" id="btn-token-line" class="brutal-btn-sm"><i class="fa-solid fa-chart-line"></i> Đường</button>
                        </div>
                        <div class="btn-toggle-group">
                            <button onclick="changeTokenUnit('day')" id="btn-token-day" class="brutal-btn-sm">Ngày</button>
                            <button onclick="changeTokenUnit('month')" id="btn-token-month" class="brutal-btn-sm active">Tháng</button>
                            <button onclick="changeTokenUnit('year')" id="btn-token-year" class="brutal-btn-sm">Năm</button>
                        </div>
                        <select id="tokenMonthSelect" onchange="updateTokenChart()" class="brutal-select" style="display: none; padding: 3px 5px; font-size: 11px; border: 2px solid #000; font-weight: 800;">
                            <option value="1">Tháng 1</option><option value="2">Tháng 2</option><option value="3">Tháng 3</option>
                            <option value="4">Tháng 4</option><option value="5">Tháng 5</option><option value="6">Tháng 6</option>
                            <option value="7">Tháng 7</option><option value="8">Tháng 8</option><option value="9">Tháng 9</option>
                            <option value="10">Tháng 10</option><option value="11">Tháng 11</option><option value="12">Tháng 12</option>
                        </select>
                        <select id="tokenYearSelect" onchange="updateTokenChart()" class="brutal-select" style="padding: 3px 5px; font-size: 11px; border: 2px solid #000; font-weight: 800;">
                        </select>
                    </div>
                </div>
                <div style="position: relative; width: 100%; height: 320px;">
                    <canvas id="tokenChart"></canvas>
                </div>
            </div>

            <div class="chart-card">
                <div class="chart-toolbar">
                    <h3 style="font-weight: 900; font-size: 18px; text-transform: uppercase; margin: 0; color: var(--pink);">
                        <i class="fa-solid fa-money-check-dollar"></i> Thống Kê Doanh Thu (VNĐ)
                    </h3>
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                        <div class="btn-toggle-group">
                            <button onclick="changeRevenueType('bar')" id="btn-rev-bar" class="brutal-btn-sm active"><i class="fa-solid fa-chart-bar"></i> Cột</button>
                            <button onclick="changeRevenueType('line')" id="btn-rev-line" class="brutal-btn-sm"><i class="fa-solid fa-chart-line"></i> Đường</button>
                        </div>
                        <div class="btn-toggle-group">
                            <button onclick="changeRevenueUnit('day')" id="btn-rev-day" class="brutal-btn-sm">Ngày</button>
                            <button onclick="changeRevenueUnit('month')" id="btn-rev-month" class="brutal-btn-sm active">Tháng</button>
                            <button onclick="changeRevenueUnit('year')" id="btn-rev-year" class="brutal-btn-sm">Năm</button>
                        </div>
                        <select id="revenueMonthSelect" onchange="updateRevenueChart()" class="brutal-select" style="display: none; padding: 3px 5px; font-size: 11px; border: 2px solid #000; font-weight: 800;">
                            <option value="1">Tháng 1</option><option value="2">Tháng 2</option><option value="3">Tháng 3</option>
                            <option value="4">Tháng 4</option><option value="5">Tháng 5</option><option value="6">Tháng 6</option>
                            <option value="7">Tháng 7</option><option value="8">Tháng 8</option><option value="9">Tháng 9</option>
                            <option value="10">Tháng 10</option><option value="11">Tháng 11</option><option value="12">Tháng 12</option>
                        </select>
                        <select id="revenueYearSelect" onchange="updateRevenueChart()" class="brutal-select" style="padding: 3px 5px; font-size: 11px; border: 2px solid #000; font-weight: 800;">
                        </select>
                    </div>
                </div>
                <div style="position: relative; width: 100%; height: 320px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <div class="user-table-wrapper">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid var(--black); padding-bottom: 12px; flex-wrap: wrap; gap: 15px;">
                <h2 style="font-weight: 900; font-size: 20px; text-transform: uppercase; margin: 0; color: var(--black);">
                    <i class="fa-solid fa-users-gear"></i> Chi Tiết Hoạt Động Người Dùng
                </h2>
                <input type="text" id="userSearchInput" onkeyup="filterUserTable()" class="brutal-input" placeholder="Tìm kiếm tài khoản..." style="width: 250px; font-size: 13px; padding: 6px 12px; margin: 0;" />
            </div>

            <div class="user-table-container">
                <table class="user-table" id="userTable">
                    <thead>
                        <tr>
                            <th style="width: 80px; text-align: center;">ID</th>
                            <th>Tài khoản</th>
                            <th style="width: 150px;">Vai trò</th>
                            <th style="width: 150px;">Gói Đăng ký</th>
                            <th style="width: 180px; text-align: right;">Token đã tiêu thụ</th>
                            <th style="width: 180px; text-align: right;">Tổng số tiền đã chi</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.UserAnalytics)
                        {
                            <tr>
                                <td style="text-align: center; color: #666; font-size: 13px;">@user.UserId</td>
                                <td style="font-weight: 800;">@user.Username</td>
                                <td>
                                    <span class="role-badge @(user.Role == "Admin" ? "role-admin" : user.Role == "Lecturer" ? "role-lecturer" : "role-student")">
                                        @user.Role
                                    </span>
                                </td>
                                <td style="font-weight: 800;">
                                    <span style="color: @(user.SubscriptionPlan == "Basic" ? "#666" : "var(--pink)");">@user.SubscriptionPlan</span>
                                </td>
                                <td style="text-align: right; font-weight: 800; font-family: monospace; font-size: 15px;">
                                    @user.TotalTokensUsed.ToString("N0")
                                </td>
                                <td style="text-align: right; font-weight: 800; color: var(--green); font-size: 15px;">
                                    @user.TotalAmountSpent.ToString("N0")đ
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/courseHub").build();
        connection.on("PaymentStatusUpdated", function (transactionId, newStatus) { if (newStatus === "Success") window.location.reload(); });
        connection.start().catch(function (err) { console.error(err.toString()); });

        const rawTokens = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TokenStats));
        const rawRevenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueStats));

        let tokenChartInstance = null, tokenChartType = 'bar', tokenChartUnit = 'month', tokenSelectedYear = null, tokenSelectedMonth = new Date().getMonth() + 1;
        let revenueChartInstance = null, revenueChartType = 'bar', revenueChartUnit = 'month', revenueSelectedYear = null, revenueSelectedMonth = new Date().getMonth() + 1;

        document.addEventListener("DOMContentLoaded", function () {
            initializeSelectors();
            renderTokenChart();
            renderRevenueChart();
        });

        function initializeSelectors() {
            const tokenYears = [...new Set(rawTokens.map(item => item.Year))].sort((a, b) => b - a);
            const revenueYears = [...new Set(rawRevenue.map(item => item.Year))].sort((a, b) => b - a);
            const currentYear = new Date().getFullYear();
            const tSelect = document.getElementById("tokenYearSelect");
            const rSelect = document.getElementById("revenueYearSelect");
            if (tokenYears.length === 0) tokenYears.push(currentYear);
            tokenYears.forEach(year => { const opt = document.createElement("option"); opt.value = year; opt.text = "Năm " + year; tSelect.appendChild(opt); });
            tokenSelectedYear = tokenYears[0];
            if (revenueYears.length === 0) revenueYears.push(currentYear);
            revenueYears.forEach(year => { const opt = document.createElement("option"); opt.value = year; opt.text = "Năm " + year; rSelect.appendChild(opt); });
            revenueSelectedYear = revenueYears[0];
            document.getElementById("tokenMonthSelect").value = tokenSelectedMonth;
            document.getElementById("revenueMonthSelect").value = revenueSelectedMonth;
        }

        function buildChartConfig(type, labels, data, color) {
            return { type: type, data: { labels: labels, datasets: [{ label: color === '#4fa8db' ? 'Lượng Token' : 'Doanh thu (đ)', data: data, backgroundColor: color, borderColor: '#000000', borderWidth: 3, fill: type === 'line', tension: 0.1 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: '#ddd' }, ticks: { color: '#000', font: { weight: '800' } } }, x: { grid: { display: false }, ticks: { color: '#000', font: { weight: '800' } } } } } };
        }

        async function renderTokenChart() {
            const ctx = document.getElementById('tokenChart').getContext('2d');
            let labels = [], data = [];
            if (tokenChartUnit === 'day') {
                document.getElementById("tokenMonthSelect").style.display = "inline-block";
                document.getElementById("tokenYearSelect").style.display = "inline-block";
                const dIM = new Date(tokenSelectedYear, tokenSelectedMonth, 0).getDate();
                labels = Array.from({length: dIM}, (_, i) => i + 1);
                data = Array(dIM).fill(0);
                try {
                    const res = await fetch(`?handler=DailyTokenStats&year=${tokenSelectedYear}&month=${tokenSelectedMonth}`);
                    const result = await res.json();
                    if (result.success) result.data.forEach(item => { data[(item.day || item.Day) - 1] = item.totalTokens || item.TotalTokens; });
                } catch (e) { console.error(e); }
            } else if (tokenChartUnit === 'month') {
                document.getElementById("tokenMonthSelect").style.display = "none";
                document.getElementById("tokenYearSelect").style.display = "inline-block";
                labels = ["T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8", "T9", "T10", "T11", "T12"];
                data = Array(12).fill(0);
                rawTokens.forEach(item => { if (item.Year == tokenSelectedYear) data[item.Month - 1] = item.TotalTokens; });
            } else {
                document.getElementById("tokenMonthSelect").style.display = "none";
                document.getElementById("tokenYearSelect").style.display = "none";
                const yMap = {}; rawTokens.forEach(item => { yMap[item.Year] = (yMap[item.Year] || 0) + item.TotalTokens; });
                labels = Object.keys(yMap).sort(); data = labels.map(y => yMap[y]); labels = labels.map(y => "Năm " + y);
            }
            if (tokenChartInstance) tokenChartInstance.destroy();
            tokenChartInstance = new Chart(ctx, buildChartConfig(tokenChartType, labels, data, '#4fa8db'));
        }

        function changeTokenType(type) { tokenChartType = type; document.getElementById("btn-token-bar").classList.toggle("active", type === 'bar'); document.getElementById("btn-token-line").classList.toggle("active", type === 'line'); renderTokenChart(); }
        function changeTokenUnit(unit) { tokenChartUnit = unit; document.getElementById("btn-token-day").classList.toggle("active", unit === 'day'); document.getElementById("btn-token-month").classList.toggle("active", unit === 'month'); document.getElementById("btn-token-year").classList.toggle("active", unit === 'year'); renderTokenChart(); }
        function updateTokenChart() { tokenSelectedYear = document.getElementById("tokenYearSelect").value; tokenSelectedMonth = document.getElementById("tokenMonthSelect").value; renderTokenChart(); }

        async function renderRevenueChart() {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            let labels = [], data = [];
            if (revenueChartUnit === 'day') {
                document.getElementById("revenueMonthSelect").style.display = "inline-block";
                document.getElementById("revenueYearSelect").style.display = "inline-block";
                const dIM = new Date(revenueSelectedYear, revenueSelectedMonth, 0).getDate();
                labels = Array.from({length: dIM}, (_, i) => i + 1);
                data = Array(dIM).fill(0);
                try {
                    const res = await fetch(`?handler=DailyRevenueStats&year=${revenueSelectedYear}&month=${revenueSelectedMonth}`);
                    const result = await res.json();
                    if (result.success) result.data.forEach(item => { data[(item.day || item.Day) - 1] = item.totalAmount || item.TotalAmount; });
                } catch (e) { console.error(e); }
            } else if (revenueChartUnit === 'month') {
                document.getElementById("revenueMonthSelect").style.display = "none";
                document.getElementById("revenueYearSelect").style.display = "inline-block";
                labels = ["T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8", "T9", "T10", "T11", "T12"];
                data = Array(12).fill(0);
                rawRevenue.forEach(item => { if (item.Year == revenueSelectedYear) data[item.Month - 1] = item.TotalAmount; });
            } else {
                document.getElementById("revenueMonthSelect").style.display = "none";
                document.getElementById("revenueYearSelect").style.display = "none";
                const yMap = {}; rawRevenue.forEach(item => { yMap[item.Year] = (yMap[item.Year] || 0) + item.TotalAmount; });
                labels = Object.keys(yMap).sort(); data = labels.map(y => yMap[y]); labels = labels.map(y => "Năm " + y);
            }
            if (revenueChartInstance) revenueChartInstance.destroy();
            revenueChartInstance = new Chart(ctx, buildChartConfig(revenueChartType, labels, data, '#eb2f64'));
        }

        function changeRevenueType(type) { revenueChartType = type; document.getElementById("btn-rev-bar").classList.toggle("active", type === 'bar'); document.getElementById("btn-rev-line").classList.toggle("active", type === 'line'); renderRevenueChart(); }
        function changeRevenueUnit(unit) { revenueChartUnit = unit; document.getElementById("btn-rev-day").classList.toggle("active", unit === 'day'); document.getElementById("btn-rev-month").classList.toggle("active", unit === 'month'); document.getElementById("btn-rev-year").classList.toggle("active", unit === 'year'); renderRevenueChart(); }
        function updateRevenueChart() { revenueSelectedYear = document.getElementById("revenueYearSelect").value; revenueSelectedMonth = document.getElementById("revenueMonthSelect").value; renderRevenueChart(); }

        function filterUserTable() {
            const input = document.getElementById("userSearchInput");
            const filter = input.value.toUpperCase();
            const table = document.getElementById("userTable");
            const tr = table.getElementsByTagName("tr");
            for (let i = 1; i < tr.length; i++) {
                const td = tr[i].getElementsByTagName("td")[1];
                if (td) {
                    const txtValue = td.textContent || td.innerText;
                    tr[i].style.display = txtValue.toUpperCase().indexOf(filter) > -1 ? "" : "none";
                }
            }
        }
    </script>
}

