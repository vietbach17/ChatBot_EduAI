@page
@model PresentationLayer.Pages.IndexModel
@{
    ViewBag.ActiveMenu = "Overview";
    ViewData["Title"] = "Tổng quan";
}

<div class="main-wrapper" style="padding: 40px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px;">
        <div>
            <h1 style="color: var(--pink); font-weight: 900; font-size: 32px; text-transform: uppercase; text-shadow: 2px 2px 0px var(--black); margin-bottom: 5px;">
                Tổng quan học tập
            </h1>
            <p style="font-weight: 700; color: #555; font-size: 14px;">Chào mừng bạn quay trở lại. Hôm nay bạn muốn học gì?</p>
        </div>
        <div>
            <a asp-page="/Chat/Index" class="brutal-btn" style="background-color: var(--yellow); color: var(--black); border: 3px solid var(--black); padding: 10px 20px; font-weight: 900; font-size: 16px; text-decoration: none; box-shadow: 4px 4px 0px var(--black); display: inline-flex; align-items: center; gap: 8px;">
                <i class="fa-solid fa-robot"></i> TRÒ CHUYỆN VỚI AI
            </a>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 30px;">
        <!-- STAT 1: Môn học -->
        <div style="background-color: var(--white); border: 3px solid var(--black); box-shadow: 6px 6px 0px var(--black); padding: 25px; display: flex; flex-direction: column;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                <div style="background-color: var(--green); width: 50px; height: 50px; border: 2px solid var(--black); display: flex; align-items: center; justify-content: center; font-size: 20px; color: var(--black); box-shadow: 2px 2px 0px var(--black);">
                    <i class="fa-solid fa-book-open"></i>
                </div>
                <div style="font-size: 40px; font-weight: 900; color: var(--black); line-height: 1;">
                    @Model.TotalSubjects
                </div>
            </div>
            <div style="font-weight: 800; font-size: 18px; color: var(--black); text-transform: uppercase; margin-bottom: 5px;">Môn học sẵn có</div>
            <div style="font-weight: 700; font-size: 12px; color: #666; margin-bottom: 20px; flex: 1;">Khám phá các môn học và tài liệu được giảng viên biên soạn.</div>
            <a asp-page="/StudentDocument/Subjects" style="color: var(--pink); font-weight: 800; font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 5px;">
                Xem danh sách <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>

        <!-- STAT 2: Gói hội viên -->
        <div style="background-color: var(--white); border: 3px solid var(--black); box-shadow: 6px 6px 0px var(--black); padding: 25px; display: flex; flex-direction: column;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                <div style="background-color: var(--blue); width: 50px; height: 50px; border: 2px solid var(--black); display: flex; align-items: center; justify-content: center; font-size: 20px; color: var(--black); box-shadow: 2px 2px 0px var(--black);">
                    <i class="fa-solid fa-crown"></i>
                </div>
            </div>
            <div style="font-weight: 800; font-size: 18px; color: var(--black); text-transform: uppercase; margin-bottom: 5px;">Gói hiện tại: @(Model.SubscriptionInfo?.CurrentPlan ?? "Free")</div>
            
            @if (Model.SubscriptionInfo != null && Model.SubscriptionInfo.MonthlyLimit > 0)
            {
                double percentage = 0;
                if (Model.SubscriptionInfo.MonthlyLimit >= 999999999) { percentage = 100; }
                else if (Model.SubscriptionInfo.MonthlyLimit > 0) {
                    percentage = ((double)Model.SubscriptionInfo.Remaining / Model.SubscriptionInfo.MonthlyLimit) * 100;
                }
                <div style="font-weight: 700; font-size: 12px; color: #666; margin-bottom: 10px; flex: 1;">
                    Bạn còn <strong style="color: var(--black); font-size: 14px;">@(Model.SubscriptionInfo.MonthlyLimit >= 999999999 ? "∞" : Math.Round(percentage) + "%")</strong> token trong tháng.
                </div>
                <!-- Progress bar -->
                <div style="width: 100%; height: 12px; border: 2px solid var(--black); background: #eee; margin-bottom: 20px; overflow: hidden;">
                    <div style="height: 100%; background: var(--pink); width: @percentage%; border-right: 2px solid var(--black);"></div>
                </div>
            }
            else
            {
                <div style="font-weight: 700; font-size: 12px; color: #666; margin-bottom: 20px; flex: 1;">
                    Bạn chưa có gói hội viên nào.
                </div>
            }

            <a asp-page="/Subscription/Index" style="color: var(--blue); font-weight: 800; font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 5px;">
                Nâng cấp gói <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
