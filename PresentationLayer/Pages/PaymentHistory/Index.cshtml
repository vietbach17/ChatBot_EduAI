@page
@model PresentationLayer.Pages.PaymentHistory.IndexModel
@{
    ViewData["Title"] = "Lịch sử thanh toán";
}

<div class="container mt-4">
    <h2 class="mb-4">Lịch sử thanh toán</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Phương thức</label>
                    <select name="method" class="form-select" asp-for="SelectedMethod">
                        <option value="">Tất cả</option>
                        <option value="VNPay">VNPay</option>
                        <option value="PayOS">PayOS</option>
                        <option value="SePay">SePay</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select" asp-for="SelectedStatus">
                        <option value="">Tất cả</option>
                        <option value="Success">Thành công</option>
                        <option value="Pending">Đang xử lý</option>
                        <option value="Failed">Thất bại</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Ngày TT</th>
                    <th>Gói dịch vụ</th>
                    <th>Số tiền</th>
                    <th>Phương thức</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Histories != null && Model.Histories.Any())
                {
                    foreach (var item in Model.Histories)
                    {
                        <tr>
                            <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-primary">@item.PlanName</span></td>
                            <td class="text-danger fw-bold">@item.Amount.ToString("N0") VNĐ</td>
                            <td>
                                @if (item.Method == "VNPay") { <span class="badge bg-info text-dark">VNPay</span> }
                                else if (item.Method == "PayOS") { <span class="badge bg-primary">PayOS</span> }
                                else if (item.Method == "SePay") { <span class="badge bg-success">SePay</span> }
                                else { <span class="badge bg-secondary">@item.Method</span> }
                            </td>
                            <td>
                                @if (item.Status == "Success") { <span class="text-success"><i class="bi bi-check-circle-fill"></i> Thành công</span> }
                                else if (item.Status == "Failed") { <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Thất bại</span> }
                                else { <span class="text-warning"><i class="bi bi-clock-fill"></i> Đang xử lý</span> }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#invoiceModal-@item.TransactionId">
                                    Chi tiết
                                </button>

                                <!-- Modal Chi Tiết Hóa Đơn -->
                                <div class="modal fade" id="invoiceModal-@item.TransactionId" tabindex="-1" aria-hidden="true">
                                  <div class="modal-dialog">
                                    <div class="modal-content">
                                      <div class="modal-header bg-light">
                                        <h5 class="modal-title">Hóa đơn #@item.TransactionCode</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                      </div>
                                      <div class="modal-body">
                                        <table class="table table-bordered">
                                            <tr><th class="bg-light w-50">Mã giao dịch</th><td>@item.TransactionCode</td></tr>
                                            <tr><th class="bg-light">Khách hàng</th><td>@item.UserName</td></tr>
                                            <tr><th class="bg-light">Gói đăng ký</th><td>@item.PlanName</td></tr>
                                            <tr><th class="bg-light">Số tiền</th><td class="text-danger fw-bold">@item.Amount.ToString("N0") VNĐ</td></tr>
                                            <tr><th class="bg-light">Phương thức</th><td>@item.Method</td></tr>
                                            <tr><th class="bg-light">Trạng thái</th><td>@item.Status</td></tr>
                                            <tr><th class="bg-light">Ngày thanh toán</th><td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td></tr>
                                        </table>
                                      </div>
                                      <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                        @if(item.Status == "Success") {
                                            <form method="post" asp-page-handler="ResendEmail" asp-route-id="@item.TransactionId">
                                                <button type="submit" class="btn btn-primary"><i class="bi bi-envelope"></i> Gửi lại email</button>
                                            </form>
                                        }
                                      </div>
                                    </div>
                                  </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">Chưa có dữ liệu lịch sử thanh toán</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
